PATCH {{baseUrl}}/api/v{{apiVersion}}/shipments/{{shipmentId}}/issue
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "issueReason": "The package label was damaged during pickup."
}

