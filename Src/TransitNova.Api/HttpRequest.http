@baseUrl =  http://localhost:5200
@apiVersion = 1
@accessToken = replace-with-a-valid-jwt-access-token
@userId = 11111111-1111-1111-1111-111111111111
@carrierId = 22222222-2222-2222-2222-222222222222
@operationManagerId = 33333333-3333-3333-3333-333333333333
@shipmentId = 44444444-4444-4444-4444-444444444444
@receiverId = 55555555-5555-5555-5555-555555555555
@bundleId = 66666666-6666-6666-6666-666666666666
@warehouseId = 77777777-7777-7777-7777-777777777777
@zoneId = 88888888-8888-8888-8888-888888888888
@tripId = 99999999-9999-9999-9999-999999999999
@roleId = aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
@vehicleId = bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb
@subscriptionId = cccccccc-cccc-cccc-cccc-cccccccccccc
@refreshTokenId = dddddddd-dddd-dddd-dddd-dddddddddddd
@governmentId = 1
@countryId = 1
@cityId = 1
@trackingNumber = TN-2026-000184
@plateNumber = ABC-4821

### Authentication - Register
POST {{baseUrl}}/api/auth/register
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "userName": "ahmed.mohamed",
  "email": "ahmed.mohamed@example.com",
  "password": "TransitNova#2026",
  "confirmPassword": "TransitNova#2026",
  "phoneNumber": "+201001234567",
  "firstName": "Ahmed H.",
  "lastName": "Mohamed",
  "address": "12 Tahrir Street, Cairo",
  "userType": "User",
  "cityId": {{cityId}}
}

### Authentication - Login
POST {{baseUrl}}/api/auth/login
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "password": "TransitNova#2026",
  "email": "ahmed.mohamed@example.com"
}

### Authentication - Change password
PUT {{baseUrl}}/api/auth/change-password
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "currentPassword": "TransitNova#2026",
  "newPassword": "TransitNova#2027",
  "confirmNewPassword": "TransitNova#2027"
}

### Authentication - Sign out
POST {{baseUrl}}/api/auth/signout
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Accept: application/json

### Tokens - Rotate refresh token
POST {{baseUrl}}/api/v{{apiVersion}}/refresh-tokens
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "token": "replace-with-a-valid-refresh-token"
}

### Tokens - Revoke refresh token
DELETE {{baseUrl}}/api/v{{apiVersion}}/refresh-tokens/{{refreshTokenId}}
X-Idempotency-Key: {{$guid}}
Accept: application/json

### Locations - Get countries
GET {{baseUrl}}/api/v{{apiVersion}}/countries
Accept: application/json

### Locations - Get governments for country
GET {{baseUrl}}/api/v{{apiVersion}}/countries/{{countryId}}/governments
Accept: application/json

### Locations - Get cities for government
GET {{baseUrl}}/api/v{{apiVersion}}/governments/{{governmentId}}/cities
Accept: application/json

### User subscriptions - Subscribe to bundle
POST {{baseUrl}}/api/v{{apiVersion}}/subscriptions/bundles/{{bundleId}}/subscription
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Accept: application/json

### User subscriptions - Unsubscribe from bundle
DELETE {{baseUrl}}/api/v{{apiVersion}}/subscriptions/bundles/{{bundleId}}/subscription
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Accept: application/json

### User shipments - Create shipment
POST {{baseUrl}}/api/v{{apiVersion}}/shipments
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "receiver": {
    "firstName": "Mariam",
    "senderId": "{{userId}}",
    "lastName": "Hassan",
    "email": "mariam.hassan@example.com",
    "phoneNumber": "+201112345678",
    "address": "25 El-Nasr Road, Alexandria",
    "cityId": {{cityId}}
  },
  "packageSpecification": {
    "weight": 12.5,
    "width": 40.0,
    "height": 30.0,
    "length": 55.0
  },
  "currency": "EGP",
  "pickUpDate": "2026-07-15T09:30:00Z",
  "transportationMode": "Land",
  "shipmentDeliveryType": "Express",
  "deliveryAddress": "25 El-Nasr Road, Alexandria",
  "pickupAddress": "12 Tahrir Street, Cairo",
  "packageBundleId": "{{bundleId}}"
}

### User shipments - Update shipment
PUT {{baseUrl}}/api/v{{apiVersion}}/shipments/{{shipmentId}}
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Content-Type: application/json
Accept: application/json

{
  "receiverId": "{{receiverId}}",
  "deliveryAddress": "30 Corniche Road, Alexandria",
  "pickupAddress": "14 Tahrir Street, Cairo",
  "packageSpecification": {
    "weight": 13.0,
    "width": 42.0,
    "height": 31.0,
    "length": 56.0
  },
  "shipmentType": "Express",
  "transportationMode": "Land"
}

### User shipments - Cancel shipment
PATCH {{baseUrl}}/api/v{{apiVersion}}/shipments/{{shipmentId}}
Authorization: Bearer {{accessToken}}
X-Idempotency-Key: {{$guid}}
Accept: application/json

