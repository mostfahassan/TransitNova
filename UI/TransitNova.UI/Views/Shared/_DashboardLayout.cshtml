@using Microsoft.AspNetCore.Html
@using TransitNova.UI.ViewModels
@{
    Layout = null;

    var navItems = ViewData["DashboardNavItems"] as IEnumerable<DashboardNavItemViewModel>
        ?? new[]
        {
            new DashboardNavItemViewModel("Overview", "#", "grid", true),
            new DashboardNavItemViewModel("Shipments", "#", "truck"),
            new DashboardNavItemViewModel("Trips", "#", "route"),
            new DashboardNavItemViewModel("Carriers", "#", "users"),
            new DashboardNavItemViewModel("Analytics", "#", "chart"),
            new DashboardNavItemViewModel("Settings", "#", "settings")
        };

    var dashboardRole = ViewData["DashboardRole"]?.ToString() ?? "Operations";
    var dashboardTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    var dashboardSubtitle = ViewData["DashboardSubtitle"]?.ToString() ?? "Monitor logistics activity, exceptions, capacity, and daily movement.";
    var userName = ViewData["DashboardUserName"]?.ToString() ?? User.Identity?.Name ?? "TransitNova User";
    var userInitials = string.Join(string.Empty, userName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(part => part[0])).ToUpperInvariant();
}
<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@dashboardTitle - TransitNova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="~/Tailwind/tailwind.config.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/Dashboard/dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body h-full overflow-hidden">
    <div class="dashboard-grid-bg flex h-screen bg-dashboard-bg">
        <div class="dashboard-sidebar-overlay fixed inset-0 z-40 hidden bg-slate-950/30 backdrop-blur-sm lg:hidden" data-dashboard-sidebar-overlay></div>

        <aside class="hidden h-full w-72 shrink-0 border-r border-slate-200 bg-white/95 lg:flex lg:flex-col">
            @RenderSidebar(navItems, dashboardRole)
        </aside>

        <aside class="dashboard-mobile-sidebar fixed inset-y-0 left-0 z-50 flex h-full w-72 -translate-x-full flex-col border-r border-slate-200 bg-white transition-transform duration-300 ease-smooth lg:hidden" data-dashboard-sidebar>
            @RenderSidebar(navItems, dashboardRole)
        </aside>

        <div class="flex min-w-0 flex-1 flex-col">
            <header class="sticky top-0 z-30 border-b border-slate-200 bg-white/88 px-4 py-3 backdrop-blur-xl sm:px-6 lg:px-8">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex min-w-0 items-center gap-3">
                        <button class="grid h-10 w-10 place-items-center rounded-lg border border-slate-200 bg-white text-slate-700 transition-colors duration-200 hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dashboard-primary lg:hidden" type="button" aria-label="Open dashboard navigation" aria-expanded="false" data-dashboard-sidebar-toggle>
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M4 7H20M4 12H20M4 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                            </svg>
                        </button>
                        <div class="min-w-0">
                            <p class="font-mono text-[11px] font-extrabold uppercase tracking-wideTech text-slate-500">@dashboardRole workspace</p>
                            <h1 class="truncate text-xl font-black tracking-tight text-slate-950 sm:text-2xl">@dashboardTitle</h1>
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <button class="relative grid h-10 w-10 place-items-center rounded-lg border border-slate-200 bg-white text-slate-700 transition-colors duration-200 hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dashboard-primary" type="button" aria-label="Notifications">
                            <span class="absolute right-2.5 top-2.5 h-2 w-2 rounded-full bg-dashboard-danger ring-2 ring-white"></span>
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M18 9.5A6 6 0 0 0 6 9.5C6 16 3.5 17 3.5 17H20.5S18 16 18 9.5Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M10 20H14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                            </svg>
                        </button>
                        <div class="hidden items-center gap-3 rounded-lg border border-slate-200 bg-white px-3 py-2 sm:flex">
                            <span class="grid h-8 w-8 place-items-center rounded-md bg-slate-950 text-xs font-black text-white">@userInitials</span>
                            <span class="grid leading-none">
                                <span class="text-sm font-extrabold text-slate-950">@userName</span>
                                <span class="mt-1 text-xs font-semibold text-slate-500">@dashboardRole</span>
                            </span>
                        </div>
                    </div>
                </div>
            </header>

            <main class="min-h-0 flex-1 overflow-y-auto px-4 py-6 sm:px-6 lg:px-8">
                <section class="mb-6 dashboard-reveal" data-dashboard-reveal>
                    <div class="dashboard-panel p-5 sm:p-6">
                        <p class="font-mono text-[11px] font-extrabold uppercase tracking-wideTech text-dashboard-primary">TransitNova Control Surface</p>
                        <div class="mt-3 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
                            <div>
                                <h2 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">@dashboardTitle</h2>
                                <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">@dashboardSubtitle</p>
                            </div>
                            <button class="inline-flex min-h-10 items-center justify-center rounded-lg border border-slate-200 bg-white px-4 text-sm font-extrabold text-slate-800 transition-colors duration-200 hover:bg-slate-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-dashboard-primary" type="button">Export report</button>
                        </div>
                    </div>
                </section>

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/js/Dashboard/dashboard.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@functions {
    private IHtmlContent RenderSidebar(IEnumerable<DashboardNavItemViewModel> navItems, string role)
    {
        var builder = new HtmlContentBuilder();
        builder.AppendHtml("<div class=\"flex h-full flex-col\">");
        builder.AppendHtml("<div class=\"border-b border-slate-200 p-5\"><a href=\"/\" class=\"inline-flex items-center gap-3 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-dashboard-primary\"><span class=\"grid h-10 w-10 place-items-center rounded-lg bg-slate-950 text-sm font-black text-white\">TN</span><span class=\"grid leading-none\"><span class=\"text-sm font-black tracking-tight text-slate-950\">TransitNova</span><span class=\"mt-1 font-mono text-[10px] font-extrabold uppercase tracking-wideTech text-slate-500\">");
        builder.Append(role);
        builder.AppendHtml("</span></span></a></div>");
        builder.AppendHtml("<nav class=\"flex-1 space-y-1 overflow-y-auto p-4\" aria-label=\"Dashboard navigation\">");

        foreach (var item in navItems)
        {
            builder.AppendHtml("<a class=\"dashboard-sidebar-link");
            if (item.IsActive)
                builder.AppendHtml(" is-active");
            builder.AppendHtml("\" href=\"");
            builder.Append(item.Href);
            builder.AppendHtml("\">");
            builder.AppendHtml(Icon(item.Icon));
            builder.AppendHtml("<span class=\"min-w-0 flex-1 truncate\">");
            builder.Append(item.Label);
            builder.AppendHtml("</span>");
            if (!string.IsNullOrWhiteSpace(item.Badge))
            {
                builder.AppendHtml("<span class=\"rounded-md bg-blue-50 px-2 py-1 text-[11px] font-extrabold text-blue-700\">");
                builder.Append(item.Badge);
                builder.AppendHtml("</span>");
            }
            builder.AppendHtml("</a>");
        }

        builder.AppendHtml("</nav><div class=\"border-t border-slate-200 p-4\"><div class=\"rounded-lg border border-slate-200 bg-slate-50 p-3\"><p class=\"font-mono text-[10px] font-extrabold uppercase tracking-wideTech text-slate-500\">System state</p><p class=\"mt-2 text-sm font-extrabold text-slate-950\">All services monitored</p></div></div></div>");
        return builder;
    }

    private static string Icon(string icon) => icon switch
    {
        "truck" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M3.5 15.5H5.5M18.5 15.5H20.5M7.5 17.5A2 2 0 1 0 7.5 13.5A2 2 0 0 0 7.5 17.5ZM16.5 17.5A2 2 0 1 0 16.5 13.5A2 2 0 0 0 16.5 17.5ZM4.5 15.5V9.5C4.5 8.7 5.2 8 6 8H13.5V15.5M13.5 10.5H16.8L19.5 13V15.5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>",
        "route" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M6.5 6.5H7M17 17.5H17.5M7 7C4.8 8.7 4.7 11.1 6.7 12.2C8.9 13.4 12.4 10.4 14.8 11.9C17.2 13.4 16.4 16 14.5 17.5M6.5 9A2.5 2.5 0 1 0 6.5 4A2.5 2.5 0 0 0 6.5 9ZM17.5 20A2.5 2.5 0 1 0 17.5 15A2.5 2.5 0 0 0 17.5 20Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>",
        "users" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M16 19C16 16.8 14.2 15 12 15H8C5.8 15 4 16.8 4 19M15 5.3A3 3 0 0 1 15 10.7M20 19C20 17.1 18.9 15.5 17.4 14.7M10 11A3 3 0 1 0 10 5A3 3 0 0 0 10 11Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>",
        "chart" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M5 19V10M12 19V5M19 19V13M4 19H20\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>",
        "settings" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M12 15.2A3.2 3.2 0 1 0 12 8.8A3.2 3.2 0 0 0 12 15.2ZM19 12A7 7 0 0 0 18.9 10.9L21 9.3L19 5.9L16.5 6.9A7.6 7.6 0 0 0 14.6 5.8L14.2 3H9.8L9.4 5.8A7.6 7.6 0 0 0 7.5 6.9L5 5.9L3 9.3L5.1 10.9A7 7 0 0 0 5.1 13.1L3 14.7L5 18.1L7.5 17.1A7.6 7.6 0 0 0 9.4 18.2L9.8 21H14.2L14.6 18.2A7.6 7.6 0 0 0 16.5 17.1L19 18.1L21 14.7L18.9 13.1A7 7 0 0 0 19 12Z\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>",
        _ => "<svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M4 5H10V11H4V5ZM14 5H20V11H14V5ZM4 15H10V19H4V15ZM14 15H20V19H14V15Z\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" /></svg>"
    };
}

