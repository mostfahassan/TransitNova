@model ErrorPageViewModel
@{
    Layout = null;
    var toneClass = Model.Tone switch
    {
        "danger" => "from-[#FDEBEC] to-white border-[#F2C7C7]",
        "warning" => "from-[#FFF6DB] to-white border-[#F3DF9C]",
        _ => "from-[#F7F6F3] to-white border-[#EAEAEA]"
    };
}

<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Code | TransitNova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="~/Tailwind/tailwind.config.js" asp-append-version="true"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { color-scheme: light; }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #F7F6F3; color: #111111; }
        .tn-error-grid { background-image: linear-gradient(#EAEAEA 1px, transparent 1px), linear-gradient(90deg, #EAEAEA 1px, transparent 1px); background-size: 44px 44px; mask-image: radial-gradient(circle at center, black, transparent 72%); }
        .tn-error-card { animation: tnErrorIn .55s cubic-bezier(.16,1,.3,1) both; }
        .tn-error-orbit { animation: tnErrorPulse 2.2s ease-in-out infinite; }
        @@keyframes tnErrorIn { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
        @@keyframes tnErrorPulse { 0%, 100% { transform: scale(1); opacity: .72; } 50% { transform: scale(1.04); opacity: 1; } }
        @@media (prefers-reduced-motion: reduce) { .tn-error-card, .tn-error-orbit { animation: none; } }
    </style>
</head>
<body class="min-h-full">
    <main class="relative grid min-h-screen place-items-center overflow-hidden px-5 py-10">
        <div class="tn-error-grid pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
        <section class="tn-error-card relative w-full max-w-[760px] overflow-hidden rounded-2xl border bg-gradient-to-br @toneClass shadow-[0_24px_80px_rgba(17,17,17,0.08)]">
            <div class="grid gap-0 lg:grid-cols-[260px_1fr]">
                <div class="border-b border-[#EAEAEA] bg-[#FBFBFA] p-8 lg:border-b-0 lg:border-r">
                    <a asp-area="LandingArea" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-3 rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-black/30">
                        <span class="grid h-10 w-10 place-items-center rounded-xl bg-[#111111] text-sm font-black text-white">TN</span>
                        <span>
                            <span class="block text-sm font-black tracking-tight text-[#111111]">TransitNova</span>
                            <span class="block font-mono text-[10px] font-black uppercase tracking-[0.16em] text-[#787774]">Exception desk</span>
                        </span>
                    </a>
                    <div class="mt-12 grid h-36 w-36 place-items-center rounded-2xl border border-[#EAEAEA] bg-white">
                        <div class="tn-error-orbit grid h-24 w-24 place-items-center rounded-full border border-[#DADAD7] bg-[#F7F6F3] font-mono text-3xl font-black tracking-tight text-[#111111]">@Model.Code</div>
                    </div>
                </div>

                <div class="p-8 sm:p-10">
                    <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">@Model.Eyebrow</div>
                    <h1 class="mt-4 text-4xl font-black leading-[1.02] tracking-[-0.035em] text-[#111111] sm:text-5xl">@Model.Title</h1>
                    <p class="mt-5 max-w-xl text-base font-semibold leading-7 text-[#666666]">@Model.Description</p>
                    <div class="mt-8 grid gap-3 sm:grid-cols-2">
                        <a asp-area="@Model.PrimaryArea" asp-controller="@Model.PrimaryController" asp-action="@Model.PrimaryAction" class="inline-flex min-h-[48px] items-center justify-center rounded-xl bg-[#111111] px-5 text-sm font-black text-white transition-all duration-200 hover:bg-[#2F3437] active:scale-[0.98] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black/30">@Model.PrimaryLabel</a>
                        <a asp-area="@Model.SecondaryArea" asp-controller="@Model.SecondaryController" asp-action="@Model.SecondaryAction" class="inline-flex min-h-[48px] items-center justify-center rounded-xl border border-[#EAEAEA] bg-white px-5 text-sm font-black text-[#111111] transition-all duration-200 hover:border-black/15 hover:bg-black/[0.03] active:scale-[0.98] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black/20">@Model.SecondaryLabel</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>