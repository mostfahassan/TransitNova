@model LoginViewModel
@{
    Layout = null;
}

<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login | TransitNova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="~/Tailwind/tailwind.config.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/Account/account.css" asp-append-version="true" />
    <script src="~/js/Account/account.js" asp-append-version="true" defer></script>
</head>
<body class="account-page login-page">
    <main class="account-shell grid min-h-screen px-5 py-6 lg:grid-cols-[minmax(0,1fr)_520px] lg:px-8">
        <section class="hidden min-h-[calc(100vh-48px)] flex-col justify-between rounded-[10px] border border-slate-200 bg-white/70 p-8 lg:flex">
            <a asp-area="LandingArea" asp-controller="Home" asp-action="Index" class="inline-flex w-fit items-center gap-3 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-account-primary">
                <span class="account-brand-mark">TN</span>
                <span class="grid leading-none">
                    <span class="text-sm font-black tracking-tight text-slate-950">TransitNova</span>
                    <span class="mt-1 font-mono text-[10px] font-bold uppercase tracking-wideTech text-slate-500">Secure workspace</span>
                </span>
            </a>

            <div class="max-w-xl account-reveal">
                <span class="account-kicker">Role-based access</span>
                <h1 class="mt-6 text-5xl font-black leading-[0.98] tracking-tight text-slate-950 xl:text-6xl">Run logistics from one clean control surface.</h1>
                <p class="mt-5 max-w-md text-base leading-7 text-slate-600">Sign in once and TransitNova sends you to the workspace that matches your role.</p>
                <div class="login-visual-line mt-8"></div>
                <div class="mt-8 grid grid-cols-3 gap-3">
                    <div class="account-side-stat"><span>Auth</span><strong>JWT</strong></div>
                    <div class="account-side-stat"><span>Flow</span><strong>PRG</strong></div>
                    <div class="account-side-stat"><span>Roles</span><strong>5</strong></div>
                </div>
            </div>

            <p class="max-w-md text-sm leading-6 text-slate-500">Access is protected by server-side validation, session state, and refresh-aware backend invocation.</p>
        </section>

        <section class="flex min-h-[calc(100vh-48px)] items-center justify-center py-10 lg:pl-8">
            <div class="login-card w-full account-reveal">
                <div class="mb-8 lg:hidden">
                    <a asp-area="LandingArea" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-3 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-account-primary">
                        <span class="account-brand-mark">TN</span>
                        <span class="text-sm font-black tracking-tight text-slate-950">TransitNova</span>
                    </a>
                </div>

                <div class="account-card p-6 sm:p-8">
                    <span class="account-kicker">Account</span>
                    <h2 class="mt-5 text-4xl font-black tracking-tight text-slate-950">Welcome back.</h2>
                    <p class="mt-3 text-sm leading-6 text-slate-600">Use your credentials to continue to your dashboard.</p>

                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="account-alert account-alert-success mt-6">@successMessage</div>
                    }
                    @if (TempData["ErrorMessage"] is string errorMessage)
                    {
                        <div class="account-alert account-alert-error mt-6">@errorMessage</div>
                    }

                    <form asp-area="AccountArea" asp-controller="Account" asp-action="Login" method="post" class="mt-7 grid gap-5" data-account-form data-ajax-form novalidate>
                        @Html.AntiForgeryToken()
                        <div class="account-alert account-alert-error" data-form-alert hidden></div>
                        <div asp-validation-summary="ModelOnly" class="account-alert account-alert-error"></div>

                        <div class="account-field">
                            <label asp-for="Email" class="account-label">Email address</label>
                            <input asp-for="Email" type="email" autocomplete="email" class="account-input" placeholder="name@company.com" required />
                            <span asp-validation-for="Email" class="account-error-message" data-account-error-for="Email"></span>
                        </div>

                        <div class="account-field">
                            <label asp-for="Password" class="account-label">Password</label>
                            <input asp-for="Password" type="password" autocomplete="current-password" class="account-input" placeholder="Enter password" required />
                            <span asp-validation-for="Password" class="account-error-message" data-account-error-for="Password"></span>
                        </div>

                        <button type="submit" class="account-button" data-submit-button data-loading-text="Signing in...">Sign in</button>
                    </form>

                    <p class="mt-7 text-center text-sm text-slate-600">
                        New to TransitNova?
                        <a asp-area="AccountArea" asp-controller="Account" asp-action="Register" class="account-secondary-link">Create an account</a>
                    </p>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
