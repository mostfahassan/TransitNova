@model ChangePasswordViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Change Password | TransitNova</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="~/Tailwind/tailwind.config.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="~/css/Account/account.css" asp-append-version="true" />
    <script src="~/js/Account/account.js" asp-append-version="true" defer></script>
</head>
<body class="account-page change-password-page">
    <main class="account-shell flex min-h-screen items-center justify-center px-5 py-10 sm:px-8">
        <section class="security-card w-full account-card account-reveal p-6 sm:p-8">
            <div class="mb-7 flex items-center justify-between gap-4 border-b border-slate-200 pb-6">
                <a asp-area="LandingArea" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-3 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-account-primary">
                    <span class="account-brand-mark">TN</span>
                    <span class="grid leading-none">
                        <span class="text-sm font-black tracking-tight text-slate-950">TransitNova</span>
                        <span class="mt-1 hidden font-mono text-[10px] font-bold uppercase tracking-wideTech text-slate-500 sm:block">Security</span>
                    </span>
                </a>
                <form asp-area="AccountArea" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="account-secondary-link cursor-pointer border-0 bg-transparent p-0">Sign out</button>
                </form>
            </div>

            <span class="account-kicker">Password</span>
            <h1 class="mt-5 text-4xl font-black tracking-tight text-slate-950">Change password.</h1>
            <p class="mt-3 text-sm leading-6 text-slate-600">Update your password before continuing with operational work.</p>

            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="account-alert account-alert-success mt-6">@successMessage</div>
            }
            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="account-alert account-alert-error mt-6">@errorMessage</div>
            }

            <form asp-area="AccountArea" asp-controller="Account" asp-action="ChangePassword" method="post" class="mt-7 grid gap-5" data-account-form data-ajax-form novalidate>
                @Html.AntiForgeryToken()
                <div class="account-alert account-alert-error" data-form-alert hidden></div>
                <div asp-validation-summary="ModelOnly" class="account-alert account-alert-error"></div>

                <div class="account-field">
                    <label asp-for="CurrentPassword" class="account-label">Current password</label>
                    <input asp-for="CurrentPassword" type="password" autocomplete="current-password" class="account-input" placeholder="Current password" required />
                    <span asp-validation-for="CurrentPassword" class="account-error-message" data-account-error-for="CurrentPassword"></span>
                </div>

                <div class="account-field">
                    <label asp-for="NewPassword" class="account-label">New password</label>
                    <input asp-for="NewPassword" id="NewPassword" type="password" autocomplete="new-password" class="account-input" placeholder="At least 6 characters" required data-min-length="6" data-revalidates="#ConfirmNewPassword" />
                    <span asp-validation-for="NewPassword" class="account-error-message" data-account-error-for="NewPassword"></span>
                </div>

                <div class="account-field">
                    <label asp-for="ConfirmNewPassword" class="account-label">Confirm new password</label>
                    <input asp-for="ConfirmNewPassword" id="ConfirmNewPassword" type="password" autocomplete="new-password" class="account-input" placeholder="Repeat new password" required data-match="#NewPassword" />
                    <span asp-validation-for="ConfirmNewPassword" class="account-error-message" data-account-error-for="ConfirmNewPassword"></span>
                </div>

                <div class="password-rules">
                    Use a password that is not shared with external tools. The update is submitted through the same refresh-aware MVC backend flow.
                </div>

                <button type="submit" class="account-button" data-submit-button data-loading-text="Updating password...">Update password</button>
            </form>
        </section>
    </main>
</body>
</html>
