@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="mb-5 rounded-xl border border-[#DDEBDD] bg-[#EDF3EC] px-4 py-3 text-sm font-semibold text-[#346538]">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="mb-5 rounded-xl border border-[#F5D4D4] bg-[#FDEBEC] px-4 py-3 text-sm font-semibold text-[#9F2F2D]">@errorMessage</div>
}
