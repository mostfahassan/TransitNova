@model OpsKpiTileViewModel
@{
    var toneClass = Model.Tone switch
    {
        "success" => "bg-[#EDF3EC] text-[#346538]",
        "warning" => "bg-[#FBF3DB] text-[#956400]",
        "danger" => "bg-[#FDEBEC] text-[#9F2F2D]",
        "info" => "bg-[#E1F3FE] text-[#1F6C9F]",
        _ => "bg-[#F1F1EF] text-[#55524D]"
    };
}

<article class="ops-card ops-lift p-5">
    <div class="flex items-start justify-between gap-4">
        <div>
            <div class="text-[11px] font-extrabold uppercase tracking-[0.16em] text-[#787774]">@Model.Label</div>
            <div class="mt-3 text-3xl font-black tracking-tight text-[#111111]">@Model.Value</div>
        </div>
        <div class="grid h-10 w-10 place-items-center rounded-lg @toneClass">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M4 7.5h16M7.5 4v16M16.5 4v16M4 16.5h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
        </div>
    </div>
    <p class="mt-4 text-sm leading-6 text-[#787774]">@Model.Meta</p>
</article>
