@{
    var controller = Context.Request.RouteValues["controller"]?.ToString() ?? string.Empty;
    var action = Context.Request.RouteValues["action"]?.ToString() ?? string.Empty;
    var items = new[]
    {
        new OpsSidebarItemViewModel("Command", "Dashboard", "Index", "grid"),
        new OpsSidebarItemViewModel("Live Tracking", "Shipments", "Index", "tracking"),
        new OpsSidebarItemViewModel("Dispatch", "Carriers", "Dispatch", "dispatch", "live"),
        new OpsSidebarItemViewModel("Fleet Status", "Carriers", "Index", "fleet"),
        new OpsSidebarItemViewModel("Exceptions", "Shipments", "ReviewQueue", "alert", "9"),
        new OpsSidebarItemViewModel("Driver Roster", "Carriers", "Index", "driver")
    };
}

<aside class="ops-sidebar">
    <div class="border-b border-[#EAEAEA] p-6">
        <a asp-area="OperationManagerArea" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center gap-3 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#111111]/10">
            <span class="grid h-10 w-10 place-items-center rounded-lg bg-[#111111] text-sm font-black text-white">TN</span>
            <span class="min-w-0">
                <span class="block text-sm font-black tracking-tight text-[#111111]">TransitNova</span>
                <span class="mt-1 block font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#787774]">OPS / CONTROL</span>
            </span>
        </a>
    </div>

    <nav class="flex-1 space-y-1 p-4">
        @foreach (var item in items)
        {
            var isActive = string.Equals(controller, item.Controller, StringComparison.OrdinalIgnoreCase)
                && (string.Equals(action, item.Action, StringComparison.OrdinalIgnoreCase)
                    || (item.Controller == "Shipments" && controller == "Shipments" && item.Label == "Live Tracking" && action is "Details" or "Assigned" or "Histories" or "Review" or "Reject")
                    || (item.Controller == "Carriers" && controller == "Carriers" && item.Label == "Fleet Status" && action is "Details" or "Shipments" or "ShipmentDetails" or "AssignPickup" or "AssignDelivery")
                    || (item.Controller == "Carriers" && controller == "Carriers" && item.Label == "Dispatch" && action is "Dispatch"));
            <a asp-area="OperationManagerArea" asp-controller="@item.Controller" asp-action="@item.Action" class="ops-sidebar-link @(isActive ? "is-active" : null)">
                @Icon(item.Icon)
                <span class="min-w-0 flex-1 truncate">@item.Label</span>
                @if (!string.IsNullOrWhiteSpace(item.Badge))
                {
                    <span class="rounded-md border border-[#EAEAEA] bg-white px-1.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.08em] text-[#787774]">@item.Badge</span>
                }
            </a>
        }
    </nav>

    <div class="border-t border-[#EAEAEA] p-4">
        <div class="rounded-xl border border-[#EAEAEA] bg-white p-4">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#787774]">Shift status</div>
            <div class="mt-3 flex items-center justify-between gap-3">
                <span class="text-sm font-extrabold text-[#111111]">Morning control</span>
                <span class="ops-badge ops-badge-success">Active</span>
            </div>
        </div>
    </div>
</aside>

@functions {
    private static IHtmlContent Icon(string icon) => new HtmlString(icon switch
    {
        "grid" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 5h6v6H4V5Zm10 0h6v6h-6V5ZM4 13h6v6H4v-6Zm10 0h6v6h-6v-6Z\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linejoin=\"round\"/></svg>",
        "tracking" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M5 17.5h14M7 17.5V8.2c0-.7.5-1.2 1.2-1.2h6.5c.5 0 .9.2 1.2.6l2.1 2.7c.2.3.4.7.4 1.1v6.1M8.5 19.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm7 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\"/></svg>",
        "dispatch" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 7h16M4 12h10M4 17h7m7-4 2 2-2 2m-3-2h5\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>",
        "fleet" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M4 15h16l-1.2-5.1A2.5 2.5 0 0 0 16.4 8H7.6a2.5 2.5 0 0 0-2.4 1.9L4 15Zm3.5 3a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm9 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\"/></svg>",
        "alert" => "<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M12 8v5m0 3h.01M10.3 4.9 3.8 16.3c-.7 1.2.2 2.7 1.6 2.7h13.2c1.4 0 2.3-1.5 1.6-2.7L13.7 4.9c-.7-1.2-2.7-1.2-3.4 0Z\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>",
        _ => "<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M7 7h10v10H7V7Zm-3 5h16\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>"
    });
}
