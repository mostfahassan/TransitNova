@model UiPagedResult<UiRetrieveShipmentDto>?
@{
    ViewData["Title"] = "Assigned Shipments";
    var result = Model ?? new UiPagedResult<UiRetrieveShipmentDto> { PageSize = 20 };
    var items = result.Data.ToList();
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Dispatch",
        Title = "Assigned shipment workload",
        Description = "Shipments already mapped to carriers and ready for trip execution tracking.",
        PrimaryLabel = "Fleet status",
        PrimaryController = "Carriers",
        PrimaryAction = "Index",
        SecondaryLabel = "All shipments",
        SecondaryController = "Shipments",
        SecondaryAction = "Index"
    };
    var table = new OpsTableViewModel
    {
        Title = "Assigned queue",
        Subtitle = "Carrier-linked shipments currently owned by the operation team.",
        Controller = "Shipments",
        Headers = ["Shipment", "Pickup", "Delivery", "Status", "Mode", "Created"],
        Rows = items.Select(shipment => AdminDisplay.OpsRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.OpsCell("Shipment", shipment.TrackingNumber, "id"),
            AdminDisplay.OpsCell("Pickup", shipment.PickupAddress),
            AdminDisplay.OpsCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.OpsCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.OpsCell("Mode", shipment.TransportationMode),
            AdminDisplay.OpsCell("Created", shipment.CreatedAt))).ToList()
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsTable" model="table" />
