@model object?
@{
    ViewData["Title"] = "Review Queue";
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Exceptions",
        Title = "Review and dispatch queue",
        Description = "Shipments waiting for approve, reject, pickup assignment, or delivery carrier decisions.",
        PrimaryLabel = "All shipments",
        PrimaryController = "Shipments",
        PrimaryAction = "Index",
        SecondaryLabel = "Fleet status",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };

    var table = new OpsTableViewModel
    {
        Title = "Pending operational decisions",
        Subtitle = "Rows here need fast action from the operations manager.",
        Source = Model,
        Controller = "Shipments",
        RouteIdName = "shipmentId",
        IdPropertyPath = "Id",
        DetailsAction = "Review",
        PrimaryRowLabel = "Reject",
        PrimaryRowAction = "Reject",
        PrimaryRowRouteIdName = "shipmentId",
        PrimaryRowIdPropertyPath = "Id",
        Columns = new List<OpsTableColumnViewModel>
        {
            new("Shipment", "TrackingNumber", "id"),
            new("Pickup", "PickupAddress|SenderCity"),
            new("Delivery", "DeliveryAddress|ReceiverCity"),
            new("Status", "CurrentStatus|Status", "badge"),
            new("Type", "ShipmentType"),
            new("Received", "CreatedAt")
        }
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsTable" model="table" />
