@model UiPagedResult<UiRetrieveShipmentDto>?
@{
    ViewData["Title"] = "Review Queue";
    var result = Model ?? new UiPagedResult<UiRetrieveShipmentDto> { PageSize = 20 };
    var items = result.Data.ToList();
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Exceptions",
        Title = "Review and dispatch queue",
        Description = "Shipments waiting for approve, reject, pickup assignment, or delivery carrier decisions.",
        PrimaryLabel = "All shipments",
        PrimaryController = "Shipments",
        PrimaryAction = "Index",
        SecondaryLabel = "Fleet status",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };

    var table = new OpsTableViewModel
    {
        Title = "Pending operational decisions",
        Subtitle = "Rows here need fast action from the operations manager.",
        Controller = "Shipments",
        DetailsAction = "Review",
        PrimaryRowLabel = "Reject",
        PrimaryRowAction = "Reject",
        Headers = ["Shipment", "Pickup", "Delivery", "Status", "Type", "Received"],
        Rows = items.Select(shipment => AdminDisplay.OpsRow(
            "shipmentId",
            shipment.Id,
            "shipmentId",
            shipment.Id,
            AdminDisplay.OpsCell("Shipment", shipment.TrackingNumber, "id"),
            AdminDisplay.OpsCell("Pickup", shipment.PickupAddress),
            AdminDisplay.OpsCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.OpsCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.OpsCell("Type", shipment.ShipmentType),
            AdminDisplay.OpsCell("Received", shipment.CreatedAt))).ToList()
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsTable" model="table" />
