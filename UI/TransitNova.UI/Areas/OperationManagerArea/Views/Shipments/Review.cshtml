@model object?
@{
    ViewData["Title"] = "Review Shipment";
    var source = Model ?? new { Id = Guid.Parse("34000000-0000-0000-0000-000000000001"), TrackingNumber = "TN-4091", PickupAddress = "Cairo Hub", DeliveryAddress = "Alexandria Customs", CurrentStatus = "Pending", TransportationMode = "Land", ShipmentType = "Express", ShippingCost = 1450, EstimatedDeliveryDate = DateTime.Now.AddHours(7), CreatedAt = DateTime.Now.AddMinutes(-42) };
    var shipmentId = AdminDisplay.RouteValue(source, "Id|ShipmentId");
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Shipment review",
        Title = "Review " + AdminDisplay.Text(source, "TrackingNumber", "id"),
        Description = "Approve the shipment if data is clean, or reject it with a clear reason.",
        SecondaryLabel = "Back to queue",
        SecondaryController = "Shipments",
        SecondaryAction = "ReviewQueue"
    };
    var detail = new OpsDetailViewModel
    {
        Title = "Review payload",
        Subtitle = "Pending decision",
        Source = source,
        Controller = "Shipments",
        IndexAction = "ReviewQueue",
        RouteIdName = "shipmentId",
        IdPropertyPath = "Id|ShipmentId",
        Fields = new List<OpsTableColumnViewModel>
        {
            new("Tracking", "TrackingNumber", "id"),
            new("Status", "CurrentStatus|Status", "badge"),
            new("Pickup", "PickupAddress|SenderCity"),
            new("Delivery", "DeliveryAddress|ReceiverCity"),
            new("Mode", "TransportationMode"),
            new("Cost", "ShippingCost|ShippinCost|ShipmentCost", "currency")
        }
    };
}

<partial name="_OpsPageHeader" model="header" />
<div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <partial name="_OpsDetail" model="detail" />
    <aside class="ops-card p-6">
        <div class="text-[11px] font-extrabold uppercase tracking-[0.18em] text-[#787774]">Decision stack</div>
        <h3 class="mt-3 text-2xl font-black text-[#111111]">Resolve this queue item</h3>
        <p class="mt-3 text-sm leading-6 text-[#787774]">Review queue actions are intentionally limited to approval or rejection.</p>
        <div class="mt-6 space-y-3">
            <form asp-area="OperationManagerArea" asp-controller="Shipments" asp-action="Approve" asp-route-shipmentId="@shipmentId" method="post" data-confirm="Approve this shipment?" data-ops-ajax-form="true">
                @Html.AntiForgeryToken()
                <button type="submit" class="ops-button w-full">Approve shipment</button>
            </form>
            <a asp-area="OperationManagerArea" asp-controller="Shipments" asp-action="Reject" asp-route-shipmentId="@shipmentId" class="ops-button-danger w-full">Reject shipment</a>
        </div>
    </aside>
</div>