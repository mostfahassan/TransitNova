@model object?
@{
    ViewData["Title"] = "Shipment History";
    var shipmentId = Convert.ToString(ViewContext.RouteData.Values["shipmentId"]) ?? string.Empty;
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Audit trail",
        Title = "Shipment status history",
        Description = "A chronological state log for review, assignment, pickup, warehouse, and delivery transitions.",
        SecondaryLabel = "Back to shipment",
        SecondaryController = "Shipments",
        SecondaryAction = "Details",
        SecondaryRouteValues = new Dictionary<string, string>
        {
            ["shipmentId"] = shipmentId
        }
    };
    var table = new OpsTableViewModel
    {
        Title = "Status timeline",
        Subtitle = "Every operational transition should be visible here.",
        Source = Model,
        Controller = "Shipments",
        ShowDetails = false,
        Columns = new List<OpsTableColumnViewModel>
        {
            new("Status", "Status|StatusType", "badge"),
            new("Carrier", "Carrier|CarrierName|CarrierId"),
            new("Created", "CreatedAt|ChangedAt"),
            new("Note", "Note|Description")
        }
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsTable" model="table" />
