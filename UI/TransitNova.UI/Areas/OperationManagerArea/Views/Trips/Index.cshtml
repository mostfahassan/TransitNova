@using TransitNova.Domain.Enums.Trip
@model UiPagedResult<UiTripDetailsDto>?
@{
    ViewData["Title"] = "Trips";
    var result = Model ?? new UiPagedResult<UiTripDetailsDto> { PageSize = 20 };
    var items = result.Data.ToList();
    var selectedTripType = Context.Request.Query["TripType"].ToString();
    var selectedStatus = Context.Request.Query["Status"].ToString();
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Dispatch board",
        Title = "Handled trips",
        Description = "Review only the trips attached to carriers handled by your operation queue.",
        PrimaryLabel = "Fleet status",
        PrimaryController = "Carriers",
        PrimaryAction = "Index",
        SecondaryLabel = "Live tracking",
        SecondaryController = "Shipments",
        SecondaryAction = "Index"
    };
    var table = new OpsTableViewModel
    {
        Title = "Trip list",
        Subtitle = "Trips scoped to your handled carriers.",
        Controller = "Trips",
        ShowDetails = true,
        Headers = ["Trip", "Type", "Status", "Carrier", "Warehouse", "Shipments", "Planned", "Started", "Ended"],
        Rows = items.Select(trip => AdminDisplay.OpsRow(
            "tripId",
            trip.Id,
            AdminDisplay.OpsCell("Trip", trip.Id, "id"),
            AdminDisplay.OpsCell("Type", trip.TripType),
            AdminDisplay.OpsCell("Status", trip.Status, "badge"),
            AdminDisplay.OpsCell("Carrier", trip.CarrierName),
            AdminDisplay.OpsCell("Warehouse", trip.WarehouseName),
            AdminDisplay.OpsCell("Shipments", trip.TotalShipments),
            AdminDisplay.OpsCell("Planned", trip.PlannedDate),
            AdminDisplay.OpsCell("Started", trip.StartTime),
            AdminDisplay.OpsCell("Ended", trip.EndTime))).ToList(),
        EmptyTitle = "No trips found",
        EmptyDescription = "Trips for handled carriers will appear here when they match your filters."
    };
}

<partial name="_OpsPageHeader" model="header" />

<section class="ops-card mb-6 p-5">
    <form method="get" class="grid gap-4 lg:grid-cols-[repeat(5,minmax(0,1fr))_auto] lg:items-end">
        <div>
            <label class="ops-label" for="TripType">Trip type</label>
            <select id="TripType" name="TripType" class="ops-select">
                <option value="">Any type</option>
                @foreach (var option in Enum.GetValues<TripType>())
                {
                    var value = option.ToString();
                    <option value="@value" selected="@(string.Equals(selectedTripType, value, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@value</option>
                }
            </select>
        </div>
        <div>
            <label class="ops-label" for="Status">Status</label>
            <select id="Status" name="Status" class="ops-select">
                <option value="">Any status</option>
                @foreach (var option in Enum.GetValues<TripStatus>())
                {
                    var value = option.ToString();
                    <option value="@value" selected="@(string.Equals(selectedStatus, value, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@value</option>
                }
            </select>
        </div>
        <div>
            <label class="ops-label" for="CarrierId">Carrier Id</label>
            <input id="CarrierId" name="CarrierId" value="@Context.Request.Query["CarrierId"]" class="ops-input" placeholder="Carrier Guid" autocomplete="off" />
        </div>
        <div>
            <label class="ops-label" for="From">From</label>
            <input id="From" name="From" value="@Context.Request.Query["From"]" type="date" class="ops-input" />
        </div>
        <div>
            <label class="ops-label" for="To">To</label>
            <input id="To" name="To" value="@Context.Request.Query["To"]" type="date" class="ops-input" />
        </div>
        <button type="submit" class="ops-button h-[46px]">Filter</button>
    </form>
</section>

<partial name="_OpsTable" model="table" />
