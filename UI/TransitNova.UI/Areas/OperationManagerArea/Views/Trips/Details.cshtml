@using TransitNova.Domain.Enums.Trip
@model object?
@{
    ViewData["Title"] = "Trip Details";
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Dispatch board",
        Title = "Trip details",
        Description = "Inspect the operational lane, manifest, and timing for a handled trip.",
        SecondaryLabel = "Back to trips",
        SecondaryController = "Trips",
        SecondaryAction = "Index"
    };
    var shipments = AdminDisplay.Value(Model, "Shipments");
    var tripType = AdminDisplay.Text(Model, "TripType");
    var tripStatus = AdminDisplay.Text(Model, "Status");
    var totalShipments = AdminDisplay.Text(Model, "TotalShipments");
    var tripTypeKpi = new OpsKpiTileViewModel("Trip type", tripType, "Movement lane", "TR", "info");
    var statusKpi = new OpsKpiTileViewModel("Status", tripStatus, "Current state", "ST", "warning");
    var shipmentCountKpi = new OpsKpiTileViewModel("Shipments", totalShipments, "Manifest count", "SH", "success");
    var detail = new OpsDetailViewModel
    {
        Title = "Trip detail",
        Subtitle = "Handled trip projection from the API.",
        Source = Model,
        Controller = "Trips",
        RouteIdName = "tripId",
        IdPropertyPath = "Id",
        Fields = new List<OpsTableColumnViewModel>
        {
            new("Trip", "Id", "id"),
            new("Carrier", "CarrierName"),
            new("Carrier phone", "CarrierPhoneNumber"),
            new("Warehouse", "WarehouseName"),
            new("Address", "WarehouseAddress"),
            new("Planned", "PlannedDate"),
            new("Started", "StartTime"),
            new("Ended", "EndTime"),
            new("Shipments", "TotalShipments"),
            new("Created by", "CreatedBy")
        }
    };
    var shipmentTable = new OpsTableViewModel
    {
        Title = "Trip shipment manifest",
        Subtitle = "Shipments currently moving on this handled trip.",
        Source = shipments,
        Controller = "Shipments",
        RouteIdName = "shipmentId",
        IdPropertyPath = "Id",
        ShowDetails = true,
        Columns = new List<OpsTableColumnViewModel>
        {
            new("Tracking", "TrackingNumber", "id"),
            new("Status", "CurrentStatus", "badge"),
            new("Receiver", "Receiver.FullName|Receiver.Email"),
            new("Pickup", "PickupAddress"),
            new("Delivery", "DeliveryAddress"),
            new("Cost", "ShippingCost")
        },
        EmptyTitle = "No shipments on this trip",
        EmptyDescription = "The shipment manifest will show here when the trip carries shipments."
    };
}

<partial name="_OpsPageHeader" model="header" />

<section class="mb-6 grid gap-4 md:grid-cols-3">
    <partial name="_OpsKpiTile" model="tripTypeKpi" />
    <partial name="_OpsKpiTile" model="statusKpi" />
    <partial name="_OpsKpiTile" model="shipmentCountKpi" />
</section>

<section class="ops-card mb-6 p-6">
    <div class="grid gap-4 md:grid-cols-2">
        <div>
            <label class="ops-label" for="TripType">Trip type</label>
            <select id="TripType" class="ops-select" disabled aria-label="Trip type">
                @foreach (var option in Enum.GetValues<TripType>())
                {
                    if (string.Equals(option.ToString(), tripType, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option" selected>@option</option>
                    }
                    else
                    {
                        <option value="@option">@option</option>
                    }
                }
            </select>
        </div>
        <div>
            <label class="ops-label" for="TripStatus">Trip status</label>
            <select id="TripStatus" class="ops-select" disabled aria-label="Trip status">
                @foreach (var option in Enum.GetValues<TripStatus>())
                {
                    if (string.Equals(option.ToString(), tripStatus, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option" selected>@option</option>
                    }
                    else
                    {
                        <option value="@option">@option</option>
                    }
                }
            </select>
        </div>
    </div>
</section>

<partial name="_OpsDetail" model="detail" />

<section class="mt-6">
    <partial name="_OpsTable" model="shipmentTable" />
</section>
