@using TransitNova.Domain.Enums.Trip
@model UiTripDetailsDto?
@{
    ViewData["Title"] = "Trip Details";
    var trip = Model ?? new UiTripDetailsDto();
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Dispatch board",
        Title = "Trip details",
        Description = "Inspect the operational lane, manifest, and timing for a handled trip.",
        SecondaryLabel = "Back to trips",
        SecondaryController = "Trips",
        SecondaryAction = "Index"
    };
    var tripType = AdminDisplay.Format(trip.TripType);
    var tripStatus = AdminDisplay.Format(trip.Status);
    var totalShipments = AdminDisplay.Format(trip.TotalShipments);
    var tripTypeKpi = new OpsKpiTileViewModel("Trip type", tripType, "Movement lane", "TR", "info");
    var statusKpi = new OpsKpiTileViewModel("Status", tripStatus, "Current state", "ST", "warning");
    var shipmentCountKpi = new OpsKpiTileViewModel("Shipments", totalShipments, "Manifest count", "SH", "success");
    var detail = new OpsDetailViewModel
    {
        Title = "Trip detail",
        Subtitle = "Handled trip projection from the API.",
        PrimaryText = trip.Id == Guid.Empty ? string.Empty : trip.Id.ToString(),
        Controller = "Trips",
        RouteValues = new Dictionary<string, object?> { ["tripId"] = trip.Id },
        Fields =
        [
            AdminDisplay.OpsCell("Trip", trip.Id, "id"),
            AdminDisplay.OpsCell("Carrier", trip.CarrierName),
            AdminDisplay.OpsCell("Carrier phone", trip.CarrierPhoneNumber),
            AdminDisplay.OpsCell("Warehouse", trip.WarehouseName),
            AdminDisplay.OpsCell("Address", trip.WarehouseAddress),
            AdminDisplay.OpsCell("Planned", trip.PlannedDate),
            AdminDisplay.OpsCell("Started", trip.StartTime),
            AdminDisplay.OpsCell("Ended", trip.EndTime),
            AdminDisplay.OpsCell("Shipments", trip.TotalShipments),
            AdminDisplay.OpsCell("Created by", trip.CreatedBy)
        ]
    };
    var shipmentTable = new OpsTableViewModel
    {
        Title = "Trip shipment manifest",
        Subtitle = "Shipments currently moving on this handled trip.",
        Controller = "Shipments",
        ShowDetails = true,
        Headers = ["Tracking", "Status", "Receiver", "Pickup", "Delivery", "Cost"],
        Rows = trip.Shipments.Select(shipment => AdminDisplay.OpsRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.OpsCell("Tracking", shipment.TrackingNumber, "id"),
            AdminDisplay.OpsCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.OpsCell("Receiver", shipment.Receiver.FullName),
            AdminDisplay.OpsCell("Pickup", shipment.PickupAddress),
            AdminDisplay.OpsCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.OpsCell("Cost", shipment.ShippingCost, "currency"))).ToList(),
        EmptyTitle = "No shipments on this trip",
        EmptyDescription = "The shipment manifest will show here when the trip carries shipments."
    };
}

<partial name="_OpsPageHeader" model="header" />

<section class="mb-6 grid gap-4 md:grid-cols-3">
    <partial name="_OpsKpiTile" model="tripTypeKpi" />
    <partial name="_OpsKpiTile" model="statusKpi" />
    <partial name="_OpsKpiTile" model="shipmentCountKpi" />
</section>

<section class="ops-card mb-6 p-6">
    <div class="grid gap-4 md:grid-cols-2">
        <div>
            <label class="ops-label" for="TripType">Trip type</label>
            <select id="TripType" class="ops-select" disabled aria-label="Trip type">
                @foreach (var option in Enum.GetValues<TripType>())
                {
                    <option value="@option" selected="@(option == trip.TripType ? "selected" : null)">@option</option>
                }
            </select>
        </div>
        <div>
            <label class="ops-label" for="TripStatus">Trip status</label>
            <select id="TripStatus" class="ops-select" disabled aria-label="Trip status">
                @foreach (var option in Enum.GetValues<TripStatus>())
                {
                    <option value="@option" selected="@(option == trip.Status ? "selected" : null)">@option</option>
                }
            </select>
        </div>
    </div>
</section>

<partial name="_OpsDetail" model="detail" />

<section class="mt-6">
    <partial name="_OpsTable" model="shipmentTable" />
</section>
