@model UiCarrierProfileDto?
@{
    ViewData["Title"] = "Carrier Details";
    var carrier = Model ?? new UiCarrierProfileDto();
    var hasCarrier = carrier.Id != Guid.Empty;
    var routeValues = new Dictionary<string, object?> { ["carrierId"] = carrier.Id };
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Carrier record",
        Title = carrier.FullName,
        Description = "Carrier readiness, contact details, and current operation assignment data.",
        PrimaryLabel = hasCarrier ? "Carrier shipments" : null,
        PrimaryController = hasCarrier ? "Carriers" : null,
        PrimaryAction = hasCarrier ? "Shipments" : null,
        PrimaryRouteValues = hasCarrier ? routeValues : null,
        SecondaryLabel = "Back to fleet",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };
    var detail = new OpsDetailViewModel
    {
        Title = "Carrier profile",
        Subtitle = "Operational readiness summary",
        PrimaryText = carrier.FullName,
        Controller = "Carriers",
        IndexAction = "Index",
        PrimaryLabel = hasCarrier ? "Shipments" : null,
        PrimaryAction = hasCarrier ? "Shipments" : null,
        RouteValues = routeValues,
        Fields =
        [
            AdminDisplay.OpsCell("Carrier", carrier.FullName),
            AdminDisplay.OpsCell("Status", carrier.Status, "badge"),
            AdminDisplay.OpsCell("Vehicle", carrier.Vehicle?.VehicleType),
            AdminDisplay.OpsCell("Current load", "-"),
            AdminDisplay.OpsCell("City", carrier.CityName),
            AdminDisplay.OpsCell("Rating", carrier.Rating),
            AdminDisplay.OpsCell("Phone", carrier.PhoneNumber),
            AdminDisplay.OpsCell("Email", carrier.Email)
        ]
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsDetail" model="detail" />
