@model object?
@{
    ViewData["Title"] = "Carrier Management";
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Fleet status",
        Title = "Carrier command roster",
        Description = "Monitor available carriers, current load, service zones, and assignment readiness.",
        PrimaryLabel = "Open dispatch",
        PrimaryController = "Carriers",
        PrimaryAction = "Dispatch",
        SecondaryLabel = "Review queue",
        SecondaryController = "Shipments",
        SecondaryAction = "ReviewQueue"
    };
    var table = new OpsTableViewModel
    {
        Title = "Carrier availability",
        Subtitle = "Live carrier list for pickup and delivery assignment decisions.",
        Source = Model,
        Controller = "Carriers",
        RouteIdName = "carrierId",
        IdPropertyPath = "Id|CarrierId",
        PrimaryRowLabel = "Shipments",
        PrimaryRowAction = "Shipments",
        PrimaryRowRouteIdName = "carrierId",
        PrimaryRowIdPropertyPath = "Id|CarrierId",
        Columns = new List<OpsTableColumnViewModel>
        {
            new("Carrier", "FullName|Name|CarrierName"),
            new("Vehicle Type", "Vehicle.VehicleType|VehicleType"),
            new("Current Status", "Status|CarrierStatus", "badge"),
            new("Current Load", "CurrentLoad|AssignedShipmentsCount"),
            new("City", "ServedCities|City|Address"),
            new("Rating", "AverageRating|Rating")
        }
    };
}

<partial name="_OpsPageHeader" model="header" />

<section class="ops-card mb-6 p-5">
    <form method="get" class="grid gap-4 md:grid-cols-[1fr_180px_160px_auto] md:items-end">
        <div>
            <label class="ops-label" for="SearchTerm">Search carrier</label>
            <input id="SearchTerm" name="SearchTerm" value="@Context.Request.Query["SearchTerm"]" class="ops-input" placeholder="Carrier name, zone, vehicle" />
        </div>
        <div>
            <label class="ops-label" for="City">City</label>
            <input id="City" name="City" value="@Context.Request.Query["City"]" class="ops-input" placeholder="Service city" />
        </div>
        <div>
            <label class="ops-label" for="Status">Status</label>
            <select id="Status" name="Status" class="ops-select">
                <option value="">Any status</option>
                <option value="Available">Available</option>
                <option value="OnTrip">On trip</option>
                <option value="AssignedToPickUpShipment">Pickup assigned</option>
                <option value="AssignedToDeliveryShipment">Delivery assigned</option>
            </select>
        </div>
        <button type="submit" class="ops-button h-[46px]">Filter</button>
    </form>
</section>

<partial name="_OpsTable" model="table" />
