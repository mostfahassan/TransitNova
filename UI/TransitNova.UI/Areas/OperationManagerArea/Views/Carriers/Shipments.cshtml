@model UiCarrierShipmentListDto?
@{
    ViewData["Title"] = "Carrier Shipments";
    var shipments = (Model?.Shipments ?? UiPagedResult<UiRetrieveShipmentDto>.From([], 0, 1, 12)).Data.ToList();
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Carrier workload",
        Title = "Assigned carrier shipments",
        Description = "Shipments currently connected to this carrier across pickup and delivery flows.",
        SecondaryLabel = "Back to fleet",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };
    var table = new OpsTableViewModel
    {
        Title = "Carrier shipment ledger",
        Subtitle = "Shipment workload owned by the selected carrier.",
        Controller = "Shipments",
        Headers = ["Shipment", "Pickup", "Delivery", "Status", "Type", "Created"],
        Rows = shipments.Select(shipment => AdminDisplay.OpsRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.OpsCell("Shipment", shipment.TrackingNumber, "id"),
            AdminDisplay.OpsCell("Pickup", shipment.PickupAddress),
            AdminDisplay.OpsCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.OpsCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.OpsCell("Type", shipment.ShipmentType),
            AdminDisplay.OpsCell("Created", shipment.CreatedAt))).ToList()
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsTable" model="table" />
