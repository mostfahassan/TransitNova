@model OpsAssignCarrierPageViewModel
@{
    ViewData["Title"] = "Assign Delivery";
    var carriers = AdminDisplay.Rows(Model.Carriers).Count > 0
        ? AdminDisplay.Rows(Model.Carriers)
        : new object[]
        {
            new { Id = Guid.Parse("41000000-0000-0000-0000-000000000001"), FullName = "Ahmed Mostafa", Status = "Available", City = Model.City ?? "Cairo", VehicleType = "Box Truck", CurrentLoad = "2 / 8" },
            new { Id = Guid.Parse("41000000-0000-0000-0000-000000000004"), FullName = "Youssef Sameh", Status = "Available", City = Model.City ?? "Cairo", VehicleType = "Van", CurrentLoad = "1 / 6" }
        };
}

<div class="ops-modal-backdrop">
    <section class="ops-slide-panel">
        <div class="flex items-start justify-between gap-4 border-b border-[#EAEAEA] p-6">
            <div>
                <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Delivery assignment</div>
                <h1 class="mt-2 text-2xl font-black tracking-tight text-[#111111]">Confirm delivery carrier</h1>
                <p class="mt-2 text-sm leading-6 text-[#787774]">Shipment @Model.ShipmentId.ToString()[..8].ToUpperInvariant() / delivery city @(Model.City ?? "all service zones")</p>
            </div>
            <a asp-area="OperationManagerArea" asp-controller="Shipments" asp-action="Details" asp-route-shipmentId="@Model.ShipmentId" class="ops-button-secondary !h-10 !w-10 !p-0" aria-label="Close assignment panel">X</a>
        </div>

        <form asp-area="OperationManagerArea" asp-controller="Carriers" asp-action="AssignDelivery" asp-route-shipmentId="@Model.ShipmentId" method="post" data-ops-assignment-form="true" class="flex min-h-0 flex-1 flex-col">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ShipmentId" />
            <input type="hidden" asp-for="AssignmentType" />
            <input type="hidden" asp-for="City" />
            <input type="hidden" asp-for="CityId" />

            <div class="flex-1 space-y-5 overflow-y-auto p-6">
                <div>
                    <label class="ops-label" asp-for="CarrierId">Available carrier</label>
                    <select class="ops-select" asp-for="CarrierId">
                        <option value="">Choose carrier</option>
                        @foreach (var carrier in carriers)
                        {
                            var id = AdminDisplay.RouteValue(carrier, "Id|CarrierId");
                            <option value="@id">@AdminDisplay.Text(carrier, "FullName|Name|CarrierName") / @AdminDisplay.Text(carrier, "Vehicle.VehicleType|VehicleType") / @AdminDisplay.Text(carrier, "CurrentLoad|AssignedShipmentsCount")</option>
                        }
                    </select>
                    <span class="ops-validation" asp-validation-for="CarrierId"></span>
                </div>

                <div>
                    <label class="ops-label" asp-for="ScheduledAt">Delivery window</label>
                    <input class="ops-input" asp-for="ScheduledAt" type="datetime-local" />
                </div>

                <div class="rounded-xl border border-[#EAEAEA] bg-[#FBFBFA] p-4">
                    <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Filtered lane</div>
                    <p class="mt-2 text-sm font-semibold text-[#2F3437]">Showing carriers serving @(Model.City ?? "all cities") with available capacity.</p>
                </div>
            </div>

            <div class="sticky bottom-0 border-t border-[#EAEAEA] bg-white p-6">
                <button type="submit" class="ops-button w-full">Confirm Delivery Assignment</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        // AJAX placeholder: intercept data-ops-assignment-form, send Fetch API request, then close panel and update the dispatch table state.
    </script>
}