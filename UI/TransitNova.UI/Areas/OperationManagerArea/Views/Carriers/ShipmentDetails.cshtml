@model UiRetrieveShipmentDto?
@{
    ViewData["Title"] = "Carrier Shipment Details";
    var shipment = Model ?? new UiRetrieveShipmentDto();
    var detail = new OpsDetailViewModel
    {
        Title = "Carrier shipment detail",
        Subtitle = "Tracking / " + AdminDisplay.Format(shipment.TrackingNumber, kind: "id"),
        PrimaryText = shipment.TrackingNumber,
        Controller = "Carriers",
        IndexAction = "Index",
        Fields =
        [
            AdminDisplay.OpsCell("Tracking", shipment.TrackingNumber, "id"),
            AdminDisplay.OpsCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.OpsCell("Pickup", shipment.PickupAddress),
            AdminDisplay.OpsCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.OpsCell("Mode", shipment.TransportationMode),
            AdminDisplay.OpsCell("Type", shipment.ShipmentType),
            AdminDisplay.OpsCell("Estimated delivery", shipment.EstimatedDeliveryDate)
        ]
    };
    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = "Carrier shipment",
        Title = AdminDisplay.Format(shipment.TrackingNumber, kind: "id"),
        Description = "Operational shipment detail as seen from a carrier assignment context.",
        SecondaryLabel = "Back to fleet",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };
}

<partial name="_OpsPageHeader" model="header" />
<partial name="_OpsDetail" model="detail" />
