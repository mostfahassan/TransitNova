@model object?
@{
    ViewData["Title"] = "Operations Dashboard";
    string Metric(string path) => AdminDisplay.Text(Model, path) == "-" ? "0" : AdminDisplay.Text(Model, path);

    var header = new OpsPageHeaderViewModel
    {
        Eyebrow = DateTime.Now.ToString("dddd, MMMM dd, yyyy"),
        Title = "Operations command floor",
        Description = "Monitor live shipment pressure, dispatch queues, carrier availability, and exceptions before they slow daily delivery.",
        PrimaryLabel = "Review queue",
        PrimaryController = "Shipments",
        PrimaryAction = "ReviewQueue",
        SecondaryLabel = "Fleet status",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };

    var alerts = AdminDisplay.Rows(AdminDisplay.Value(Model, "RecentActivity"));
    var recentShipments = AdminDisplay.Value(Model, "RecentShipments");
    var fleetRows = AdminDisplay.Rows(AdminDisplay.Value(Model, "RecentCarriers"));

    var kpis = new List<OpsKpiTileViewModel>
    {
        new("Active shipments", Metric("ActiveShipments"), "Shipments currently moving across routes.", "tracking", "info"),
        new("Available drivers", fleetRows.Count.ToString(), "Carrier pool ready for dispatch.", "driver", "success"),
        new("Pending dispatches", Metric("PendingShipments"), "Shipments waiting for assignment or review.", "dispatch", "warning")
    };

    var shipmentTable = new OpsTableViewModel
    {
        Title = "Live shipment movement",
        Subtitle = "Latest operational rows from the active control queue.",
        Source = recentShipments,
        Controller = "Shipments",
        RouteIdName = "shipmentId",
        IdPropertyPath = "Id|ShipmentId",
        Columns = new List<OpsTableColumnViewModel>
        {
            new("Shipment", "TrackingNumber", "id"),
            new("Origin", "SenderCity|PickupAddress"),
            new("Destination", "ReceiverCity|DeliveryAddress"),
            new("Status", "CurrentStatus|Status", "badge"),
            new("Type", "ShipmentType"),
            new("Cost", "ShippinCost|ShippingCost", "currency")
        }
    };
}

<partial name="_OpsPageHeader" model="header" />

<section class="mb-6 ops-card overflow-hidden border-[#F5D4D4] bg-[#FFFDFD]">
    <div class="border-b border-[#F5D4D4] bg-[#FDEBEC] px-6 py-4">
        <div class="flex items-center justify-between gap-4">
            <div>
                <div class="text-[11px] font-extrabold uppercase tracking-[0.18em] text-[#9F2F2D]">Urgent alerts</div>
                <h3 class="mt-1 text-lg font-black text-[#111111]">Exceptions requiring dispatch attention</h3>
            </div>
            <a class="ops-button-danger" asp-area="OperationManagerArea" asp-controller="Shipments" asp-action="ReviewQueue">Open queue</a>
        </div>
    </div>
    @if (alerts.Count == 0)
    {
        <div class="p-6 text-sm font-semibold text-[#787774]">No urgent alerts are currently returned by the database.</div>
    }
    else
    {
        <div class="ops-stagger grid gap-px bg-[#F5D4D4] md:grid-cols-2">
            @foreach (var alert in alerts.Take(2).Select((value, index) => new { value, index }))
            {
                <article class="bg-white p-5" style="--item-index:@alert.index">
                    <span class="@BadgeClass(AdminDisplay.Text(alert.value, "Status|CurrentStatus"))">@AdminDisplay.Text(alert.value, "Status|CurrentStatus")</span>
                    <h4 class="mt-3 text-base font-extrabold text-[#111111]">@AdminDisplay.Text(alert.value, "Title|TrackingNumber")</h4>
                    <p class="mt-2 text-sm leading-6 text-[#787774]">@AdminDisplay.Text(alert.value, "Description|Route|DeliveryAddress")</p>
                    <div class="mt-4 font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#787774]">@AdminDisplay.Text(alert.value, "OccurredAt|CreatedAt")</div>
                </article>
            }
        </div>
    }
</section>

<section class="ops-stagger grid gap-4 md:grid-cols-3">
    @for (var index = 0; index < kpis.Count; index++)
    {
        <div style="--item-index:@index">
            <partial name="_OpsKpiTile" model="kpis[index]" />
        </div>
    }
</section>

<section class="mt-6 grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="ops-card overflow-hidden">
        <div class="border-b border-[#EAEAEA] p-6">
            <h3 class="text-lg font-extrabold text-[#111111]">Live fleet status</h3>
            <p class="mt-1 text-sm leading-6 text-[#787774]">Driver availability, served zones, and current load.</p>
        </div>
        <div class="ops-stagger divide-y divide-[#EAEAEA]">
            @if (fleetRows.Count == 0)
            {
                <div class="p-6 text-sm font-semibold text-[#787774]">No carriers are currently returned by the database.</div>
            }
            @foreach (var carrier in fleetRows.Take(5).Select((value, index) => new { value, index }))
            {
                <a asp-area="OperationManagerArea" asp-controller="Carriers" asp-action="Details" asp-route-carrierId="@AdminDisplay.RouteValue(carrier.value, "Id")" class="block p-5 transition-colors hover:bg-black/[0.035]" style="--item-index:@carrier.index">
                    <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                            <div class="truncate text-sm font-extrabold text-[#111111]">@AdminDisplay.Text(carrier.value, "FullName|Name")</div>
                            <div class="mt-1 text-sm text-[#787774]">@AdminDisplay.Text(carrier.value, "ServedCities|CurrentLocation|City")</div>
                        </div>
                        <span class="@BadgeClass(AdminDisplay.Text(carrier.value, "Status"))">@AdminDisplay.Text(carrier.value, "Status")</span>
                    </div>
                    <div class="mt-4 grid grid-cols-3 gap-3 text-center">
                        <div class="rounded-lg border border-[#EAEAEA] bg-[#FBFBFA] p-3"><div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#787774]">Load</div><div class="mt-1 font-black text-[#111111]">@AdminDisplay.Text(carrier.value, "AssignedShipmentsCount")</div></div>
                        <div class="rounded-lg border border-[#EAEAEA] bg-[#FBFBFA] p-3"><div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#787774]">Trips</div><div class="mt-1 font-black text-[#111111]">@AdminDisplay.Text(carrier.value, "ActiveTripsCount")</div></div>
                        <div class="rounded-lg border border-[#EAEAEA] bg-[#FBFBFA] p-3"><div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#787774]">Rating</div><div class="mt-1 font-black text-[#111111]">@AdminDisplay.Text(carrier.value, "Rating")</div></div>
                    </div>
                </a>
            }
        </div>
    </section>

    <partial name="_OpsTable" model="shipmentTable" />
</section>

@functions {
    private static string BadgeClass(string value) =>
        AdminDisplay.BadgeClass(value).Replace("admin-badge", "ops-badge", StringComparison.Ordinal);
}
