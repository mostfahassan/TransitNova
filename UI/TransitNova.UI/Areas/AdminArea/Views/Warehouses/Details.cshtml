@model UiWarehouseDto?
@{
    ViewData["Title"] = "Warehouse details";
    var warehouse = Model ?? new UiWarehouseDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Warehouse details",
        Description = "Inspect capacity, usage, zones, and operational timestamps.",
        SecondaryLabel = "Back",
        SecondaryController = "Warehouses",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Warehouse record",
        Subtitle = "Full warehouse data returned by the API.",
        PrimaryLabel = warehouse.Name,
        Controller = "Warehouses",
        EditAction = "Edit",
        DeleteAction = "Delete",
        RouteValues = new Dictionary<string, object?> { ["warehouseId"] = warehouse.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Warehouse", warehouse.Name),
            AdminDisplay.AdminCell("Type", warehouse.Type, "badge"),
            AdminDisplay.AdminCell("Address", warehouse.Address),
            AdminDisplay.AdminCell("Capacity", warehouse.Capacity),
            AdminDisplay.AdminCell("Current usage", warehouse.CurrentUsage),
            AdminDisplay.AdminCell("Operating hours", warehouse.OperatingHours),
            AdminDisplay.AdminCell("Zones", warehouse.ZoneNames),
            AdminDisplay.AdminCell("Created", warehouse.CreatedAt),
            AdminDisplay.AdminCell("Updated", warehouse.UpdatedAt)
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
