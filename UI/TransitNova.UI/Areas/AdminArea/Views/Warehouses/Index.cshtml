@model IEnumerable<UiWarehouseDto>?
@{
    ViewData["Title"] = "Warehouses";
    var items = (Model ?? Enumerable.Empty<UiWarehouseDto>()).ToList();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Warehouses",
        Description = "Track storage hubs, capacity, usage, zones, and route support.",
        PrimaryLabel = "Create warehouse",
        PrimaryController = "Warehouses",
        PrimaryAction = "Create"
    };
    var table = new AdminTableViewModel
    {
        Title = "Warehouse network",
        Subtitle = "Fulfillment hubs connected to carriers and trips.",
        Controller = "Warehouses",
        ShowDetails = true,
        ShowEdit = true,
        ShowDelete = true,
        Headers = ["Warehouse", "Type", "Capacity", "Usage", "Carriers", "Active trips"],
        Rows = items.Select(warehouse => AdminDisplay.AdminRow(
            "warehouseId",
            warehouse.Id,
            AdminDisplay.AdminCell("Warehouse", warehouse.Name),
            AdminDisplay.AdminCell("Type", warehouse.Type, "badge"),
            AdminDisplay.AdminCell("Capacity", warehouse.Capacity),
            AdminDisplay.AdminCell("Usage", warehouse.CurrentUsage),
            AdminDisplay.AdminCell("Carriers", warehouse.CarrierCount),
            AdminDisplay.AdminCell("Active trips", warehouse.ActiveTripsCount))).ToList(),
        TotalCount = items.Count,
        PageNumber = 1,
        TotalPages = 1
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
