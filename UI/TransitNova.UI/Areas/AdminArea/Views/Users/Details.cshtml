@model UiAdminUserDetailsDto?
@{
    ViewData["Title"] = "User details";
    var user = Model ?? new UiAdminUserDetailsDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "User details",
        Description = "Inspect identity, profile, address, and account state.",
        SecondaryLabel = "Back",
        SecondaryController = "Users",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "User record",
        Subtitle = "Complete administrative user profile returned by the API.",
        PrimaryLabel = user.FullName,
        Controller = "Users",
        EditAction = null,
        DeleteAction = null,
        RouteValues = new Dictionary<string, object?> { ["userId"] = user.UserId },
        Fields =
        [
            AdminDisplay.AdminCell("Full name", user.FullName),
            AdminDisplay.AdminCell("Username", user.UserName),
            AdminDisplay.AdminCell("Email", user.Email),
            AdminDisplay.AdminCell("Phone", user.PhoneNumber),
            AdminDisplay.AdminCell("Type", user.UserType, "badge"),
            AdminDisplay.AdminCell("Active", user.IsActive, "badge"),
            AdminDisplay.AdminCell("Locked out", user.IsLockedOut, "badge"),
            AdminDisplay.AdminCell("Address", user.Address),
            AdminDisplay.AdminCell("City", user.CityName),
            AdminDisplay.AdminCell("Government", user.GovernmentName),
            AdminDisplay.AdminCell("Country", user.CountryName),
            AdminDisplay.AdminCell("Shipments sent", user.TotalShipmentsSent),
            AdminDisplay.AdminCell("Bundle", user.BundleName),
            AdminDisplay.AdminCell("Created", user.CreatedAt)
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
