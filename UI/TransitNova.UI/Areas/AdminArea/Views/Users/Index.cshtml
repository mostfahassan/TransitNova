@model UiPagedResult<UiAdminUserDetailsDto>?
@{
    ViewData["Title"] = "Users";
    var page = Model ?? UiPagedResult<UiAdminUserDetailsDto>.From([], 0, 1, 10);
    var header = new AdminPageHeaderViewModel
    {
        Title = "Users",
        Description = "Search and review customer accounts, profile health, activity, and lockout state.",
        PrimaryLabel = null,
        PrimaryController = "Users",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "User directory",
        Subtitle = "Users returned from the backend filtering endpoint.",
        Controller = "Users",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["User", "Email", "Type", "City", "Active", "Created"],
        Rows = page.Data.Select(user => AdminDisplay.AdminRow(
            "userId",
            user.UserId,
            AdminDisplay.AdminCell("User", string.IsNullOrWhiteSpace(user.FullName) ? user.UserName : user.FullName),
            AdminDisplay.AdminCell("Email", user.Email),
            AdminDisplay.AdminCell("Type", user.UserType, "badge"),
            AdminDisplay.AdminCell("City", user.CityName),
            AdminDisplay.AdminCell("Active", user.IsActive, "badge"),
            AdminDisplay.AdminCell("Created", user.CreatedAt))).ToList(),
        TotalCount = page.TotalCount,
        PageNumber = page.PageNumber,
        TotalPages = page.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
