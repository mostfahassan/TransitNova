@model UiWarehouseManagerDetailsDto?
@{
    ViewData["Title"] = "Warehouse manager details";
    var manager = Model ?? new UiWarehouseManagerDetailsDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Warehouse manager details",
        Description = "Inspect profile, warehouse assignment, and contact data.",
        SecondaryLabel = "Back",
        SecondaryController = "WarehouseManagers",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Warehouse manager record",
        Subtitle = "Manager details returned by the warehouse management API.",
        PrimaryLabel = manager.FullName,
        Controller = "WarehouseManagers",
        EditAction = null,
        DeleteAction = null,
        RouteValues = new Dictionary<string, object?> { ["id"] = manager.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Manager", manager.FullName),
            AdminDisplay.AdminCell("Email", manager.Email),
            AdminDisplay.AdminCell("Phone", manager.PhoneNumber),
            AdminDisplay.AdminCell("Warehouse", manager.WarehouseName ?? AdminDisplay.Format(manager.WarehouseId, "Warehouse", "id")),
            AdminDisplay.AdminCell("City", "-"),
            AdminDisplay.AdminCell("Government", "-"),
            AdminDisplay.AdminCell("Country", "-"),
            AdminDisplay.AdminCell("Address", "-"),
            AdminDisplay.AdminCell("Active", "-", "badge")
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
