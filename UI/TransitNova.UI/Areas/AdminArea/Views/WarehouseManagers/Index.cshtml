@model UiPagedResult<UiWarehouseManagerListDto>?
@{
    ViewData["Title"] = "Warehouse managers";
    var page = Model ?? UiPagedResult<UiWarehouseManagerListDto>.From([], 0, 1, 10);
    var header = new AdminPageHeaderViewModel
    {
        Title = "Warehouse managers",
        Description = "Review managers attached to warehouses and regional fulfillment workflows.",
        PrimaryLabel = null,
        PrimaryController = "WarehouseManagers",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Warehouse manager directory",
        Subtitle = "Managers returned by warehouse-manager filters.",
        Controller = "WarehouseManagers",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["Manager", "Email", "Phone", "Warehouse", "City", "Active"],
        Rows = page.Data.Select(manager => AdminDisplay.AdminRow(
            "id",
            manager.Id,
            AdminDisplay.AdminCell("Manager", manager.FullName),
            AdminDisplay.AdminCell("Email", manager.Email),
            AdminDisplay.AdminCell("Phone", "-"),
            AdminDisplay.AdminCell("Warehouse", manager.WarehouseName ?? AdminDisplay.Format(manager.WarehouseId, "Warehouse", "id")),
            AdminDisplay.AdminCell("City", "-"),
            AdminDisplay.AdminCell("Active", "-", "badge"))).ToList(),
        TotalCount = page.TotalCount,
        PageNumber = page.PageNumber,
        TotalPages = page.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
