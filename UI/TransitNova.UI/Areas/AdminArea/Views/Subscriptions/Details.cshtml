@model UiBundleSubscriptionDetailsDto?
@{
    ViewData["Title"] = "Subscription details";
    var subscription = Model ?? new UiBundleSubscriptionDetailsDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Subscription details",
        Description = "Inspect a bundle subscription and related customer state.",
        SecondaryLabel = "Back",
        SecondaryController = "Subscriptions",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Subscription record",
        Subtitle = "Subscription data returned by the backend.",
        PrimaryLabel = subscription.FullName,
        Controller = "Subscriptions",
        RouteValues = new Dictionary<string, object?> { ["subscriptionId"] = subscription.Id },
        EditAction = null,
        DeleteAction = null,
        Fields =
        [
            AdminDisplay.AdminCell("Subscription", subscription.Id, "id"),
            AdminDisplay.AdminCell("Bundle", subscription.BundleName),
            AdminDisplay.AdminCell("User", subscription.FullName),
            AdminDisplay.AdminCell("Email", subscription.Email),
            AdminDisplay.AdminCell("Phone", subscription.PhoneNumber),
            AdminDisplay.AdminCell("Status", subscription.IsActive, "badge"),
            AdminDisplay.AdminCell("Created", subscription.SubscriptionDate),
            AdminDisplay.AdminCell("Expires", subscription.EndDate),
            AdminDisplay.AdminCell("Cancelled", subscription.CancelledAt)
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
