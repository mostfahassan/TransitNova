@using TransitNova.Domain.Enums.Shipment
@model UiPagedResult<UiRetrieveShipmentDto>?
@{
    ViewData["Title"] = "Shipments";
    var result = Model ?? new UiPagedResult<UiRetrieveShipmentDto> { PageSize = 20 };
    var items = result.Data.ToList();
    var selectedStatus = Context.Request.Query["Status"].ToString();
    var selectedMode = Context.Request.Query["Mode"].ToString();
    var selectedType = Context.Request.Query["Type"].ToString();
    var header = new AdminPageHeaderViewModel
    {
        Eyebrow = "Shipment oversight",
        Title = "Shipments",
        Description = "Review platform shipments, inspect their routing data, and jump into the full shipment record."
    };

    var table = new AdminTableViewModel
    {
        Title = "Shipment registry",
        Subtitle = "Operationally relevant shipment records returned by the API.",
        Controller = "Shipments",
        ShowDetails = true,
        Headers = ["Tracking", "Status", "Pickup", "Delivery", "Mode", "Type", "Cost", "Created"],
        Rows = items.Select(shipment => AdminDisplay.AdminRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.AdminCell("Tracking", shipment.TrackingNumber, "id"),
            AdminDisplay.AdminCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.AdminCell("Pickup", shipment.PickupAddress),
            AdminDisplay.AdminCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.AdminCell("Mode", shipment.TransportationMode),
            AdminDisplay.AdminCell("Type", shipment.ShipmentType),
            AdminDisplay.AdminCell("Cost", shipment.ShippingCost, "currency"),
            AdminDisplay.AdminCell("Created", shipment.CreatedAt))).ToList(),
        TotalCount = result.TotalCount,
        PageNumber = result.PageNumber,
        TotalPages = result.PageSize <= 0 ? 1 : result.TotalPages,
        EmptyTitle = "No shipments found",
        EmptyDescription = "Once shipments are returned by the API they will appear here."
    };
}

<partial name="_AdminPageHeader" model="header" />

<section class="admin-card mb-6 p-5">
    <form method="get" class="grid gap-4 lg:grid-cols-[minmax(220px,1fr)_180px_150px_150px_220px_160px_160px_auto] lg:items-end">
        <div>
            <label class="admin-label" for="SearchTerm">Search shipment</label>
            <input id="SearchTerm" name="SearchTerm" value="@Context.Request.Query["SearchTerm"]" class="admin-input" placeholder="Tracking, city, address" />
        </div>
        <div>
            <label class="admin-label" for="Status">Status</label>
            <select id="Status" name="Status" class="admin-select">
                <option value="">Any status</option>
                @foreach (var status in Enum.GetValues<ShipmentStatuses>())
                {
                    var value = status.ToString();
                    <option value="@value" selected="@(selectedStatus == value ? "selected" : null)">@value</option>
                }
            </select>
        </div>
        <div>
            <label class="admin-label" for="Mode">Mode</label>
            <select id="Mode" name="Mode" class="admin-select">
                <option value="">Any mode</option>
                @foreach (var mode in Enum.GetValues<TransportationMode>())
                {
                    var value = mode.ToString();
                    <option value="@value" selected="@(selectedMode == value ? "selected" : null)">@value</option>
                }
            </select>
        </div>
        <div>
            <label class="admin-label" for="Type">Type</label>
            <select id="Type" name="Type" class="admin-select">
                <option value="">Any type</option>
                @foreach (var type in Enum.GetValues<enShipmentType>())
                {
                    var value = type.ToString();
                    <option value="@value" selected="@(selectedType == value ? "selected" : null)">@value</option>
                }
            </select>
        </div>
        <div>
            <label class="admin-label" for="SenderId">Sender Id</label>
            <input id="SenderId" name="SenderId" value="@Context.Request.Query["SenderId"]" class="admin-input" placeholder="Customer profile id" />
        </div>
        <div>
            <label class="admin-label" for="From">From</label>
            <input id="From" name="From" type="date" value="@Context.Request.Query["From"]" class="admin-input" />
        </div>
        <div>
            <label class="admin-label" for="To">To</label>
            <input id="To" name="To" type="date" value="@Context.Request.Query["To"]" class="admin-input" />
        </div>
        <button type="submit" class="admin-button h-[46px]">Filter</button>
    </form>
</section>

<partial name="_AdminTable" model="table" />
