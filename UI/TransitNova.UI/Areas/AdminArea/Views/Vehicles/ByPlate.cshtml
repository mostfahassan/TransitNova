@model UiVehicleDto?
@{
    ViewData["Title"] = "Vehicle by plate";
    var vehicle = Model ?? new UiVehicleDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Vehicle by plate",
        Description = "Lookup result for a fleet unit by plate number.",
        SecondaryLabel = "Back",
        SecondaryController = "Vehicles",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Vehicle record",
        Subtitle = "Fleet metadata matched by plate number.",
        PrimaryLabel = vehicle.PlateNumber,
        Controller = "Vehicles",
        EditAction = null,
        DeleteAction = "Delete",
        RouteValues = new Dictionary<string, object?> { ["vehicleId"] = vehicle.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Plate", vehicle.PlateNumber, "id"),
            AdminDisplay.AdminCell("Type", vehicle.VehicleType, "badge"),
            AdminDisplay.AdminCell("Carrier", vehicle.CarrierName),
            AdminDisplay.AdminCell("Carrier code", vehicle.CarrierCode, "id"),
            AdminDisplay.AdminCell("Carrier status", vehicle.CarrierStatus, "badge"),
            AdminDisplay.AdminCell("Capacity weight", vehicle.CapacityWeight),
            AdminDisplay.AdminCell("Capacity volume", vehicle.CapacityVolume),
            AdminDisplay.AdminCell("Refrigerated", vehicle.IsRefrigerated, "badge"),
            AdminDisplay.AdminCell("Active", vehicle.IsActive, "badge")
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
