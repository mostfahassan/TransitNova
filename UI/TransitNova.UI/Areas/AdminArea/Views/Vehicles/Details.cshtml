@model object?
@{
    ViewData["Title"] = "Vehicle details";
    var header = new AdminPageHeaderViewModel
    {
        Title = "Vehicle details",
        Description = "Inspect fleet capacity and carrier association.",
        SecondaryLabel = "Back",
        SecondaryController = "Vehicles",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Vehicle record",
        Subtitle = "Fleet metadata used by carrier assignment and delivery planning.",
        Source = Model,
        Controller = "Vehicles",
        RouteIdName = "vehicleId",
        IdPropertyPath = "Id|VehicleId",
        EditAction = null,
        DeleteAction = "Delete",
        Fields = new List<AdminTableColumnViewModel>
        {
            new("Plate", "PlateNumber", "id"),
            new("Type", "VehicleType", "badge"),
            new("Carrier", "CarrierName"),
            new("Carrier code", "CarrierCode", "id"),
            new("Carrier status", "CarrierStatus", "badge"),
            new("Capacity weight", "CapacityWeight"),
            new("Capacity volume", "CapacityVolume"),
            new("Refrigerated", "IsRefrigerated", "badge"),
            new("Active", "IsActive", "badge")
        }
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
