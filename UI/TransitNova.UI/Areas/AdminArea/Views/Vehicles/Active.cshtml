@model IEnumerable<UiVehicleDto>?
@{
    ViewData["Title"] = "Active vehicles";
    var items = (Model ?? Enumerable.Empty<UiVehicleDto>()).ToList();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Active vehicles",
        Description = "Operational fleet units currently available in the system.",
        PrimaryLabel = null,
        PrimaryController = "Vehicles",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Active fleet",
        Subtitle = "Vehicles that can participate in current assignment flows.",
        Controller = "Vehicles",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = true,
        Headers = ["Plate", "Type", "Carrier", "Weight", "Volume", "Active"],
        Rows = items.Select(vehicle => AdminDisplay.AdminRow(
            "vehicleId",
            vehicle.Id,
            AdminDisplay.AdminCell("Plate", vehicle.PlateNumber, "id"),
            AdminDisplay.AdminCell("Type", vehicle.VehicleType, "badge"),
            AdminDisplay.AdminCell("Carrier", vehicle.CarrierName),
            AdminDisplay.AdminCell("Weight", vehicle.CapacityWeight),
            AdminDisplay.AdminCell("Volume", vehicle.CapacityVolume),
            AdminDisplay.AdminCell("Active", vehicle.IsActive, "badge"))).ToList(),
        TotalCount = items.Count,
        PageNumber = 1,
        TotalPages = 1
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
