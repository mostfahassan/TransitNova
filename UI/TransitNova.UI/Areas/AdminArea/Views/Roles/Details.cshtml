@model object?
@{
    ViewData["Title"] = "Role details";
    var header = new AdminPageHeaderViewModel
    {
        Title = "Role details",
        Description = "Inspect the selected role before editing its name or reviewing its members.",
        SecondaryLabel = "Back",
        SecondaryController = "Roles",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Role record",
        Subtitle = "Authorization role summary from the backend.",
        Source = Model,
        Controller = "Roles",
        RouteIdName = "roleId",
        IdPropertyPath = "RoleId|Id",
        EditAction = "Edit",
        DeleteAction = "Delete",
        Fields = new List<AdminTableColumnViewModel>
        {
            new("Role", "RoleName|Name"),
            new("Total Users", "TotalUsers|UsersCount")
        }
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
