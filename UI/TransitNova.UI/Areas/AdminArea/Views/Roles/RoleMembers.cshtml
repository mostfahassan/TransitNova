@model UiRoleMembersDto?
@{
    ViewData["Title"] = "Role Members";
    var members = Model ?? new UiRoleMembersDto();
    var pager = new AdminPagerViewModel
    {
        PageNumber = members.PageNumber,
        TotalPages = members.TotalPages,
        PreviousUrl = members.PageNumber > 1 ? Url.Action("RoleMembers", "Roles", new { area = "AdminArea", roleId = members.RoleId, pageNumber = members.PageNumber - 1, pageSize = members.PageSize }) : null,
        NextUrl = members.PageNumber < members.TotalPages ? Url.Action("RoleMembers", "Roles", new { area = "AdminArea", roleId = members.RoleId, pageNumber = members.PageNumber + 1, pageSize = members.PageSize }) : null
    };
    var header = new AdminPageHeaderViewModel
    {
        Title = "RoleMembers",
        Description = "Read-only paginated view of the users currently assigned to the selected role.",
        SecondaryLabel = "Back to roles",
        SecondaryController = "Roles",
        SecondaryAction = "Index"
    };
    var table = new AdminTableViewModel
    {
        Title = members.RoleName,
        Subtitle = $"{members.TotalUsers} current members in this role.",
        Controller = "Roles",
        ShowDetails = false,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["Full Name", "Email", "Phone Number", "Status"],
        Rows = members.Users.Select(user => AdminDisplay.AdminRow(
            "userId",
            user.UserId,
            AdminDisplay.AdminCell("Full Name", user.FullName),
            AdminDisplay.AdminCell("Email", user.Email),
            AdminDisplay.AdminCell("Phone Number", user.PhoneNumber),
            AdminDisplay.AdminCell("Status", user.Status, "badge"))).ToList(),
        TotalCount = members.TotalUsers,
        PageNumber = members.PageNumber,
        TotalPages = members.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
<partial name="_AdminPager" model="pager" />
