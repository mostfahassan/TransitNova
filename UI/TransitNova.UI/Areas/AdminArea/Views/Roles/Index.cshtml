@model IEnumerable<UiRoleSummaryDto>?
@{
    ViewData["Title"] = "Roles";
    var items = (Model ?? Enumerable.Empty<UiRoleSummaryDto>()).ToList();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Roles",
        Description = "Control the authorization surface used by MVC and API policies.",
        PrimaryLabel = "Create role",
        PrimaryController = "Roles",
        PrimaryAction = "Create"
    };
    var table = new AdminTableViewModel
    {
        Title = "Role registry",
        Subtitle = "Application roles available to the identity system.",
        Controller = "Roles",
        ShowDetails = true,
        ShowEdit = true,
        ShowDelete = true,
        RowActions = [new AdminRowActionViewModel("RoleMembers", "RoleMembers")],
        Headers = ["Role", "Total Users"],
        Rows = items.Select(role => AdminDisplay.AdminRow(
            "roleId",
            role.RoleId,
            AdminDisplay.AdminCell("Role", role.RoleName),
            AdminDisplay.AdminCell("Total Users", role.TotalUsers))).ToList(),
        TotalCount = items.Count,
        PageNumber = 1,
        TotalPages = 1
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
