@model UiRoleMembersDto?
@{
    ViewData["Title"] = "Role Members";
    var members = Model ?? new UiRoleMembersDto();
    var users = members.Users.ToList();
    var roleId = AdminDisplay.Format(members.RoleId, "Role", "id");
    var header = new AdminPageHeaderViewModel
    {
        Title = "Role members",
        Description = "Assign or remove users from the selected authorization role without exposing low-level identity implementation details.",
        SecondaryLabel = "Back to roles",
        SecondaryController = "Roles",
        SecondaryAction = "Index"
    };
}

<partial name="_AdminPageHeader" model="header" />

<form method="post" class="admin-card overflow-hidden">
    @Html.AntiForgeryToken()
    <div class="flex flex-col gap-3 border-b border-[#EAEAEA] p-6 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <div class="text-[11px] font-extrabold uppercase tracking-[0.18em] text-[#787774]">Role / @roleId</div>
            <h3 class="mt-2 text-2xl font-extrabold tracking-tight text-[#111111]">@members.RoleName</h3>
        </div>
        <button type="submit" class="admin-button">Save membership</button>
    </div>

    @if (users.Count == 0)
    {
        <div class="p-12 text-center">
            <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl border border-[#EAEAEA] bg-[#FBFBFA] text-[#787774]">TN</div>
            <h4 class="mt-5 text-lg font-bold text-[#111111]">No users returned</h4>
            <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-[#787774]">When the backend returns role members, they will appear here with membership toggles.</p>
        </div>
    }
    else
    {
        <div class="divide-y divide-[#EAEAEA]">
            @for (var index = 0; index < users.Count; index++)
            {
                var user = users[index];
                <label class="flex cursor-pointer items-center justify-between gap-4 bg-white p-5 transition-colors hover:bg-black/[0.025]" style="--row-index:@index">
                    <span class="min-w-0">
                        <span class="block truncate text-sm font-bold text-[#111111]">@user.FullName</span>
                        <span class="mt-1 block truncate text-xs text-[#787774]">@user.Email</span>
                    </span>
                    <span class="flex items-center gap-3">
                        <input type="hidden" name="Users[@index].UserId" value="@user.UserId" />
                        <input type="hidden" name="Users[@index].IsInRole" value="false" />
                        <input type="checkbox" name="Users[@index].IsInRole" value="true" checked="@user.IsInRole" class="h-5 w-5 rounded border-[#EAEAEA] text-[#111111] focus:ring-[#111111]/10" />
                        <span class="text-xs font-bold uppercase tracking-[0.14em] text-[#787774]">Member</span>
                    </span>
                </label>
            }
        </div>
    }
</form>
