@model UiRetrieveBundleDto?
@{
    ViewData["Title"] = "Bundle details";
    var bundle = Model ?? new UiRetrieveBundleDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Bundle details",
        Description = "Inspect bundle pricing and operational limits.",
        SecondaryLabel = "Back",
        SecondaryController = "Bundles",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Bundle record",
        Subtitle = "Full bundle configuration returned by the backend.",
        PrimaryLabel = bundle.BundleName,
        Controller = "Bundles",
        EditAction = null,
        DeleteAction = null,
        RouteValues = new Dictionary<string, object?> { ["bundleId"] = bundle.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Name", bundle.BundleName),
            AdminDisplay.AdminCell("Price", bundle.BundlePrice, "currency"),
            AdminDisplay.AdminCell("Weight", bundle.MaxWeightPerShipment),
            AdminDisplay.AdminCell("Distance", bundle.MaxDistancePerShipment),
            AdminDisplay.AdminCell("Shipments", bundle.MaxShipmentsPerMonth),
            AdminDisplay.AdminCell("Description", bundle.BundleDescription)
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
