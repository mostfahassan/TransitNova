@model IEnumerable<UiRetrieveBundleDto>?
@{
    ViewData["Title"] = "Bundles";
    var items = (Model ?? Enumerable.Empty<UiRetrieveBundleDto>()).ToList();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Bundles",
        Description = "Manage customer-facing shipment bundles, pricing, weight limits, and distance rules.",
        PrimaryLabel = "Create bundle",
        PrimaryController = "Bundles",
        PrimaryAction = "Create"
    };
    var table = new AdminTableViewModel
    {
        Title = "Bundle catalog",
        Subtitle = "Operational products available to users and subscriptions.",
        Controller = "Bundles",
        ShowDetails = true,
        ShowEdit = true,
        ShowDelete = true,
        Headers = ["Name", "Price", "Weight", "Distance", "Shipments"],
        Rows = items.Select(bundle => AdminDisplay.AdminRow(
            "bundleId",
            bundle.Id,
            AdminDisplay.AdminCell("Name", bundle.BundleName),
            AdminDisplay.AdminCell("Price", bundle.BundlePrice, "currency"),
            AdminDisplay.AdminCell("Weight", bundle.MaxWeightPerShipment),
            AdminDisplay.AdminCell("Distance", bundle.MaxDistancePerShipment),
            AdminDisplay.AdminCell("Shipments", bundle.MaxShipmentsPerMonth))).ToList(),
        TotalCount = items.Count,
        PageNumber = 1,
        TotalPages = 1
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
