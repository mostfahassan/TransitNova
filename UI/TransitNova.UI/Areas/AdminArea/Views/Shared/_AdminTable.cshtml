@model AdminTableViewModel

<section class="admin-card overflow-hidden">
    <div class="flex flex-col gap-4 border-b border-[#EAEAEA] p-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h3 class="text-lg font-extrabold tracking-tight text-[#111111]">@Model.Title</h3>
            <p class="mt-1 text-sm text-[#787774]">@Model.Subtitle</p>
        </div>
        <div class="text-[11px] font-extrabold uppercase tracking-[0.16em] text-[#787774]">
            @Model.TotalCount records / page @Model.PageNumber of @Model.TotalPages
        </div>
    </div>

    @if (Model.Rows.Count == 0)
    {
        <div class="p-12 text-center">
            <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl border border-[#EAEAEA] bg-[#FBFBFA] text-[#787774]">TN</div>
            <h4 class="mt-5 text-lg font-bold text-[#111111]">@Model.EmptyTitle</h4>
            <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-[#787774]">@Model.EmptyDescription</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="admin-table">
                <thead>
                    <tr>
                        @foreach (var header in Model.Headers)
                        {
                            <th>@header</th>
                        }
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < Model.Rows.Count; index++)
                    {
                        var row = Model.Rows[index];
                        var detailsUrl = Url.Action(Model.DetailsAction, Model.Controller, row.RouteValues);
                        var editUrl = Url.Action(Model.EditAction, Model.Controller, row.RouteValues);
                        var deleteUrl = Url.Action(Model.DeleteAction, Model.Controller, row.RouteValues);

                        <tr style="--row-index:@index">
                            @foreach (var cell in row.Cells)
                            {
                                <td>
                                    @if (cell.Kind == "badge")
                                    {
                                        <span class="@AdminDisplay.BadgeClass(cell.Text)">@cell.Text</span>
                                    }
                                    else if (cell.Kind == "id")
                                    {
                                        <span class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[#55524D]">@cell.Text</span>
                                    }
                                    else
                                    {
                                        <span>@cell.Text</span>
                                    }
                                </td>
                            }
                            <td>
                                <div class="flex items-center justify-end gap-2">
                                    @if (Model.ShowDetails && !string.IsNullOrWhiteSpace(detailsUrl))
                                    {
                                        <a href="@detailsUrl" class="admin-button-secondary !px-3 !py-2">View</a>
                                    }
                                    @if (Model.ShowEdit && !string.IsNullOrWhiteSpace(editUrl))
                                    {
                                        <a href="@editUrl" class="admin-button-secondary !px-3 !py-2">Edit</a>
                                    }
                                    @foreach (var rowAction in Model.RowActions)
                                    {
                                        var rowActionUrl = Url.Action(rowAction.Action, Model.Controller, row.RouteValues);
                                        if (!string.IsNullOrWhiteSpace(rowActionUrl))
                                        {
                                            var buttonClass = rowAction.Style.Equals("primary", StringComparison.OrdinalIgnoreCase)
                                                ? "admin-button !px-3 !py-2"
                                                : rowAction.Style.Equals("danger", StringComparison.OrdinalIgnoreCase)
                                                    ? "admin-button-danger !px-3 !py-2"
                                                    : "admin-button-secondary !px-3 !py-2";
                                            <a href="@rowActionUrl" class="@buttonClass">@rowAction.Label</a>
                                        }
                                    }
                                    @if (Model.ShowDelete && !string.IsNullOrWhiteSpace(deleteUrl))
                                    {
                                        <form method="post" action="@deleteUrl" data-confirm="Delete this record? This action cannot be undone.">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="admin-button-danger !px-3 !py-2">Delete</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
