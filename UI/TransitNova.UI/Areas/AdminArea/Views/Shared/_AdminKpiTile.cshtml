@model AdminKpiTileViewModel

<article class="admin-card admin-lift p-5">
    <div class="flex items-start justify-between gap-4">
        <div>
            <p class="text-[11px] font-extrabold uppercase tracking-[0.14em] text-[#787774]">@Model.Label</p>
            <p class="mt-4 text-3xl font-extrabold tracking-tight text-[#111111]">@Model.Value</p>
        </div>
        <div class="grid h-11 w-11 place-items-center rounded-xl border border-[#EAEAEA] bg-[#FBFBFA] text-[#111111]">
            <span class="text-xs font-black uppercase tracking-[0.14em]">@Model.Icon</span>
        </div>
    </div>
    <p class="mt-4 text-sm leading-6 text-[#787774]">@Model.Meta</p>
</article>
