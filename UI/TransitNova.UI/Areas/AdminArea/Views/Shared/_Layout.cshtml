<!DOCTYPE html>
<html lang="en" class="h-full bg-background">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - TransitNova Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@20..48,0..1&display=swap" rel="stylesheet">
    <style>
            @@keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .fade-in {
                animation: fadeIn 0.4s ease-out forwards;
            }

            body {
                font-family: 'Inter', sans-serif;
            }
    </style>

    <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            background: '#F9FAFB',
                            surface: '#FFFFFF',
                            primary: '#2563EB',
                            'on-surface': '#111827',
                            'on-surface-variant': '#6B7280'
                        }
                    }
                }
            }
    </script>
</head>
<body class="h-full flex overflow-hidden">

    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col h-full shrink-0">
        <div class="p-6 flex items-center gap-3">
            <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold">TN</div>
            <span class="font-bold text-lg tracking-tight text-on-surface">TransitNova</span>
        </div>

        <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
            <partial name="_SidebarItem" model='("Dashboard", "dashboard", "Dashboard", "Index")' />
            <partial name="_SidebarItem" model='("Shipments", "local_shipping", "OperationManagers", "Index")' />
            <partial name="_SidebarItem" model='("Bundles", "inventory_2", "Bundles", "Index")' />
            <partial name="_SidebarItem" model='("Carriers", "rv_hookup", "Carriers", "Index")' />
            <partial name="_SidebarItem" model='("Cities", "location_city", "Cities", "Index")' />
            <partial name="_SidebarItem" model='("Governments", "map", "Governments", "Index")' />
            <partial name="_SidebarItem" model='("Roles", "admin_panel_settings", "Roles", "Index")' />
        </nav>
    </aside>

    <main class="flex-1 flex flex-col h-full overflow-hidden">
        <header class="h-16 bg-white/80 backdrop-blur-md border-b border-gray-200 px-8 flex items-center justify-between shrink-0">
            <h1 class="text-lg font-semibold text-on-surface">@ViewData["Title"]</h1>
            <div class="flex items-center gap-4">
                <button class="p-2 text-on-surface-variant hover:bg-gray-100 rounded-full transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <div class="w-8 h-8 bg-gray-200 rounded-full"></div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 fade-in">
            @RenderBody()
        </div>
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>