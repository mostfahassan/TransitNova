@{
    var currentController = Context.Request.RouteValues["controller"]?.ToString();
    var items = new[]
    {
        new AdminSidebarItemViewModel("Dashboard", "Dashboard", "Index", "dashboard"),
        new AdminSidebarItemViewModel("Bundles", "Bundles", "Index", "box"),
        new AdminSidebarItemViewModel("Cities", "Cities", "Index", "pin"),
        new AdminSidebarItemViewModel("Governments", "Governments", "Index", "map"),
        new AdminSidebarItemViewModel("Warehouses", "Warehouses", "Index", "warehouse"),
        new AdminSidebarItemViewModel("Vehicles", "Vehicles", "Index", "truck"),
        new AdminSidebarItemViewModel("Users", "Users", "Index", "users"),
        new AdminSidebarItemViewModel("Carriers", "Carriers", "Index", "carrier"),
        new AdminSidebarItemViewModel("Operations", "OperationManagers", "Index", "radar"),
        new AdminSidebarItemViewModel("Warehouse Managers", "WarehouseManagers", "Index", "clipboard"),
        new AdminSidebarItemViewModel("Roles", "Roles", "Index", "shield"),
        new AdminSidebarItemViewModel("Subscriptions", "Subscriptions", "BundleSubscribers", "receipt")
    };
}

<aside class="admin-sidebar">
    <div class="border-b border-[#EAEAEA] p-6">
        <a asp-area="LandingArea" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 active:scale-95 transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-[#111111] text-sm font-black text-white">TN</span>
            <span>
                <span class="block text-base font-extrabold tracking-tight text-[#111111]">TransitNova</span>
                <span class="block text-[10px] font-bold uppercase tracking-[0.16em] text-[#787774]">Logistics admin</span>
            </span>
        </a>
    </div>

    <nav class="flex-1 overflow-y-auto p-4">
        <div class="mb-3 px-2 text-[10px] font-extrabold uppercase tracking-[0.18em] text-[#787774]">Control surface</div>
        <div class="space-y-1">
            @foreach (var item in items)
            {
                var active = string.Equals(currentController, item.Controller, StringComparison.OrdinalIgnoreCase);
                <a asp-area="AdminArea" asp-controller="@item.Controller" asp-action="@item.Action" class="admin-sidebar-link @(active ? "is-active" : string.Empty)">
                    @Html.Raw(AdminIcon(item.Icon))
                    <span class="truncate">@item.Label</span>
                    @if (!string.IsNullOrWhiteSpace(item.Badge))
                    {
                        <span class="ml-auto rounded-full bg-[#F1F1EF] px-2 py-0.5 text-[10px] font-bold text-[#55524D]">@item.Badge</span>
                    }
                </a>
            }
        </div>
    </nav>

    <div class="border-t border-[#EAEAEA] p-4">
        <div class="rounded-xl border border-[#EAEAEA] bg-white p-3">
            <div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-[0.16em] text-[#787774]">
                <span>System</span>
                <span class="text-[#346538]">Online</span>
            </div>
            <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-[#F1F1EF]">
                <div class="h-full w-[78%] rounded-full bg-[#111111]"></div>
            </div>
            <p class="mt-2 text-xs leading-5 text-[#787774]">API clients wired. MVC views ready for data binding.</p>
        </div>
    </div>
</aside>

