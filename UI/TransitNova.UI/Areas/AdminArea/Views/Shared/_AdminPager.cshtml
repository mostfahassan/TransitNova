@model AdminPagerViewModel

@if (Model.TotalPages > 1)
{
    <div class="mt-6 flex items-center justify-between gap-3 rounded-[20px] border border-[#EAEAEA] bg-white px-4 py-3">
        <div class="text-sm font-semibold text-[#787774]">
            Page <span class="font-extrabold text-[#111111]">@Model.PageNumber</span> of <span class="font-extrabold text-[#111111]">@Model.TotalPages</span>
        </div>
        <div class="flex items-center gap-2">
            @if (!string.IsNullOrWhiteSpace(Model.PreviousUrl))
            {
                <a href="@Model.PreviousUrl" class="admin-button-secondary !px-3 !py-2">Previous</a>
            }
            else
            {
                <span class="admin-button-secondary pointer-events-none !px-3 !py-2 opacity-45">Previous</span>
            }

            @if (!string.IsNullOrWhiteSpace(Model.NextUrl))
            {
                <a href="@Model.NextUrl" class="admin-button !px-3 !py-2">Next</a>
            }
            else
            {
                <span class="admin-button pointer-events-none !px-3 !py-2 opacity-45">Next</span>
            }
        </div>
    </div>
}
