@model UiPagedResult<UiTripDetailsDto>?
@{
    ViewData["Title"] = "Trips";
    var result = Model ?? new UiPagedResult<UiTripDetailsDto> { PageSize = 20 };
    var items = result.Data.ToList();
    var header = new AdminPageHeaderViewModel
    {
        Eyebrow = "Trip oversight",
        Title = "Trips",
        Description = "Review pickup and delivery trips across warehouses, carriers, timing windows, and manifest size.",
        SecondaryLabel = "Shipments",
        SecondaryController = "Shipments",
        SecondaryAction = "Index"
    };
    var table = new AdminTableViewModel
    {
        Title = "Trip directory",
        Subtitle = "Trips returned from the admin filtering endpoint.",
        Controller = "Trips",
        ShowDetails = true,
        Headers = ["Trip", "Type", "Status", "Carrier", "Warehouse", "Shipments", "Planned", "Started", "Ended"],
        Rows = items.Select(trip => AdminDisplay.AdminRow(
            "tripId",
            trip.Id,
            AdminDisplay.AdminCell("Trip", trip.Id, "id"),
            AdminDisplay.AdminCell("Type", trip.TripType),
            AdminDisplay.AdminCell("Status", trip.Status, "badge"),
            AdminDisplay.AdminCell("Carrier", trip.CarrierName),
            AdminDisplay.AdminCell("Warehouse", trip.WarehouseName),
            AdminDisplay.AdminCell("Shipments", trip.TotalShipments),
            AdminDisplay.AdminCell("Planned", trip.PlannedDate),
            AdminDisplay.AdminCell("Started", trip.StartTime),
            AdminDisplay.AdminCell("Ended", trip.EndTime))).ToList(),
        TotalCount = result.TotalCount,
        PageNumber = result.PageNumber,
        TotalPages = result.PageSize <= 0 ? 1 : result.TotalPages,
        EmptyTitle = "No trips found",
        EmptyDescription = "Trips matching the current filter will appear here."
    };
}

<partial name="_AdminPageHeader" model="header" />

<section class="admin-card mb-6 p-5 md:p-6">
    <form method="get" class="grid gap-3 md:grid-cols-2 xl:grid-cols-[repeat(6,minmax(0,1fr))_auto] xl:items-end">
        <div>
            <label class="admin-label" for="Id">Trip Id</label>
            <input id="Id" name="Id" value="@Context.Request.Query["Id"]" class="admin-input" placeholder="Trip Guid" autocomplete="off" />
        </div>
        <div>
            <label class="admin-label" for="TripType">Trip type</label>
            <input id="TripType" name="TripType" value="@Context.Request.Query["TripType"]" class="admin-input" placeholder="Pickup / Delivery" autocomplete="off" />
        </div>
        <div>
            <label class="admin-label" for="Status">Status</label>
            <input id="Status" name="Status" value="@Context.Request.Query["Status"]" class="admin-input" placeholder="Planned / Started" autocomplete="off" />
        </div>
        <div>
            <label class="admin-label" for="CarrierId">Carrier Id</label>
            <input id="CarrierId" name="CarrierId" value="@Context.Request.Query["CarrierId"]" class="admin-input" placeholder="Carrier Guid" autocomplete="off" />
        </div>
        <div>
            <label class="admin-label" for="From">From</label>
            <input id="From" name="From" value="@Context.Request.Query["From"]" type="date" class="admin-input" />
        </div>
        <div>
            <label class="admin-label" for="To">To</label>
            <input id="To" name="To" value="@Context.Request.Query["To"]" type="date" class="admin-input" />
        </div>
        <button type="submit" class="admin-button">Filter</button>
    </form>
</section>

<partial name="_AdminTable" model="table" />
