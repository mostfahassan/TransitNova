@model UiTripDetailsDto?
@{
    ViewData["Title"] = "Trip Details";
    var trip = Model ?? new UiTripDetailsDto();
    var header = new AdminPageHeaderViewModel
    {
        Eyebrow = "Trip oversight",
        Title = "Trip details",
        Description = "Inspect the carrier lane, warehouse context, timestamps, and shipment manifest for one trip.",
        SecondaryLabel = "Back",
        SecondaryController = "Trips",
        SecondaryAction = "Index"
    };
    var tripType = AdminDisplay.Format(trip.TripType);
    var tripStatus = AdminDisplay.Format(trip.Status, kind: "badge");
    var totalShipments = AdminDisplay.Format(trip.TotalShipments);
    var tripTypeKpi = new AdminKpiTileViewModel("Trip type", tripType, "Movement lane", "TR");
    var statusKpi = new AdminKpiTileViewModel("Status", tripStatus, "Current state", "ST");
    var shipmentCountKpi = new AdminKpiTileViewModel("Shipments", totalShipments, "Manifest count", "SH");
    var detail = new AdminDetailViewModel
    {
        Title = "Trip record",
        Subtitle = "Administrative trip projection returned by the API.",
        PrimaryLabel = trip.Id == Guid.Empty ? string.Empty : trip.Id.ToString(),
        Controller = "Trips",
        RouteValues = new Dictionary<string, object?> { ["tripId"] = trip.Id },
        EditAction = null,
        DeleteAction = null,
        Fields =
        [
            AdminDisplay.AdminCell("Trip", trip.Id, "id"),
            AdminDisplay.AdminCell("Type", trip.TripType),
            AdminDisplay.AdminCell("Status", trip.Status, "badge"),
            AdminDisplay.AdminCell("Carrier", trip.CarrierName),
            AdminDisplay.AdminCell("Carrier phone", trip.CarrierPhoneNumber),
            AdminDisplay.AdminCell("Warehouse", trip.WarehouseName),
            AdminDisplay.AdminCell("Address", trip.WarehouseAddress),
            AdminDisplay.AdminCell("Planned", trip.PlannedDate),
            AdminDisplay.AdminCell("Started", trip.StartTime),
            AdminDisplay.AdminCell("Ended", trip.EndTime),
            AdminDisplay.AdminCell("Shipments", trip.TotalShipments),
            AdminDisplay.AdminCell("Created by", trip.CreatedBy),
            AdminDisplay.AdminCell("Created", trip.CreatedAt)
        ]
    };
    var shipmentTable = new AdminTableViewModel
    {
        Title = "Trip shipment manifest",
        Subtitle = "Shipments currently attached to this trip.",
        Controller = "Shipments",
        ShowDetails = true,
        Headers = ["Tracking", "Status", "Receiver", "Pickup", "Delivery", "Cost"],
        Rows = trip.Shipments.Select(shipment => AdminDisplay.AdminRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.AdminCell("Tracking", shipment.TrackingNumber, "id"),
            AdminDisplay.AdminCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.AdminCell("Receiver", shipment.Receiver.FullName),
            AdminDisplay.AdminCell("Pickup", shipment.PickupAddress),
            AdminDisplay.AdminCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.AdminCell("Cost", shipment.ShippingCost, "currency"))).ToList(),
        EmptyTitle = "No shipments on this trip",
        EmptyDescription = "The manifest will appear here when shipments are attached to the trip."
    };
}

<partial name="_AdminPageHeader" model="header" />

<section class="mb-6 grid gap-4 md:grid-cols-3">
    <partial name="_AdminKpiTile" model="tripTypeKpi" />
    <partial name="_AdminKpiTile" model="statusKpi" />
    <partial name="_AdminKpiTile" model="shipmentCountKpi" />
</section>

<partial name="_AdminDetail" model="detail" />

<section class="mt-6">
    <partial name="_AdminTable" model="shipmentTable" />
</section>
