@model UiRetrieveShipmentDto?
@{
    ViewData["Title"] = "Carrier shipment details";
    var shipment = Model ?? new UiRetrieveShipmentDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Carrier shipment details",
        Description = "Inspect a carrier shipment, package data, status history, and route data.",
        SecondaryLabel = "Back",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Shipment record",
        Subtitle = "Shipment details returned inside the carrier administration surface.",
        PrimaryLabel = shipment.TrackingNumber,
        Controller = "Carriers",
        EditAction = null,
        DeleteAction = null,
        RouteValues = new Dictionary<string, object?> { ["shipmentId"] = shipment.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Tracking", shipment.TrackingNumber, "id"),
            AdminDisplay.AdminCell("Pickup", shipment.PickupAddress),
            AdminDisplay.AdminCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.AdminCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.AdminCell("Mode", shipment.TransportationMode, "badge"),
            AdminDisplay.AdminCell("Type", shipment.ShipmentType, "badge"),
            AdminDisplay.AdminCell("Cost", shipment.ShippingCost, "currency"),
            AdminDisplay.AdminCell("Estimated delivery", shipment.EstimatedDeliveryDate),
            AdminDisplay.AdminCell("Created", shipment.CreatedAt),
            AdminDisplay.AdminCell("Receiver", shipment.Receiver.FullName),
            AdminDisplay.AdminCell("Sender", shipment.Sender?.FullName)
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
