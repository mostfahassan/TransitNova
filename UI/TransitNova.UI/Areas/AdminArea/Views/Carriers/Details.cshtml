@model UiCarrierProfileDto?
@{
    ViewData["Title"] = "Carrier details";
    var carrier = Model ?? new UiCarrierProfileDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Carrier details",
        Description = "Inspect carrier operational state, zones, load, and rating.",
        SecondaryLabel = "Back",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Carrier record",
        Subtitle = "Carrier profile and summary details from the API.",
        PrimaryLabel = carrier.FullName,
        Controller = "Carriers",
        EditAction = null,
        DeleteAction = "Delete",
        RouteValues = new Dictionary<string, object?> { ["carrierId"] = carrier.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Carrier", carrier.FullName),
            AdminDisplay.AdminCell("Code", carrier.Code, "id"),
            AdminDisplay.AdminCell("Phone", carrier.PhoneNumber),
            AdminDisplay.AdminCell("Status", carrier.Status, "badge"),
            AdminDisplay.AdminCell("Rating", carrier.Rating),
            AdminDisplay.AdminCell("Served cities", carrier.CityName),
            AdminDisplay.AdminCell("Assigned shipments", "-"),
            AdminDisplay.AdminCell("Active trips", "-")
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
