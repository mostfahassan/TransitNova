@model UiCarrierShipmentListDto?
@{
    ViewData["Title"] = "Carrier shipments";
    var shipments = Model?.Shipments ?? UiPagedResult<UiRetrieveShipmentDto>.From([], 0, 1, 10);
    var header = new AdminPageHeaderViewModel
    {
        Title = "Carrier shipments",
        Description = "Review shipments currently associated with the selected carrier.",
        PrimaryLabel = null,
        PrimaryController = "Shipments",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Carrier shipment ledger",
        Subtitle = "Shipment rows filtered through the carrier administration endpoint.",
        Controller = "Shipments",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["Shipment", "Pickup", "Delivery", "Status", "Mode", "Cost", "Created"],
        Rows = shipments.Data.Select(shipment => AdminDisplay.AdminRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.AdminCell("Shipment", shipment.TrackingNumber, "id"),
            AdminDisplay.AdminCell("Pickup", shipment.PickupAddress),
            AdminDisplay.AdminCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.AdminCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.AdminCell("Mode", shipment.TransportationMode, "badge"),
            AdminDisplay.AdminCell("Cost", shipment.ShippingCost, "currency"),
            AdminDisplay.AdminCell("Created", shipment.CreatedAt))).ToList(),
        TotalCount = shipments.TotalCount,
        PageNumber = shipments.PageNumber,
        TotalPages = shipments.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
