@model object?
@{
    ViewData["Title"] = "Carriers";
    var header = new AdminPageHeaderViewModel
    {
        Title = "Carriers",
        Description = "Monitor carrier readiness, rating, service zones, and shipment load.",
        PrimaryLabel = null,
        PrimaryController = "Carriers",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Carrier network",
        Subtitle = "Carrier partners registered in the logistics network.",
        Source = Model,
        Controller = "Carriers",
        RouteIdName = "carrierId",
        IdPropertyPath = "Id|CarrierId",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = true,
        Columns = new List<AdminTableColumnViewModel>
        {
            new("Carrier", "FullName|Name"),
            new("Code", "Code", "id"),
            new("Status", "Status", "badge"),
            new("Rating", "Rating"),
            new("Assigned", "AssignedShipmentsCount"),
            new("Trips", "ActiveTripsCount"),
            new("Cities", "ServedCities")
        }
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
