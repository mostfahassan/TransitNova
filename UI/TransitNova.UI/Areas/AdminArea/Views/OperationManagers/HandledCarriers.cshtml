@model UiPagedResult<UiCarrierSummaryDetailsDto>?
@{
    ViewData["Title"] = "Handled carriers";
    var page = Model ?? UiPagedResult<UiCarrierSummaryDetailsDto>.From([], 0, 1, 10);
    var header = new AdminPageHeaderViewModel
    {
        Title = "Handled carriers",
        Description = "Carriers currently handled by the selected operation manager.",
        PrimaryLabel = null,
        PrimaryController = "OperationManagers",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Handled carrier ledger",
        Subtitle = "Paginated carrier assignments returned by the backend.",
        Controller = "OperationManagers",
        ShowDetails = false,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["Carrier", "Code", "Status", "Rating", "Assigned", "Trips"],
        Rows = page.Data.Select(carrier => AdminDisplay.AdminRow(
            "carrierId",
            carrier.Id,
            AdminDisplay.AdminCell("Carrier", carrier.FullName),
            AdminDisplay.AdminCell("Code", carrier.Code, "id"),
            AdminDisplay.AdminCell("Status", carrier.Status, "badge"),
            AdminDisplay.AdminCell("Rating", carrier.Rating),
            AdminDisplay.AdminCell("Assigned", carrier.AssignedShipmentsCount),
            AdminDisplay.AdminCell("Trips", carrier.ActiveTripsCount))).ToList(),
        TotalCount = page.TotalCount,
        PageNumber = page.PageNumber,
        TotalPages = page.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
