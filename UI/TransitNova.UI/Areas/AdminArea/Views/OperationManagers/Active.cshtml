@model IEnumerable<UiOperationManagerProfileDto>?
@{
    ViewData["Title"] = "Active operation managers";
    var items = (Model ?? Enumerable.Empty<UiOperationManagerProfileDto>()).ToList();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Active operation managers",
        Description = "Operational managers currently available for assignment and review.",
        PrimaryLabel = null,
        PrimaryController = "OperationManagers",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Active managers",
        Subtitle = "Managers marked active by the backend.",
        Controller = "OperationManagers",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["Manager", "Email", "Phone", "Active", "Handled carriers", "Handled shipments"],
        Rows = items.Select(manager => AdminDisplay.AdminRow(
            "operationManagerId",
            manager.Id,
            AdminDisplay.AdminCell("Manager", manager.FullName),
            AdminDisplay.AdminCell("Email", manager.Email),
            AdminDisplay.AdminCell("Phone", manager.PhoneNumber),
            AdminDisplay.AdminCell("Active", "-", "badge"),
            AdminDisplay.AdminCell("Handled carriers", manager.TotalCarriertHandled),
            AdminDisplay.AdminCell("Handled shipments", manager.TotalShipmentHandled))).ToList(),
        TotalCount = items.Count,
        PageNumber = 1,
        TotalPages = 1
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
