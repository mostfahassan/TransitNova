@model UiOperationManagerProfileDto?
@{
    ViewData["Title"] = "Operation manager details";
    var manager = Model ?? new UiOperationManagerProfileDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Operation manager details",
        Description = "Inspect manager contact data and workload signals.",
        SecondaryLabel = "Back",
        SecondaryController = "OperationManagers",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Operation manager record",
        Subtitle = "Profile and performance details for the selected operation manager.",
        PrimaryLabel = manager.FullName,
        Controller = "OperationManagers",
        EditAction = null,
        DeleteAction = null,
        RouteValues = new Dictionary<string, object?> { ["operationManagerId"] = manager.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Manager", manager.FullName),
            AdminDisplay.AdminCell("Email", manager.Email),
            AdminDisplay.AdminCell("Phone", manager.PhoneNumber),
            AdminDisplay.AdminCell("Active", "-", "badge"),
            AdminDisplay.AdminCell("City", manager.CityName),
            AdminDisplay.AdminCell("Address", manager.Address),
            AdminDisplay.AdminCell("Handled carriers", manager.TotalCarriertHandled),
            AdminDisplay.AdminCell("Handled shipments", manager.TotalShipmentHandled)
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
