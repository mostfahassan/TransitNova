@model UiPagedResult<UiRetrieveShipmentSummaryDto>?
@{
    ViewData["Title"] = "Handled shipments";
    var page = Model ?? UiPagedResult<UiRetrieveShipmentSummaryDto>.From([], 0, 1, 10);
    var header = new AdminPageHeaderViewModel
    {
        Title = "Handled shipments",
        Description = "Shipments currently reviewed or handled by the selected operation manager.",
        PrimaryLabel = null,
        PrimaryController = "Shipments",
        PrimaryAction = null
    };
    var table = new AdminTableViewModel
    {
        Title = "Handled shipment ledger",
        Subtitle = "Paginated shipment workload returned by the backend.",
        Controller = "Shipments",
        ShowDetails = true,
        ShowEdit = false,
        ShowDelete = false,
        Headers = ["Shipment", "Pickup", "Delivery", "Status", "Mode", "Created"],
        Rows = page.Data.Select(shipment => AdminDisplay.AdminRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.AdminCell("Shipment", shipment.TrackingNumber, "id"),
            AdminDisplay.AdminCell("Pickup", shipment.SenderCity),
            AdminDisplay.AdminCell("Delivery", shipment.ReceiverCity),
            AdminDisplay.AdminCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.AdminCell("Mode", shipment.ShipmentType, "badge"),
            AdminDisplay.AdminCell("Created", shipment.CreatedAt))).ToList(),
        TotalCount = page.TotalCount,
        PageNumber = page.PageNumber,
        TotalPages = page.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
