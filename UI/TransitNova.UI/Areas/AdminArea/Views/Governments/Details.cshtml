@model UiGovernmentDto?
@{
    ViewData["Title"] = "Government details";
    var government = Model ?? new UiGovernmentDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Government details",
        Description = "Inspect government data and country linkage.",
        SecondaryLabel = "Back",
        SecondaryController = "Governments",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "Government record",
        Subtitle = "Regional metadata used by location workflows.",
        PrimaryLabel = government.Name,
        Controller = "Governments",
        EditAction = "Edit",
        DeleteAction = "Delete",
        RouteValues = new Dictionary<string, object?> { ["governmentId"] = government.Id },
        Fields =
        [
            AdminDisplay.AdminCell("Government", government.Name),
            AdminDisplay.AdminCell("Country", government.CountryName),
            AdminDisplay.AdminCell("Country ID", government.CountryId, "id"),
            AdminDisplay.AdminCell("Government ID", government.Id, "id")
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
