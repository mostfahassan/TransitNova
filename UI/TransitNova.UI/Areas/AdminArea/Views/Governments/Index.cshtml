@model IEnumerable<UiGovernmentDto>?
@{
    ViewData["Title"] = "Governments";
    var items = (Model ?? Enumerable.Empty<UiGovernmentDto>()).ToList();
    var header = new AdminPageHeaderViewModel
    {
        Title = "Governments",
        Description = "Maintain regional government data for country and city relationships.",
        PrimaryLabel = "Create government",
        PrimaryController = "Governments",
        PrimaryAction = "Create"
    };
    var table = new AdminTableViewModel
    {
        Title = "Government registry",
        Subtitle = "Administrative regions available for city mapping.",
        Controller = "Governments",
        ShowDetails = true,
        ShowEdit = true,
        ShowDelete = true,
        Headers = ["Government", "Country", "Country ID"],
        Rows = items.Select(government => AdminDisplay.AdminRow(
            "governmentId",
            government.Id,
            AdminDisplay.AdminCell("Government", government.Name),
            AdminDisplay.AdminCell("Country", government.CountryName),
            AdminDisplay.AdminCell("Country ID", government.CountryId, "id"))).ToList(),
        TotalCount = items.Count,
        PageNumber = 1,
        TotalPages = 1
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
