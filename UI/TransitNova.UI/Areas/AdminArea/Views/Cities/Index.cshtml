@model UiPagedResult<UiCityDto>?
@{
    ViewData["Title"] = "Cities";
    var page = Model ?? UiPagedResult<UiCityDto>.From([], 0, 1, 10);
    var header = new AdminPageHeaderViewModel
    {
        Title = "Cities",
        Description = "Review and maintain city-level routing data used by address capture and carrier zones.",
        PrimaryLabel = "Create city",
        PrimaryController = "Cities",
        PrimaryAction = "Create"
    };
    var table = new AdminTableViewModel
    {
        Title = "City registry",
        Subtitle = "Cities returned from the backend filter endpoint.",
        Controller = "Cities",
        ShowDetails = true,
        ShowEdit = true,
        ShowDelete = true,
        Headers = ["City", "Government", "Government ID"],
        Rows = page.Data.Select(city => AdminDisplay.AdminRow(
            "cityId",
            city.Id,
            AdminDisplay.AdminCell("City", city.Name),
            AdminDisplay.AdminCell("Government", city.GovernmentName),
            AdminDisplay.AdminCell("Government ID", city.GovernmentId, "id"))).ToList(),
        TotalCount = page.TotalCount,
        PageNumber = page.PageNumber,
        TotalPages = page.TotalPages
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminTable" model="table" />
