@model CityFormViewModel
@{
    ViewData["Title"] = ViewContext.RouteData.Values["action"]?.ToString() == "Edit" ? "Edit City" : "Create City";
    var header = new AdminPageHeaderViewModel
    {
        Title = ViewData["Title"]?.ToString() ?? "Create City",
        Description = "Attach cities to governments so pickup and delivery addresses map cleanly to operational zones.",
        SecondaryLabel = "Back to cities",
        SecondaryController = "Cities",
        SecondaryAction = "Index"
    };
}
<partial name="_AdminPageHeader" model="header" />
<form method="post" class="admin-card p-6">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="mb-5 rounded-xl border border-[#F5D4D4] bg-[#FDEBEC] p-4 text-sm text-[#9F2F2D]"></div>
    <div class="grid gap-5 lg:grid-cols-2">
        <div><label asp-for="Name" class="admin-label"></label><input asp-for="Name" class="admin-input" placeholder="Alexandria" /><span asp-validation-for="Name" class="admin-validation"></span></div>
        <div><label asp-for="GovernmentId" class="admin-label"></label><input asp-for="GovernmentId" class="admin-input" placeholder="2" /><span asp-validation-for="GovernmentId" class="admin-validation"></span></div>
    </div>
    <div class="mt-6 flex justify-end gap-3"><a asp-action="Index" class="admin-button-secondary">Cancel</a><button type="submit" class="admin-button">Save city</button></div>
</form>
