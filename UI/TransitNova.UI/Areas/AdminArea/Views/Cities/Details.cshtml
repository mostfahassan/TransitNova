@model UiCityDto?
@{
    ViewData["Title"] = "City details";
    var city = Model ?? new UiCityDto();
    var header = new AdminPageHeaderViewModel
    {
        Title = "City details",
        Description = "Inspect the city record and its government mapping.",
        SecondaryLabel = "Back",
        SecondaryController = "Cities",
        SecondaryAction = "Index"
    };
    var detail = new AdminDetailViewModel
    {
        Title = "City record",
        Subtitle = "Location metadata used across shipment addresses.",
        PrimaryLabel = city.Name,
        Controller = "Cities",
        EditAction = "Edit",
        DeleteAction = "Delete",
        RouteValues = new Dictionary<string, object?> { ["cityId"] = city.Id },
        Fields =
        [
            AdminDisplay.AdminCell("City", city.Name),
            AdminDisplay.AdminCell("Government", city.GovernmentName),
            AdminDisplay.AdminCell("Government ID", city.GovernmentId, "id"),
            AdminDisplay.AdminCell("City ID", city.Id, "id")
        ]
    };
}

<partial name="_AdminPageHeader" model="header" />
<partial name="_AdminDetail" model="detail" />
