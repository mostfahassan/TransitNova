@model RateCalculatorViewModel
@{
    ViewData["Title"] = "Rate Calculator";
    var calculatedRate = ViewData["CalculatedRate"] as decimal?;
}

<section class="customer-fade-up grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
    <div>
        <div class="customer-badge customer-badge-info">Pricing estimate</div>
        <h1 class="mt-5 text-4xl font-black leading-[1.03] tracking-[-0.04em] text-[#111111] md:text-6xl">Know the cost before you ship.</h1>
        <p class="mt-5 max-w-xl text-base leading-7 text-[#666666]">Estimate package pricing from dimensions, weight, delivery type, and transport mode.</p>
        <div class="mt-8 customer-card-flat p-5">
            <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Estimate quality</div>
            <div class="mt-4 grid gap-3 text-sm font-semibold text-[#2F3437]">
                <div class="flex items-center justify-between"><span>Base handling</span><span>Included</span></div>
                <div class="flex items-center justify-between"><span>Dimensional weight</span><span>Checked live</span></div>
                <div class="flex items-center justify-between"><span>Delivery window</span><span>Mode based</span></div>
            </div>
        </div>
    </div>

    <div class="customer-card p-6 md:p-8">
        <form asp-area="UserArea" asp-controller="Pricing" asp-action="RateCalculator" method="post" class="space-y-6" data-loading-form data-loading-text="Calculating...">
            @Html.AntiForgeryToken()
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label class="customer-label" asp-for="PackageSpecification.Weight">Weight kg</label>
                    <input class="customer-input" asp-for="PackageSpecification.Weight" type="number" step="0.01" min="0.01" placeholder="2.40" />
                    <span class="customer-field-error is-visible" asp-validation-for="PackageSpecification.Weight"></span>
                </div>
                <div>
                    <label class="customer-label" asp-for="TransportationMode">Mode</label>
                    <select class="customer-select" asp-for="TransportationMode">
                        <option value="Land">Land</option>
                        <option value="Air">Air</option>
                        <option value="Sea">Sea</option>
                    </select>
                </div>
                <div>
                    <label class="customer-label" asp-for="PackageSpecification.Width">Width cm</label>
                    <input class="customer-input" asp-for="PackageSpecification.Width" type="number" step="0.01" min="0.01" placeholder="34" />
                </div>
                <div>
                    <label class="customer-label" asp-for="PackageSpecification.Height">Height cm</label>
                    <input class="customer-input" asp-for="PackageSpecification.Height" type="number" step="0.01" min="0.01" placeholder="12" />
                </div>
                <div>
                    <label class="customer-label" asp-for="PackageSpecification.Length">Length cm</label>
                    <input class="customer-input" asp-for="PackageSpecification.Length" type="number" step="0.01" min="0.01" placeholder="44" />
                </div>
                <div>
                    <label class="customer-label" asp-for="ShipmentDeliveryType">Delivery type</label>
                    <select class="customer-select" asp-for="ShipmentDeliveryType">
                        <option value="Standard">Standard</option>
                        <option value="Express">Express</option>
                        <option value="Fragile">Fragile</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="customer-button min-h-[48px] w-full">
                <span class="customer-spinner hidden" data-button-spinner></span>
                <span data-button-text>Calculate Rate</span>
            </button>
        </form>

        <div class="mt-6 rounded-[18px] border border-[#EAEAEA] bg-[#FBFBFA] p-6">
            <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Estimated total</div>
            <div class="mt-3 text-5xl font-black tracking-[-0.05em] text-[#111111]">@(calculatedRate.HasValue ? calculatedRate.Value.ToString("N2") : "--")</div>
            <p class="mt-2 text-sm leading-6 text-[#666666]">EGP estimate before final carrier assignment and payment confirmation.</p>
        </div>
    </div>
</section>