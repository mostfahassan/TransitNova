@model object?
@{
    ViewData["Title"] = "Profile";
}

<section class="customer-fade-up">
    <div class="customer-card overflow-hidden">
        <div class="grid gap-0 lg:grid-cols-[360px_1fr]">
            <aside class="border-b border-[#EAEAEA] bg-[#FBFBFA] p-8 lg:border-b-0 lg:border-r">
                <div class="grid h-20 w-20 place-items-center rounded-[24px] bg-[#111111] text-2xl font-black text-white">CU</div>
                <h1 class="mt-6 text-4xl font-black tracking-[-0.04em] text-[#111111]">@AdminDisplay.Text(Model, "FullName|Name|FirstName|UserName", "text")</h1>
                <p class="mt-3 text-sm leading-6 text-[#666666]">@AdminDisplay.Text(Model, "Email")</p>
                <div class="mt-6 customer-badge customer-badge-success">Verified customer</div>
            </aside>

            <div class="p-8">
                <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                    <div>
                        <h2 class="text-2xl font-black tracking-[-0.03em] text-[#111111]">Account overview</h2>
                        <p class="mt-2 text-sm leading-6 text-[#666666]">Customer profile data currently coming from the backend contract.</p>
                    </div>
                    <a asp-area="AccountArea" asp-controller="Account" asp-action="ChangePassword" class="customer-button-secondary">Change password</a>
                </div>

                <dl class="mt-8 grid gap-4 md:grid-cols-2">
                    <div class="customer-card-flat p-5">
                        <dt class="customer-label">Full name</dt>
                        <dd class="text-lg font-black tracking-[-0.02em] text-[#111111]">@AdminDisplay.Text(Model, "FullName|Name|UserName")</dd>
                    </div>
                   
                    <div class="customer-card-flat p-5">
                        <dt class="customer-label">Phone</dt>
                        <dd class="text-lg font-black tracking-[-0.02em] text-[#111111]">@AdminDisplay.Text(Model, "PhoneNumber|Phone")</dd>
                    </div>
                    <div class="customer-card-flat p-5">
                        <dt class="customer-label">City</dt>
                        <dd class="text-lg font-black tracking-[-0.02em] text-[#111111]">@AdminDisplay.Text(Model, "City|CityName|CityId")</dd>
                    </div>
                    <div class="customer-card-flat p-5 md:col-span-2">
                        <dt class="customer-label">Address</dt>
                        <dd class="text-lg font-black tracking-[-0.02em] text-[#111111]">@AdminDisplay.Text(Model, "Address")</dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
</section>
