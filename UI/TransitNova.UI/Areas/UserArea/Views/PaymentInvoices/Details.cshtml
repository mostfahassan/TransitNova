@model UserPaymentInvoiceDetailsViewModel
@{
    ViewData["Title"] = "Invoice Details";
    var invoice = Model.Invoice;
}

<section class="customer-fade-up">
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div>
            <div class="@BadgeClass(invoice.Status.ToString())">@invoice.Status</div>
            <h1 class="mt-5 text-4xl font-black leading-[1.02] tracking-[-0.04em] text-[#111111] md:text-6xl">@(invoice.InvoiceId ?? ShortId(invoice.PaymentId))</h1>
            <p class="mt-4 max-w-2xl text-base leading-7 text-[#666666]">A customer-facing invoice record with payment reference, shipment reference, cost breakdown, and report-ready totals.</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <a asp-area="UserArea" asp-controller="PaymentInvoices" asp-action="Index" class="customer-button-secondary">All invoices</a>
            <a asp-area="UserArea" asp-controller="Shipments" asp-action="Details" asp-route-shipmentId="@invoice.ShipmentId" class="customer-button">Shipment details</a>
        </div>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-[1fr_380px]">
        <section class="customer-card overflow-hidden">
            <div class="border-b border-[#EAEAEA] p-6 md:p-8">
                <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">INVOICE / PAYMENT BREAKDOWN</div>
                <h2 class="mt-3 text-2xl font-black tracking-[-0.03em] text-[#111111]">Cost structure</h2>
                <p class="mt-2 text-sm leading-6 text-[#666666]">The values below are returned from the backend invoice contract and stay stable for report generation.</p>
            </div>

            <div class="grid gap-0 md:grid-cols-2">
                @InfoTile("Shipping cost", FormatMoney(invoice.ShippingCost), invoice.Currency.ToString(), "00")
                @InfoTile("Commission", FormatMoney(invoice.Commission), invoice.Currency.ToString(), "01")
                @InfoTile("Payment method", invoice.PaymentMethod.ToString(), "METHOD", "02")
                @InfoTile("Paid at", FormatDate(invoice.PaidAt), "UTC", "03")
            </div>

            <div class="border-t border-[#EAEAEA] bg-[#FBFBFA] p-6 md:p-8">
                <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                    <div>
                        <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">TOTAL DUE</div>
                        <div class="mt-2 text-5xl font-black tracking-[-0.05em] text-[#111111]">@FormatMoney(invoice.TotalAmount)</div>
                    </div>
                    <div class="text-right">
                        <div class="text-sm font-black text-[#111111]">@invoice.Currency</div>
                        <div class="mt-1 text-xs font-bold uppercase tracking-[0.12em] text-[#787774]">settlement currency</div>
                    </div>
                </div>
            </div>
        </section>

        <aside class="space-y-5">
            <section class="customer-card-flat p-6">
                <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Customer</div>
                <p class="mt-4 text-xl font-black tracking-[-0.02em] text-[#111111]">@CustomerLabel(invoice.CustomerName)</p>
                <p class="mt-2 text-sm leading-6 text-[#666666]">This invoice is currently linked to the customer account returned by the backend response.</p>
            </section>

            <section class="customer-card-flat p-6">
                <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">References</div>
                <dl class="mt-5 space-y-4 text-sm">
                    <div class="border-b border-[#EAEAEA] pb-3"><dt class="font-bold text-[#666666]">Payment ID</dt><dd class="mt-1 break-all font-black text-[#111111]">@invoice.PaymentId</dd></div>
                    <div class="border-b border-[#EAEAEA] pb-3">
                        <dt class="font-bold text-[#666666]">Shipment</dt>
                        <dd class="mt-1">
                            <a asp-area="UserArea" asp-controller="Shipments" asp-action="Details" asp-route-shipmentId="@invoice.ShipmentId" class="font-mono text-xs font-black uppercase tracking-[0.08em] text-[#111111] transition-colors hover:text-[#666666]">
                                @ShipmentReference(invoice.ShipmentTrackingNumber, invoice.ShipmentId)
                            </a>
                            <span class="mt-2 block break-all text-xs font-bold text-[#787774]">@invoice.ShipmentId</span>
                        </dd>
                    </div>
                    <div><dt class="font-bold text-[#666666]">Invoice ID</dt><dd class="mt-1 font-black text-[#111111]">@(invoice.InvoiceId ?? "Not assigned")</dd></div>
                </dl>
            </section>

            <section class="customer-card-flat p-6">
                <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Notes</div>
                <p class="mt-4 text-sm leading-6 text-[#666666]">@(string.IsNullOrWhiteSpace(invoice.Notes) ? "No additional notes were returned for this payment invoice." : invoice.Notes)</p>
            </section>
        </aside>
    </div>
</section>

@functions {
    private static string ShortId(Guid id) => id == Guid.Empty ? "-" : id.ToString()[..8].ToUpperInvariant();
    private static string ShipmentReference(string? trackingNumber, Guid shipmentId) => string.IsNullOrWhiteSpace(trackingNumber) ? ShortId(shipmentId) : trackingNumber;
    private static string CustomerLabel(string? customerName) => string.IsNullOrWhiteSpace(customerName) ? "Customer account" : customerName;
    private static string FormatMoney(decimal value) => value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);
    private static string FormatDate(DateTime? value) => value is null ? "Pending confirmation" : value.Value.ToString("MMM dd, yyyy HH:mm", System.Globalization.CultureInfo.InvariantCulture);

    private IHtmlContent InfoTile(string label, string value, string meta, string index)
    {
        return new HtmlString($"<div class='border-b border-[#EAEAEA] p-6 md:border-r'><div class='font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]'>[{index}] {label}</div><div class='mt-3 text-2xl font-black tracking-[-0.03em] text-[#111111]'>{System.Net.WebUtility.HtmlEncode(value)}</div><div class='mt-2 text-xs font-bold uppercase tracking-[0.12em] text-[#787774]'>{System.Net.WebUtility.HtmlEncode(meta)}</div></div>");
    }

    private static string BadgeClass(string value)
    {
        var text = value.ToLowerInvariant();
        if (text.Contains("success") || text.Contains("paid")) return "customer-badge customer-badge-success";
        if (text.Contains("pending")) return "customer-badge customer-badge-warning";
        if (text.Contains("fail") || text.Contains("declin")) return "customer-badge customer-badge-danger";
        return "customer-badge customer-badge-neutral";
    }
}
