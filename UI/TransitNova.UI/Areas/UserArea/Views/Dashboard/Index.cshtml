@model UserDashboardPageViewModel
@{
    ViewData["Title"] = "Dashboard";
    var dashboard = Model.Dashboard;
    var rows = AdminDisplay.Rows(AdminDisplay.Value(dashboard, "ShipmentSummary|RecentShipments|Shipments"));
    var invoices = Model.RecentInvoices.OrderByDescending(invoice => invoice.PaidAt ?? DateTime.MinValue).ToArray();
    var bundles = Model.AvailableBundles.OrderBy(bundle => bundle.BundlePrice).ToArray();
    string Metric(string path) => AdminDisplay.Text(dashboard, path) == "-" ? "0" : AdminDisplay.Text(dashboard, path);
}

<section class="customer-fade-up grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-stretch">
    <div class="customer-card p-8 md:p-10">
        <div class="customer-badge customer-badge-info">Customer workspace</div>
        <h1 class="mt-6 max-w-3xl text-4xl font-black leading-[1.02] tracking-[-0.04em] text-[#111111] md:text-6xl">Ship, track, pay, and audit deliveries without friction.</h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-[#666666]">Create shipments, check live progress, estimate pricing, and keep every invoice connected to the shipment that produced it.</p>

        <form asp-area="UserArea" asp-controller="Shipments" asp-action="TrackSubmit" method="post" class="mt-8 flex flex-col gap-3 rounded-[18px] border border-[#EAEAEA] bg-[#FBFBFA] p-3 sm:flex-row" data-loading-form data-loading-text="Tracking...">
            @Html.AntiForgeryToken()
            <input name="trackingNumber" class="customer-input min-h-[56px] flex-1 !border-transparent !bg-white text-lg font-bold tracking-[-0.01em]" placeholder="Enter tracking number" aria-label="Tracking number" />
            <button type="submit" class="customer-button min-h-[56px] px-6">
                <span class="customer-spinner hidden" data-button-spinner></span>
                <span data-button-text>Quick Track</span>
            </button>
        </form>
    </div>

    <a asp-area="UserArea" asp-controller="Shipments" asp-action="Create" class="customer-card customer-lift relative overflow-hidden p-8 md:p-10">
        <div class="absolute right-8 top-8 grid h-14 w-14 place-items-center rounded-[16px] border border-[#EAEAEA] bg-[#FBFBFA]">
            <svg class="h-6 w-6 text-[#111111]" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 8.5 12 4l7 4.5v7L12 20l-7-4.5v-7Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="m5.5 9 6.5 4 6.5-4M12 13v6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </div>
        <div class="customer-badge customer-badge-success">Fast action</div>
        <h2 class="mt-16 text-3xl font-black tracking-[-0.03em] text-[#111111]">Create new shipment</h2>
        <p class="mt-4 text-sm leading-6 text-[#666666]">A guided, one-page flow for receiver details, package dimensions, payment, and invoice generation.</p>
        <span class="customer-button mt-8 w-full">Start shipment</span>
    </a>
</section>

<section class="customer-stagger mt-8 grid gap-4 md:grid-cols-4">
    <div class="customer-card-flat p-6" style="--item-index:0">
        <div class="text-sm font-bold text-[#666666]">In Transit</div>
        <div class="mt-3 text-4xl font-black tracking-[-0.04em] text-[#111111]">@Metric("ActiveShipments")</div>
        <p class="mt-2 text-sm leading-6 text-[#787774]">Moving through pickup, warehouse, or final-mile delivery.</p>
    </div>
    <div class="customer-card-flat p-6" style="--item-index:1">
        <div class="text-sm font-bold text-[#666666]">Delivered</div>
        <div class="mt-3 text-4xl font-black tracking-[-0.04em] text-[#111111]">@Metric("DeliveredShipments")</div>
        <p class="mt-2 text-sm leading-6 text-[#787774]">Completed deliveries across your account.</p>
    </div>
    <div class="customer-card-flat p-6" style="--item-index:2">
        <div class="text-sm font-bold text-[#666666]">Open Issues</div>
        <div class="mt-3 text-4xl font-black tracking-[-0.04em] text-[#111111]">@Metric("IssueShipments")</div>
        <p class="mt-2 text-sm leading-6 text-[#787774]">Shipments currently flagged for support.</p>
    </div>
    <a asp-area="UserArea" asp-controller="PaymentInvoices" asp-action="Index" class="customer-card-flat customer-lift p-6" style="--item-index:3">
        <div class="text-sm font-bold text-[#666666]">Invoices</div>
        <div class="mt-3 text-4xl font-black tracking-[-0.04em] text-[#111111]">@Model.TotalInvoices</div>
        <p class="mt-2 text-sm leading-6 text-[#787774]">Payment receipts ready for review and reports.</p>
    </a>
</section>

<section class="customer-card mt-8 overflow-hidden">
    <div class="flex flex-col gap-3 border-b border-[#EAEAEA] p-6 md:flex-row md:items-center md:justify-between">
        <div>
            <div class="customer-badge customer-badge-info">Plans</div>
            <h2 class="mt-4 text-2xl font-black tracking-[-0.03em] text-[#111111]">Available bundles</h2>
            <p class="mt-2 text-sm leading-6 text-[#666666]">Choose an operational bundle that matches your monthly shipping rhythm.</p>
        </div>
        <a asp-area="UserArea" asp-controller="Pricing" asp-action="RateCalculator" class="customer-button-secondary">Estimate shipment cost</a>
    </div>

    @if (bundles.Length == 0)
    {
        <div class="p-8 text-center">
            <div class="mx-auto grid h-14 w-14 place-items-center rounded-[18px] border border-[#EAEAEA] bg-[#FBFBFA]">
                <svg class="h-6 w-6 text-[#111111]" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 8.5 12 4l7 4.5v7L12 20l-7-4.5v-7Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="m5.5 9 6.5 4 6.5-4M12 13v6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
            <h3 class="mt-5 text-xl font-black tracking-[-0.02em] text-[#111111]">No bundles are available yet.</h3>
            <p class="mt-2 text-sm leading-6 text-[#666666]">When the catalog is published, the plans will appear here automatically.</p>
        </div>
    }
    else
    {
        <div class="customer-stagger grid gap-4 p-6 md:grid-cols-2 xl:grid-cols-3">
            @for (var index = 0; index < bundles.Length; index++)
            {
                var bundle = bundles[index];
                <article class="customer-card customer-lift flex h-full flex-col p-6" style="--item-index:@index">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <span class="@TierBadgeClass(bundle.Tier.ToString())">@bundle.Tier</span>
                            <h3 class="mt-4 text-2xl font-black tracking-[-0.03em] text-[#111111]">@bundle.BundleName</h3>
                            <p class="mt-3 text-sm leading-6 text-[#666666]">@bundle.BundleDescription</p>
                        </div>
                        <div class="shrink-0 text-right">
                            <div class="text-3xl font-black tracking-[-0.04em] text-[#111111]">@FormatMoney(bundle.BundlePrice)</div>
                            <div class="mt-1 text-xs font-bold uppercase tracking-[0.14em] text-[#787774]">@bundle.BundleDurationMonths months</div>
                        </div>
                    </div>

                    <dl class="mt-6 grid gap-3 text-sm">
                        <div class="flex justify-between gap-4 border-b border-[#EFEFED] pb-3">
                            <dt class="font-bold text-[#666666]">Max shipments</dt>
                            <dd class="text-right font-black text-[#111111]">@bundle.MaxShipmentsPerMonth / month</dd>
                        </div>
                        <div class="flex justify-between gap-4 border-b border-[#EFEFED] pb-3">
                            <dt class="font-bold text-[#666666]">Max weight</dt>
                            <dd class="text-right font-black text-[#111111]">@FormatMoney(bundle.MaxWeightPerShipment) kg</dd>
                        </div>
                        <div class="flex justify-between gap-4">
                            <dt class="font-bold text-[#666666]">Max distance</dt>
                            <dd class="text-right font-black text-[#111111]">@FormatMoney(bundle.MaxDistancePerShipment) km</dd>
                        </div>
                    </dl>

                    <div class="mt-auto pt-6">
                        <a asp-area="UserArea" asp-controller="Subscriptions" asp-action="Checkout" asp-route-bundleId="@bundle.Id" class="customer-button w-full">
                            Subscribe
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</section>
<section class="customer-card mt-8 overflow-hidden">
    <div class="flex flex-col gap-3 border-b border-[#EAEAEA] p-6 md:flex-row md:items-center md:justify-between">
        <div>
            <h2 class="text-xl font-black tracking-[-0.02em] text-[#111111]">Recent invoices</h2>
            <p class="mt-1 text-sm leading-6 text-[#666666]">The newest payment records generated by shipment creation.</p>
        </div>
        <a asp-area="UserArea" asp-controller="PaymentInvoices" asp-action="Index" class="customer-button-secondary">View all invoices</a>
    </div>
    <div class="overflow-x-auto">
        <table class="customer-table">
            <thead>
                <tr>
                    <th>Invoice</th>
                    <th>Shipment</th>
                    <th>Status</th>
                    <th>Paid at</th>
                    <th class="text-right">Total</th>
                    <th class="text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (invoices.Length == 0)
                {
                    <tr>
                        <td colspan="6" class="py-12 text-center text-sm font-semibold text-[#787774]">No invoices have been generated yet.</td>
                    </tr>
                }
                @for (var index = 0; index < invoices.Length; index++)
                {
                    var invoice = invoices[index];
                    <tr style="--row-index:@index">
                        <td><span class="font-mono text-xs font-black uppercase tracking-[0.08em] text-[#111111]">@(invoice.InvoiceId ?? ShortId(invoice.PaymentId))</span></td>
                        <td><span class="font-mono text-xs font-bold text-[#666666]">@ShortId(invoice.ShipmentId)</span></td>
                        <td><span class="@BadgeClass(invoice.Status.ToString())">@invoice.Status</span></td>
                        <td>@FormatDate(invoice.PaidAt)</td>
                        <td class="text-right font-black text-[#111111]">@FormatMoney(invoice.TotalAmount) @invoice.Currency</td>
                        <td class="text-right"><a asp-area="UserArea" asp-controller="PaymentInvoices" asp-action="Details" asp-route-paymentId="@invoice.PaymentId" class="customer-button-secondary !px-3 !py-2">Details</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section class="customer-card mt-8 overflow-hidden">
    <div class="flex flex-col gap-3 border-b border-[#EAEAEA] p-6 md:flex-row md:items-center md:justify-between">
        <div>
            <h2 class="text-xl font-black tracking-[-0.02em] text-[#111111]">Recent shipments</h2>
            <p class="mt-1 text-sm leading-6 text-[#666666]">High-signal shipment rows with customer-facing status.</p>
        </div>
        <a asp-area="UserArea" asp-controller="Shipments" asp-action="Track" class="customer-button-secondary">Open tracker</a>
    </div>
    <div class="overflow-x-auto">
        <table class="customer-table">
            <thead>
                <tr>
                    <th>Tracking</th>
                    <th>Package</th>
                    <th>Route</th>
                    <th>Status</th>
                    <th>Updated</th>
                    <th class="text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (rows.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="py-12 text-center text-sm font-semibold text-[#787774]">No shipments have been returned from the database yet.</td>
                    </tr>
                }
                @for (var index = 0; index < rows.Count; index++)
                {
                    var row = rows[index];
                    var tracking = AdminDisplay.Text(row, "TrackingNumber|Code", "id");
                    var status = AdminDisplay.Text(row, "Status|CurrentStatus");
                    <tr style="--row-index:@index">
                        <td><span class="font-mono text-xs font-black uppercase tracking-[0.08em] text-[#111111]">@tracking</span></td>
                        <td>@AdminDisplay.Text(row, "Product|ShipmentType|PackageSpecification")</td>
                        <td>@AdminDisplay.Text(row, "Route|DeliveryAddress|ReceiverCity")</td>
                        <td><span class="@BadgeClass(status)">@status</span></td>
                        <td>@AdminDisplay.Text(row, "Updated|UpdatedAt|CreatedAt")</td>
                        <td class="text-right"><a asp-area="UserArea" asp-controller="Shipments" asp-action="TrackResult" asp-route-trackingNumber="@tracking" class="customer-button-secondary !px-3 !py-2">Track</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@functions {
    private static string ShortId(Guid id) => id == Guid.Empty ? "-" : id.ToString()[..8].ToUpperInvariant();
    private static string FormatMoney(decimal value) => value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture);
    private static string FormatDate(DateTime? value) => value is null ? "Pending" : value.Value.ToString("MMM dd, yyyy HH:mm", System.Globalization.CultureInfo.InvariantCulture);
    private static string TierBadgeClass(string value)
    {
        var text = value.ToLowerInvariant();
        if (text.Contains("premium") || text.Contains("enterprise")) return "customer-badge customer-badge-info";
        if (text.Contains("pro") || text.Contains("business")) return "customer-badge customer-badge-success";
        if (text.Contains("basic") || text.Contains("starter")) return "customer-badge customer-badge-warning";
        return "customer-badge customer-badge-neutral";
    }
private static string BadgeClass(string value)
    {
        var text = value.ToLowerInvariant();
        if (text.Contains("success") || text.Contains("paid") || text.Contains("deliver")) return "customer-badge customer-badge-success";
        if (text.Contains("transit") || text.Contains("pickup") || text.Contains("warehouse")) return "customer-badge customer-badge-info";
        if (text.Contains("pending") || text.Contains("review")) return "customer-badge customer-badge-warning";
        if (text.Contains("fail") || text.Contains("issue") || text.Contains("cancel") || text.Contains("reject")) return "customer-badge customer-badge-danger";
        return "customer-badge customer-badge-neutral";
    }
}



