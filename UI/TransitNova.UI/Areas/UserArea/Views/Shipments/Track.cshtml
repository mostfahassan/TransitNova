@{
    ViewData["Title"] = "Track Shipment";
}

<section class="customer-fade-up">
    <div class="mx-auto max-w-4xl text-center">
        <div class="customer-badge customer-badge-info justify-center">Live tracking</div>
        <h1 class="mt-6 text-5xl font-black leading-[0.98] tracking-[-0.055em] text-[#111111] md:text-7xl">Know exactly where your shipment is.</h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-7 text-[#666666]">Enter a tracking number and get a clean, customer-ready timeline from pickup to final delivery.</p>
    </div>

    <form asp-area="UserArea" asp-controller="Shipments" asp-action="TrackSubmit" method="post" class="mx-auto mt-12 max-w-4xl rounded-[28px] border border-[#EAEAEA] bg-white p-3 shadow-[0_1px_0_rgba(17,17,17,0.025),0_28px_80px_rgba(17,17,17,0.055)] md:flex md:items-center md:gap-3" data-loading-form data-loading-text="Tracking...">
        @Html.AntiForgeryToken()
        <label for="trackingNumber" class="sr-only">Tracking number</label>
        <input id="trackingNumber" name="trackingNumber" class="customer-input min-h-[72px] flex-1 !border-transparent !bg-[#FBFBFA] px-6 text-xl font-black tracking-[-0.02em] md:text-2xl" placeholder="Tracking number" autocomplete="off" />
        <button type="submit" class="customer-button mt-3 min-h-[72px] w-full px-8 text-base md:mt-0 md:w-auto">
            <span class="customer-spinner hidden" data-button-spinner></span>
            <span data-button-text>Track Package</span>
        </button>
    </form>

    <div class="customer-stagger mx-auto mt-10 grid max-w-5xl gap-4 md:grid-cols-3">
        <div class="customer-card-flat p-5" style="--item-index:0">
            <div class="font-mono text-[10px] font-black uppercase tracking-[0.16em] text-[#787774]">Source</div>
            <div class="mt-3 text-lg font-black tracking-[-0.02em] text-[#111111]">Database-backed</div>
            <p class="mt-2 text-sm leading-6 text-[#666666]">Tracking results are loaded from the shipment API.</p>
        </div>
        <div class="customer-card-flat p-5" style="--item-index:1">
            <div class="font-mono text-[10px] font-black uppercase tracking-[0.16em] text-[#787774]">Refresh</div>
            <div class="mt-3 text-lg font-black tracking-[-0.02em] text-[#111111]">Near real-time</div>
            <p class="mt-2 text-sm leading-6 text-[#666666]">Status changes are presented as a calm progress timeline.</p>
        </div>
        <div class="customer-card-flat p-5" style="--item-index:2">
            <div class="font-mono text-[10px] font-black uppercase tracking-[0.16em] text-[#787774]">Support</div>
            <div class="mt-3 text-lg font-black tracking-[-0.02em] text-[#111111]">Issue-ready</div>
            <p class="mt-2 text-sm leading-6 text-[#666666]">Open an issue directly from shipment details when needed.</p>
        </div>
    </div>
</section>
