@model CreateShipmentViewModel
@{
    ViewData["Title"] = "Create Shipment";

    var formErrors = ViewData.ModelState
        .Where(entry => entry.Value?.Errors.Count > 0)
        .SelectMany(entry => entry.Value!.Errors.Select(error => new
        {
            entry.Key,
            Message = string.IsNullOrWhiteSpace(error.ErrorMessage) ? "Invalid value." : error.ErrorMessage
        }))
        .ToArray();
    var serverMessages = formErrors.Select(error => error.Message).Distinct(StringComparer.Ordinal).ToArray();
    var hasFieldErrors = formErrors.Any(error => !string.IsNullOrWhiteSpace(error.Key));
    var serverAlertTitle = hasFieldErrors ? "Please review the highlighted fields" : "Payment couldn't be completed";
}

<section class="customer-fade-up">
    <div class="mx-auto max-w-3xl text-center">
        <div class="customer-badge customer-badge-info justify-center">New shipment</div>
        <h1 class="mt-5 text-4xl font-black leading-[1.03] tracking-[-0.04em] text-[#111111] md:text-6xl">A calmer way to create a shipment.</h1>
        <p class="mt-5 text-base leading-7 text-[#666666]">Receiver, route, package, and delivery preferences are kept on one page with instant checks before you submit.</p>
    </div>

    <form asp-area="UserArea" asp-controller="Shipments" asp-action="Create" method="post" class="mx-auto mt-10 max-w-5xl space-y-6" data-customer-create-form data-governments-url="@Url.Action("Governments", "Shipments", new { area = "UserArea" })" data-cities-url="@Url.Action("Cities", "Shipments", new { area = "UserArea" })">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PaymentId" />
        <input type="hidden" asp-for="PackageBundleId" />

        <div class="@(serverMessages.Length == 0 ? "hidden " : string.Empty)mx-auto max-w-5xl" data-create-alert role="alert" aria-live="polite">
            <div class="rounded-[28px] border border-[#F3D1D1] bg-[#FDEBEC] p-5 text-[#9F2F2D] shadow-[0_1px_0_rgba(17,17,17,0.03),0_24px_60px_rgba(17,17,17,0.08)] md:p-6">
                <div class="text-[11px] font-black uppercase tracking-[0.18em] text-[#B04443]">Shipment update</div>
                <h2 class="mt-2 text-2xl font-black tracking-[-0.03em] text-[#7C1F1E]" data-create-alert-title>@serverAlertTitle</h2>
                <div class="mt-3 space-y-2 text-sm leading-6 text-[#8E2C2A]" data-create-alert-message>
                    @if (serverMessages.Length > 0)
                    {
                        foreach (var message in serverMessages)
                        {
                            <p>@message</p>
                        }
                    }
                </div>
            </div>
        </div>

        <section class="customer-card p-6 md:p-8">
            <div class="grid gap-8 lg:grid-cols-[280px_1fr]">
                <div>
                    <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">01 / Receiver</div>
                    <h2 class="mt-3 text-2xl font-black tracking-[-0.03em] text-[#111111]">Who receives it?</h2>
                    <p class="mt-3 text-sm leading-6 text-[#666666]">Use accurate contact details so delivery updates reach the right person.</p>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="customer-label" asp-for="Receiver.FirstName">First name</label>
                        <input class="customer-input" asp-for="Receiver.FirstName" data-live-required="Receiver first name" />
                        <div class="customer-field-error" data-error-for="Receiver_FirstName"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="Receiver.LastName">Last name</label>
                        <input class="customer-input" asp-for="Receiver.LastName" data-live-required="Receiver last name" />
                        <div class="customer-field-error" data-error-for="Receiver_LastName"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="Receiver.Email">Email</label>
                        <input class="customer-input" asp-for="Receiver.Email" type="email" data-live-email />
                        <div class="customer-field-error" data-error-for="Receiver_Email"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="Receiver.PhoneNumber">Phone</label>
                        <input class="customer-input" asp-for="Receiver.PhoneNumber" placeholder="+20 101 445 1200" data-live-phone />
                        <div class="customer-field-error" data-error-for="Receiver_PhoneNumber"></div>
                    </div>
                                        <div>
                        <label class="customer-label" asp-for="Receiver.Address.MainAddress">Receiver main address</label>
                        <input class="customer-input" asp-for="Receiver.Address.MainAddress" data-live-required="Receiver main address" placeholder="Building or district" />
                        <div class="customer-field-error" data-error-for="Receiver_Address_MainAddress"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="Receiver.Address.Street">Receiver street</label>
                        <input class="customer-input" asp-for="Receiver.Address.Street" data-live-required="Receiver street" placeholder="Street name" />
                        <div class="customer-field-error" data-error-for="Receiver_Address_Street"></div>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="customer-label" asp-for="Receiver.Address.SecondaryAddress">Receiver secondary address <span class="font-normal text-[#999994]">(optional)</span></label>
                        <input class="customer-input" asp-for="Receiver.Address.SecondaryAddress" placeholder="Floor, apartment, or landmark" />
                        <div class="customer-field-error" data-error-for="Receiver_Address_SecondaryAddress"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="customer-card p-6 md:p-8">
            <div class="grid gap-8 lg:grid-cols-[280px_1fr]">
                <div>
                    <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">02 / Route</div>
                    <h2 class="mt-3 text-2xl font-black tracking-[-0.03em] text-[#111111]">Where is it going?</h2>
                    <p class="mt-3 text-sm leading-6 text-[#666666]">The destination city is checked instantly before the shipment is submitted.</p>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                                        <div>
                        <label class="customer-label" asp-for="PickupAddress.MainAddress">Pickup main address</label>
                        <input class="customer-input" asp-for="PickupAddress.MainAddress" data-live-required="Pickup main address" placeholder="Building or pickup point" />
                        <div class="customer-field-error" data-error-for="PickupAddress_MainAddress"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="PickupAddress.Street">Pickup street</label>
                        <input class="customer-input" asp-for="PickupAddress.Street" data-live-required="Pickup street" placeholder="Street name" />
                        <div class="customer-field-error" data-error-for="PickupAddress_Street"></div>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="customer-label" asp-for="PickupAddress.SecondaryAddress">Pickup secondary address <span class="font-normal text-[#999994]">(optional)</span></label>
                        <input class="customer-input" asp-for="PickupAddress.SecondaryAddress" placeholder="Floor, unit, gate, or landmark" />
                        <div class="customer-field-error" data-error-for="PickupAddress_SecondaryAddress"></div>
                    </div>
                                        <div>
                        <label class="customer-label" asp-for="DeliveryAddress.MainAddress">Delivery main address</label>
                        <input class="customer-input" asp-for="DeliveryAddress.MainAddress" data-live-required="Delivery main address" placeholder="Building or destination" />
                        <div class="customer-field-error" data-error-for="DeliveryAddress_MainAddress"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="DeliveryAddress.Street">Delivery street</label>
                        <input class="customer-input" asp-for="DeliveryAddress.Street" data-live-required="Delivery street" placeholder="Street name" />
                        <div class="customer-field-error" data-error-for="DeliveryAddress_Street"></div>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="customer-label" asp-for="DeliveryAddress.SecondaryAddress">Delivery secondary address <span class="font-normal text-[#999994]">(optional)</span></label>
                        <input class="customer-input" asp-for="DeliveryAddress.SecondaryAddress" placeholder="Floor, unit, gate, or landmark" />
                        <div class="customer-field-error" data-error-for="DeliveryAddress_SecondaryAddress"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="CountryId">Destination country</label>
                        <select class="customer-select" asp-for="CountryId" data-country-select data-live-select="Country">
                            <option value="">Choose country</option>
                            @foreach (var country in Model.Countries)
                            {
                                <option value="@country.Id" selected="@(country.Id == Model.CountryId)">@country.Name</option>
                            }
                        </select>
                        <div class="customer-field-error" data-error-for="CountryId"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="GovernmentId">Destination government</label>
                        <select class="customer-select" asp-for="GovernmentId" data-government-select data-live-select="Government" disabled="@(Model.Governments.Count == 0)">
                            <option value="">Choose government</option>
                            @foreach (var government in Model.Governments)
                            {
                                <option value="@government.Id" selected="@(government.Id == Model.GovernmentId)">@government.Name</option>
                            }
                        </select>
                        <div class="customer-field-error" data-error-for="GovernmentId"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="Receiver.CityId">Destination city</label>
                        <select class="customer-select" asp-for="Receiver.CityId" data-city-select data-live-city disabled="@(Model.Cities.Count == 0)">
                            <option value="">Choose city</option>
                            @foreach (var city in Model.Cities)
                            {
                                <option value="@city.Id" selected="@(city.Id == Model.Receiver.CityId)">@city.Name</option>
                            }
                        </select>
                        <div class="customer-field-error" data-error-for="Receiver_CityId"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="PickUpDate">Preferred pickup</label>
                        <input class="customer-input" asp-for="PickUpDate" type="datetime-local" data-live-pickup-date />
                        <div class="customer-field-error" data-error-for="PickUpDate"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="customer-card p-6 md:p-8">
            <div class="grid gap-8 lg:grid-cols-[280px_1fr]">
                <div>
                    <div class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">03 / Package</div>
                    <h2 class="mt-3 text-2xl font-black tracking-[-0.03em] text-[#111111]">What are we moving?</h2>
                    <p class="mt-3 text-sm leading-6 text-[#666666]">Dimensions are validated live so oversized packages are caught early.</p>
                </div>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                    <div>
                        <label class="customer-label" asp-for="PackageSpecification.Weight">Weight kg</label>
                        <input class="customer-input" asp-for="PackageSpecification.Weight" type="number" step="0.01" min="0.01" placeholder="2.40" data-live-weight />
                        <div class="customer-field-error" data-error-for="PackageSpecification_Weight"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="PackageSpecification.Width">Width cm</label>
                        <input class="customer-input" asp-for="PackageSpecification.Width" type="number" step="0.01" min="0.01" placeholder="34" data-live-dimension />
                        <div class="customer-field-error" data-error-for="PackageSpecification_Width"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="PackageSpecification.Height">Height cm</label>
                        <input class="customer-input" asp-for="PackageSpecification.Height" type="number" step="0.01" min="0.01" placeholder="12" data-live-dimension />
                        <div class="customer-field-error" data-error-for="PackageSpecification_Height"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="PackageSpecification.Length">Length cm</label>
                        <input class="customer-input" asp-for="PackageSpecification.Length" type="number" step="0.01" min="0.01" placeholder="44" data-live-dimension />
                        <div class="customer-field-error" data-error-for="PackageSpecification_Length"></div>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="ShipmentDeliveryType">Delivery type</label>
                        <select class="customer-select" asp-for="ShipmentDeliveryType">
                            <option value="Standard">Standard</option>
                            <option value="Express">Express</option>
                            <option value="Fragile">Fragile</option>
                        </select>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="TransportationMode">Transport mode</label>
                        <select class="customer-select" asp-for="TransportationMode">
                            <option value="Land">Land</option>
                            <option value="Air">Air</option>
                            <option value="Sea">Sea</option>
                        </select>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="Currency">Currency</label>
                        <select class="customer-select" asp-for="Currency">
                            <option value="EGP">EGP</option>
                            <option value="USD">USD</option>
                            <option value="EUR">EUR</option>
                        </select>
                    </div>
                    <div>
                        <label class="customer-label" asp-for="PaymentMethod">Payment</label>
                        <select class="customer-select" asp-for="PaymentMethod">
                            <option value="CreditCard">Credit card</option>
                            <option value="PayPal">PayPal</option>
                            <option value="MobileWallets">Mobile wallet</option>
                        </select>
                    </div>
                </div>
            </div>
        </section>

        <section class="customer-card overflow-hidden">
            <div class="grid gap-0 lg:grid-cols-[1fr_360px]">
                <div class="p-6 md:p-8">
                    <div class="customer-badge customer-badge-success">Ready check</div>
                    <h2 class="mt-4 text-2xl font-black tracking-[-0.03em] text-[#111111]">Submit when everything is clean.</h2>
                    <p class="mt-3 text-sm leading-6 text-[#666666]">Any live validation issue appears inline before the backend receives the request.</p>
                </div>
                <div class="border-t border-[#EAEAEA] bg-[#FBFBFA] p-6 md:p-8 lg:border-l lg:border-t-0">
                    <button type="submit" class="customer-button min-h-[52px] w-full" data-create-submit-button>
                        <span class="customer-spinner hidden" data-button-spinner></span>
                        <span data-button-text>Create Shipment</span>
                    </button>
                    <p class="mt-3 text-center text-xs font-semibold leading-5 text-[#787774]">You can edit the shipment before it is approved.</p>
                </div>
            </div>
        </section>
    </form>

    <div class="fixed inset-0 z-50 hidden bg-[#111111]/55 px-4 py-8 backdrop-blur-sm" data-payment-overlay aria-hidden="true" role="status" aria-live="polite">
        <div class="flex min-h-full items-center justify-center">
            <div class="w-full max-w-md rounded-[32px] bg-[#111111] p-8 text-white shadow-[0_24px_80px_rgba(17,17,17,0.35)]">
                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-white/10 bg-white/5">
                    <div class="h-12 w-12 animate-spin rounded-full border-[3px] border-white/20 border-t-white"></div>
                </div>
                <h2 class="mt-6 text-center text-2xl font-black tracking-[-0.03em]">Processing payment</h2>
                <p class="mt-3 text-center text-sm leading-6 text-white/70">This usually takes around 5 seconds.</p>
            </div>
        </div>
    </div>

    <div class="fixed inset-0 z-[60] hidden bg-[#111111]/55 px-4 py-8 backdrop-blur-sm" data-invoice-modal aria-hidden="true">
        <div class="flex min-h-full items-center justify-center">
            <div class="w-full max-w-3xl rounded-[32px] border border-[#EAEAEA] bg-white shadow-[0_24px_80px_rgba(17,17,17,0.18)]" role="dialog" aria-modal="true" aria-labelledby="invoice-modal-title">
                <div class="flex items-start justify-between gap-4 border-b border-[#EFEFED] px-6 py-6 md:px-8">
                    <div>
                        <div class="customer-badge customer-badge-success">Payment complete</div>
                        <h2 id="invoice-modal-title" class="mt-4 text-3xl font-black tracking-[-0.03em] text-[#111111]">Invoice ready</h2>
                        <p class="mt-3 max-w-2xl text-sm leading-6 text-[#666666]">Your invoice is ready. You can review the payment details now and continue to the shipment record when you are ready.</p>
                    </div>
                    <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#EAEAEA] text-xl font-semibold text-[#444444] transition hover:border-[#D8D8D5] hover:bg-[#F7F7F6] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#111111]" data-invoice-close aria-label="Close invoice">×</button>
                </div>
                <div class="space-y-8 px-6 py-6 md:px-8">
                    <div class="flex flex-wrap items-center gap-3">
                        <div class="rounded-full bg-[#F3F7F3] px-4 py-2 text-sm font-bold text-[#14532D]" data-invoice-status-badge>Pending</div>
                        <div class="text-sm font-semibold text-[#666666]">Payment method: <span class="text-[#111111]" data-invoice-payment-method>Not available</span></div>
                    </div>
                    <dl class="grid gap-x-8 gap-y-5 sm:grid-cols-2">
                        <div class="border-b border-[#EFEFED] pb-4"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Invoice ID</dt><dd class="mt-2 break-all text-sm font-semibold leading-6 text-[#111111]" data-invoice-id>Not available</dd></div>`r`n                        <div class="border-b border-[#EFEFED] pb-4"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Payment ID</dt><dd class="mt-2 break-all text-sm font-semibold leading-6 text-[#111111]" data-invoice-payment-id>Not available</dd></div>
                        <div class="border-b border-[#EFEFED] pb-4"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Paid at</dt><dd class="mt-2 text-sm font-semibold leading-6 text-[#111111]" data-invoice-paid-at>Pending confirmation</dd></div>
                        <div class="border-b border-[#EFEFED] pb-4"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Shipping cost</dt><dd class="mt-2 text-sm font-semibold leading-6 text-[#111111]" data-invoice-shipping-cost>0.00</dd></div>
                        <div class="border-b border-[#EFEFED] pb-4"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Commission</dt><dd class="mt-2 text-sm font-semibold leading-6 text-[#111111]" data-invoice-commission>0.00</dd></div>
                        <div class="border-b border-[#EFEFED] pb-4 sm:col-span-2"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Total amount</dt><dd class="mt-2 text-2xl font-black tracking-[-0.03em] text-[#111111]" data-invoice-amount>0.00</dd></div>
                        <div class="sm:col-span-2"><dt class="text-[11px] font-black uppercase tracking-[0.18em] text-[#787774]">Notes</dt><dd class="mt-2 text-sm leading-6 text-[#444444]" data-invoice-notes>No additional notes.</dd></div>
                    </dl>
                </div>
                <div class="flex flex-col-reverse gap-3 border-t border-[#EFEFED] px-6 py-6 md:flex-row md:justify-end md:px-8">
                    <button type="button" class="customer-button-secondary min-h-[48px] justify-center" data-invoice-close>Close</button>
                    <a href="#" class="customer-button min-h-[48px] justify-center" data-shipment-details-link>Show Shipment Details</a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/User/create-shipment.js" asp-append-version="true"></script>
}
