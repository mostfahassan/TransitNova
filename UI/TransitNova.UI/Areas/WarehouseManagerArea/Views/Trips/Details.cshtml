@model UiTripDetailsDto?
@{
    ViewData["Title"] = "Trip Details";
    var trip = Model ?? new UiTripDetailsDto();
    var detail = new WarehouseDetailViewModel
    {
        Title = "Trip manifest",
        Subtitle = "Carrier movement, warehouse lane, and shipment manifest attached to this trip.",
        PrimaryLabel = trip.Id == Guid.Empty ? string.Empty : trip.Id.ToString(),
        Controller = "Trips",
        Fields =
        [
            AdminDisplay.WarehouseCell("Trip", trip.Id, "id"),
            AdminDisplay.WarehouseCell("Type", trip.TripType),
            AdminDisplay.WarehouseCell("Status", trip.Status, "badge"),
            AdminDisplay.WarehouseCell("Carrier", trip.CarrierName),
            AdminDisplay.WarehouseCell("Carrier phone", trip.CarrierPhoneNumber),
            AdminDisplay.WarehouseCell("Warehouse", trip.WarehouseName),
            AdminDisplay.WarehouseCell("Address", trip.WarehouseAddress),
            AdminDisplay.WarehouseCell("Planned", trip.PlannedDate),
            AdminDisplay.WarehouseCell("Started", trip.StartTime),
            AdminDisplay.WarehouseCell("Ended", trip.EndTime),
            AdminDisplay.WarehouseCell("Shipments", trip.TotalShipments),
            AdminDisplay.WarehouseCell("Created by", trip.CreatedBy)
        ]
    };
    var shipmentTable = new WarehouseTableViewModel
    {
        Title = "Trip shipment manifest",
        Subtitle = "Every shipment physically moving with this carrier trip.",
        Controller = "Shipments",
        Headers = ["Tracking", "Status", "Receiver", "Pickup", "Delivery", "Cost"],
        Rows = trip.Shipments.Select(shipment => AdminDisplay.WarehouseRow("shipmentId", shipment.Id,
            AdminDisplay.WarehouseCell("Tracking", shipment.TrackingNumber, "id"),
            AdminDisplay.WarehouseCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.WarehouseCell("Receiver", shipment.Receiver.FullName),
            AdminDisplay.WarehouseCell("Pickup", shipment.PickupAddress),
            AdminDisplay.WarehouseCell("Delivery", shipment.DeliveryAddress),
            AdminDisplay.WarehouseCell("Cost", shipment.ShippingCost, "currency"))).ToList(),
        EmptyTitle = "No shipments on this trip",
        EmptyDescription = "The manifest will show here when a trip carries shipments."
    };
    var kpiTiles = new List<WarehouseKpiTileViewModel>
    {
        new("Trip type", AdminDisplay.Format(trip.TripType), "Movement lane", "info"),
        new("Status", AdminDisplay.Format(trip.Status, kind: "badge"), "Current state", "warning"),
        new("Shipments", AdminDisplay.Format(trip.TotalShipments), "Manifest count", "success")
    };
}
<section class="mb-6 grid gap-4 md:grid-cols-3">
@foreach (var tile in kpiTiles) { <partial name="_WarehouseKpiTile" model="tile" /> }
</section>
<partial name="_WarehouseDetail" model="detail" />
<section class="mt-6"><partial name="_WarehouseTable" model="shipmentTable" /></section>
