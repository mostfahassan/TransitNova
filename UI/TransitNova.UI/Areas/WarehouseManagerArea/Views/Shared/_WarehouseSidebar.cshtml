@{
    var currentController = Context.Request.RouteValues["controller"]?.ToString();
    var items = new[]
    {
        new WarehouseSidebarItemViewModel("Dashboard", "Dashboard", "Index", "dashboard"),
        new WarehouseSidebarItemViewModel("Inbound", "Shipments", "Index", "inbound"),
        new WarehouseSidebarItemViewModel("Outbound", "Shipments", "Index", "outbound"),
        new WarehouseSidebarItemViewModel("Inventory", "Shipments", "Index", "inventory"),
        new WarehouseSidebarItemViewModel("Trips", "Trips", "Index", "route"),
        new WarehouseSidebarItemViewModel("Carriers", "Carriers", "Index", "carrier"),
        new WarehouseSidebarItemViewModel("Zones", "Dashboard", "Index", "zones"),
        new WarehouseSidebarItemViewModel("Damaged Goods", "Shipments", "Index", "damaged"),
        new WarehouseSidebarItemViewModel("Profile", "Profile", "Edit", "profile")
    };
}

<aside data-warehouse-sidebar class="warehouse-sidebar">
    <div class="border-b border-[#EAEAEA] p-6">
        <a asp-area="LandingArea" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 transition-transform duration-200 active:scale-[0.98]">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-[#111111] text-sm font-black text-white">TN</span>
            <span>
                <span class="block text-base font-black tracking-tight text-[#111111]">TransitNova</span>
                <span class="block font-mono text-[10px] font-black uppercase tracking-[0.16em] text-[#787774]">Warehouse console</span>
            </span>
        </a>
    </div>

    <nav class="flex-1 overflow-y-auto p-4">
        <div class="mb-3 px-2 font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Operations lanes</div>
        <div class="space-y-1">
            @foreach (var item in items)
            {
                var active = string.Equals(currentController, item.Controller, StringComparison.OrdinalIgnoreCase);
                var routeValues = RouteValues(item.Label);
                <a asp-area="WarehouseManagerArea" asp-controller="@item.Controller" asp-action="@item.Action" asp-all-route-data="routeValues" class="warehouse-sidebar-link @(active ? "is-active" : string.Empty)">
                    @Html.Raw(WarehouseIcon(item.Icon))
                    <span class="truncate">@item.Label</span>
                    @if (!string.IsNullOrWhiteSpace(item.Badge))
                    {
                        <span class="ml-auto rounded-full bg-[#F1F1EF] px-2 py-0.5 font-mono text-[10px] font-black text-[#55524D]">@item.Badge</span>
                    }
                </a>
            }
        </div>
    </nav>

    <div class="border-t border-[#EAEAEA] p-4">
        <div class="rounded-xl border border-[#EAEAEA] bg-white p-3">
            <div class="flex items-center justify-between font-mono text-[10px] font-black uppercase tracking-[0.16em] text-[#787774]">
                <span>Scanner</span>
                <span class="text-[#346538]">Ready</span>
            </div>
            <div class="mt-3 warehouse-progress"><span style="--progress:88%;--progress-color:#346538"></span></div>
            <p class="mt-2 text-xs font-semibold leading-5 text-[#787774]">Global scan lane routes to warehouse shipments.</p>
        </div>
    </div>
</aside>

@functions {
    private static IDictionary<string, string>? RouteValues(string label) => label switch
    {
        "Inbound" => new Dictionary<string, string> { ["Status"] = "InWarehouse" },
        "Outbound" => new Dictionary<string, string> { ["Status"] = "OutForDelivery" },
        "Damaged Goods" => new Dictionary<string, string> { ["Status"] = "Issue" },
        _ => null
    };

    private static string WarehouseIcon(string name) => name switch
    {
        "dashboard" => "<svg viewBox='0 0 24 24' fill='none'><path d='M4 5h7v7H4V5Zm9 0h7v4h-7V5ZM4 14h7v5H4v-5Zm9-3h7v8h-7v-8Z' stroke='currentColor' stroke-width='1.7' stroke-linejoin='round'/></svg>",
        "inbound" => "<svg viewBox='0 0 24 24' fill='none'><path d='M12 4v11m0 0 4-4m-4 4-4-4M4 17v2h16v-2' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'/></svg>",
        "outbound" => "<svg viewBox='0 0 24 24' fill='none'><path d='M12 20V9m0 0 4 4m-4-4-4 4M4 5v2h16V5' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'/></svg>",
        "inventory" => "<svg viewBox='0 0 24 24' fill='none'><path d='m4 8 8-4 8 4-8 4-8-4Zm0 0v8l8 4 8-4V8M12 12v8' stroke='currentColor' stroke-width='1.7' stroke-linejoin='round'/></svg>",
        "route" => "<svg viewBox='0 0 24 24' fill='none'><path d='M6 6h5a4 4 0 0 1 0 8H9a3 3 0 0 0 0 6h9M6 6l3-3M6 6l3 3' stroke='currentColor' stroke-width='1.7' stroke-linecap='round' stroke-linejoin='round'/></svg>",
        "carrier" => "<svg viewBox='0 0 24 24' fill='none'><path d='M4 17V7h10v10M14 10h4l3 4v3h-7M7 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm11 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z' stroke='currentColor' stroke-width='1.7' stroke-linejoin='round'/></svg>",
        "zones" => "<svg viewBox='0 0 24 24' fill='none'><path d='M4 4h16v16H4V4Zm0 6h16M10 4v16M14 10v10' stroke='currentColor' stroke-width='1.7'/></svg>",
        "damaged" => "<svg viewBox='0 0 24 24' fill='none'><path d='M12 3 3 20h18L12 3Zm0 6v5m0 3h.01' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'/></svg>",
        "profile" => "<svg viewBox='0 0 24 24' fill='none'><path d='M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm7 8a7 7 0 0 0-14 0' stroke='currentColor' stroke-width='1.7' stroke-linecap='round'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none'><path d='M5 12h14' stroke='currentColor' stroke-width='1.7' stroke-linecap='round'/></svg>"
    };
}