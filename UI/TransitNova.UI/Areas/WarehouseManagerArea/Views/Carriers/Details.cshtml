@model UiCarrierProfileDto?
@{
    ViewData["Title"] = "Carrier Details";
    var carrier = Model ?? new UiCarrierProfileDto();
    var assignedShipments = "-";
    var activeTrips = "-";
    var rating = AdminDisplay.Format(carrier.Rating);
    var detail = new WarehouseDetailViewModel
    {
        Title = "Carrier profile",
        Subtitle = "Operational identity, status, and warehouse workload for this carrier.",
        PrimaryLabel = carrier.FullName,
        Controller = "Carriers",
        Fields =
        [
            AdminDisplay.WarehouseCell("Carrier", carrier.FullName),
            AdminDisplay.WarehouseCell("Status", carrier.Status, "badge"),
            AdminDisplay.WarehouseCell("Code", carrier.Code, "id"),
            AdminDisplay.WarehouseCell("Phone", carrier.PhoneNumber),
            AdminDisplay.WarehouseCell("Rating", carrier.Rating),
            AdminDisplay.WarehouseCell("Assigned shipments", assignedShipments),
            AdminDisplay.WarehouseCell("Active trips", activeTrips),
            AdminDisplay.WarehouseCell("Served cities", carrier.CityName)
        ]
    };
    var kpiTiles = new List<WarehouseKpiTileViewModel>
    {
        new("Assigned shipments", assignedShipments, "Current load", "warning"),
        new("Active trips", activeTrips, "Moving now", "info"),
        new("Rating", rating, "Service quality", "success")
    };
}

<section class="mb-6 grid gap-4 md:grid-cols-3">
    @foreach (var tile in kpiTiles)
    {
        <partial name="_WarehouseKpiTile" model="tile" />
    }
</section>

<partial name="_WarehouseDetail" model="detail" />

<section class="mt-6 warehouse-card p-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <p class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Coverage</p>
            <h2 class="mt-2 text-xl font-black tracking-tight text-[#111111]">Served city lanes</h2>
            <p class="mt-1 text-sm font-semibold text-[#787774]">Used by dispatch to match pickup and delivery city coverage.</p>
        </div>
        <a asp-area="WarehouseManagerArea" asp-controller="Trips" asp-action="Index" asp-route-CarrierId="@carrier.Id" class="warehouse-button-secondary">Trips for carrier</a>
    </div>
    <div class="mt-5 flex flex-wrap gap-2">
        <span class="warehouse-badge warehouse-badge-info">@AdminDisplay.Format(carrier.CityName)</span>
    </div>
</section>
