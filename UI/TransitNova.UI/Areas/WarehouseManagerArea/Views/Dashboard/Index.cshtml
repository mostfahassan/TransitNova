@model UiWarehouseManagerDashboardDto?
@{
    ViewData["Title"] = "Warehouse Dashboard";
    var dashboard = Model ?? new UiWarehouseManagerDashboardDto();
    var manager = dashboard.Manager;
    var kpis = dashboard.Kpis;
    var totalShipments = AdminDisplay.Format(kpis.TotalShipments);
    var deliveredShipments = AdminDisplay.Format(kpis.DeliveredShipments);
    var activeTrips = AdminDisplay.Format(kpis.ActiveTrips);
    var activeCarriers = AdminDisplay.Format(kpis.ActiveCarriers);
    var deliveryProgress = kpis.TotalShipments == 0 ? 0 : Math.Round((decimal)kpis.DeliveredShipments / kpis.TotalShipments * 100, 0);
    var header = new WarehousePageHeaderViewModel
    {
        Eyebrow = "Warehouse command",
        Title = $"{AdminDisplay.Format(manager.WarehouseName)} operating board",
        Description = "Monitor shipments, active trips, and carrier capacity from one scanner-friendly operations surface.",
        PrimaryLabel = "Open inventory",
        PrimaryController = "Shipments",
        PrimaryAction = "Index",
        SecondaryLabel = "Carrier roster",
        SecondaryController = "Carriers",
        SecondaryAction = "Index"
    };
    var kpiTiles = new List<WarehouseKpiTileViewModel>
    {
        new("Total shipments", totalShipments, "All lanes", "info", deliveryProgress),
        new("Delivered", deliveredShipments, "Closed", "success"),
        new("Active trips", activeTrips, "Moving", "warning"),
        new("Active carriers", activeCarriers, "Available", "neutral")
    };
    var recentShipmentsTable = new WarehouseTableViewModel
    {
        Title = "Recent shipments",
        Subtitle = "Latest warehouse-visible shipments from the API.",
        Controller = "Shipments",
        Headers = ["Tracking", "Status", "Created"],
        Rows = dashboard.RecentShipments.Select(shipment => AdminDisplay.WarehouseRow(
            "shipmentId",
            shipment.Id,
            AdminDisplay.WarehouseCell("Tracking", shipment.TrackingNumber),
            AdminDisplay.WarehouseCell("Status", shipment.CurrentStatus, "badge"),
            AdminDisplay.WarehouseCell("Created", shipment.CreatedAt))).ToList(),
        EmptyTitle = "No recent shipments",
        EmptyDescription = "Warehouse shipments will appear here after the backend returns activity."
    };
    var recentTripsTable = new WarehouseTableViewModel
    {
        Title = "Recent trips",
        Subtitle = "Pickup and delivery trips attached to this warehouse.",
        Controller = "Trips",
        Headers = ["Trip", "Type", "Status", "Planned"],
        Rows = dashboard.RecentTrips.Select(trip => AdminDisplay.WarehouseRow(
            "tripId",
            trip.Id,
            AdminDisplay.WarehouseCell("Trip", trip.Id, "id"),
            AdminDisplay.WarehouseCell("Type", trip.TripType),
            AdminDisplay.WarehouseCell("Status", trip.Status, "badge"),
            AdminDisplay.WarehouseCell("Planned", trip.PlannedDate))).ToList(),
        EmptyTitle = "No recent trips",
        EmptyDescription = "Trips will appear here when carriers are assigned to warehouse movement."
    };
}

<partial name="_WarehousePageHeader" model="header" />

<section class="mb-6 grid gap-4 xl:grid-cols-[minmax(0,1fr)_420px]">
    <form asp-area="WarehouseManagerArea" asp-controller="Shipments" asp-action="Index" method="get" class="warehouse-card p-5 md:p-6">
        <label for="warehouseScan" class="warehouse-label">Primary scan lane</label>
        <div class="flex flex-col gap-3 md:flex-row">
            <input id="warehouseScan" name="SearchTerm" class="warehouse-input warehouse-scan-input" placeholder="SCAN SHIPMENT OR TYPE TRACKING" autocomplete="off" autofocus />
            <button type="submit" class="warehouse-button min-h-[74px] md:w-40">Search</button>
        </div>
        <p class="mt-3 text-xs font-bold uppercase tracking-[0.12em] text-[#787774]">Hardware barcode scanners can type directly into this field.</p>
    </form>

    <section id="capacity" class="warehouse-card p-5 md:p-6">
        <div class="flex items-center justify-between gap-4">
            <div>
                <p class="font-mono text-[10px] font-black uppercase tracking-[0.18em] text-[#787774]">Capacity signal</p>
                <h2 class="mt-2 text-2xl font-black tracking-tight text-[#111111]">Shipment throughput</h2>
            </div>
            <span class="warehouse-badge warehouse-badge-info">Live</span>
        </div>
        <div class="mt-5 warehouse-progress"><span style="--progress:@deliveryProgress%;--progress-color:@(deliveryProgress >= 90 ? "#9F2F2D" : deliveryProgress >= 75 ? "#956400" : "#346538")"></span></div>
        <div class="mt-3 flex items-center justify-between text-xs font-bold text-[#787774]"><span>@deliveredShipments delivered</span><span>@deliveryProgress%</span></div>
    </section>
</section>

<section class="mb-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    @foreach (var tile in kpiTiles)
    {
        <partial name="_WarehouseKpiTile" model="tile" />
    }
</section>

<section class="grid gap-6 xl:grid-cols-2">
    <partial name="_WarehouseTable" model="recentShipmentsTable" />
    <partial name="_WarehouseTable" model="recentTripsTable" />
</section>
