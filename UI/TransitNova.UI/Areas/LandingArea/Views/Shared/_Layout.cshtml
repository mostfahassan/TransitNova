<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TransitNova is a logistics platform for shipment booking, carrier assignment, warehouse coordination, and delivery tracking." />
    <title>@ViewData["Title"] - TransitNova</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/LandingPage/Landing.css" asp-append-version="true" />
</head>
<body class="landing-shell">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header" data-landing-header>
        <nav class="landing-nav" aria-label="Primary navigation">
            <a class="brand-mark" asp-area="" asp-controller="Home" asp-action="Index" aria-label="TransitNova home">
                <span class="brand-symbol" aria-hidden="true"><img class"LogoImg" src="~/Images/Logo.png" /></span>
                <span class="brand-copy">
                    <span class="brand-name">TransitNova</span>
                    <span class="brand-note">Logistics OS</span>
                </span>
            </a>

            <button class="nav-toggle" type="button" data-nav-toggle aria-expanded="false" aria-controls="landing-menu">
                <span class="nav-toggle-line" aria-hidden="true"></span>
                <span class="nav-toggle-line" aria-hidden="true"></span>
                <span class="sr-only">Toggle navigation</span>
            </button>

            <div class="nav-menu" id="landing-menu" data-nav-menu>
                <a href="#services">Services</a>
                <a href="#platform">Platform</a>
                <a href="#projects">Projects</a>
                <a href="#insights">Insights</a>
                <a class="nav-action" href="#contact">Contact us</a>
            </div>
        </nav>
    </header>

    <main id="main-content" role="main">
        @RenderBody()
    </main>

    <footer class="landing-footer">
        <div class="footer-grid">
            <div>
                <a class="brand-mark footer-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-symbol" aria-hidden="true"><img src="~/Images/Logo.png" alt="Logo" class="Logo"></span>
                    <span class="brand-copy">
                        <span class="brand-name">TransitNova</span>
                        <span class="brand-note">Shipment management without drift</span>
                    </span>
                </a>
                <p>Built for teams that need clear shipment intake, carrier operations, warehouse movement, and customer tracking in one place.</p>
            </div>

            <div>
                <h2>Quick Links</h2>
                <ul>
                    <li><a href="#services">Services</a></li>
                    <li><a href="#platform">Platform</a></li>
                    <li><a href="#projects">Projects</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>

            <div>
                <h2>Contact</h2>
                <ul>
                    <li><a href="mailto:info@transitnova.local">info@transitnova.local</a></li>
                    <li><a href="tel:+201000000000">+20 100 000 0000</a></li>
                    <li>Cairo logistics desk</li>
                </ul>
            </div>

            <form class="newsletter-form" aria-label="Newsletter signup">
                <label for="footer-email">Newsletter</label>
                <div class="newsletter-row">
                    <input id="footer-email" name="email" type="email" autocomplete="email" placeholder="Email address" />
                    <button type="submit" aria-label="Submit email">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 12h14M13 6l6 6-6 6" />
                        </svg>
                    </button>
                </div>
            </form>
        </div>

        <div class="footer-bottom">
            <span>&copy; 2026 TransitNova. All rights reserved.</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/js/LandingPage/Landing.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
