@model UiCarrierDashboardDto?
@{
    ViewData["Title"] = "Carrier Dashboard";
    var dashboard = Model ?? new UiCarrierDashboardDto();
    var recentShipments = dashboard.RecentShipments ?? [];
    var activeTrips = dashboard.ActiveTrips ?? [];
}

<section class="carrier-fade-up">
    <div class="carrier-card overflow-hidden">
        <div class="grid gap-0 lg:grid-cols-[1fr_360px]">
            <div class="p-6 md:p-8">
                <div class="carrier-badge carrier-badge-info">Carrier workspace</div>
                <h2 class="mt-5 text-4xl font-black leading-[1.02] tracking-[-0.04em] text-[#111111]">@Display(dashboard.CarrierName, "Carrier")</h2>
                <p class="mt-3 max-w-2xl text-sm leading-6 text-[#66615a]">Run active trips, confirm pickup milestones, complete deliveries, and keep your profile ready for dispatch.</p>
                <div class="mt-6 flex flex-wrap gap-3">
                    <a asp-area="CarrierArea" asp-controller="Trips" asp-action="Index" class="carrier-button">Open Trips</a>
                    <a asp-area="CarrierArea" asp-controller="Shipments" asp-action="Index" class="carrier-button-secondary">Assigned Shipments</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="carrier-stagger mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="carrier-card p-5" style="--item-index:0"><div class="text-xs font-black uppercase tracking-[0.14em] text-[#737373]">Assigned</div><div class="mt-3 text-4xl font-black text-[#111111]">@dashboard.AssignedShipmentsCount</div><p class="mt-2 text-sm text-[#66615a]">Shipments currently assigned.</p></div>
    <div class="carrier-card p-5" style="--item-index:1"><div class="text-xs font-black uppercase tracking-[0.14em] text-[#737373]">Delivered</div><div class="mt-3 text-4xl font-black text-[#111111]">@dashboard.DeliveredShipmentsCount</div><p class="mt-2 text-sm text-[#66615a]">Completed shipment handoffs.</p></div>
    <div class="carrier-card p-5" style="--item-index:2"><div class="text-xs font-black uppercase tracking-[0.14em] text-[#737373]">Active trips</div><div class="mt-3 text-4xl font-black text-[#111111]">@dashboard.ActiveTripsCount</div><p class="mt-2 text-sm text-[#66615a]">Trips requiring attention.</p></div>
    <div class="carrier-card p-5" style="--item-index:3"><div class="text-xs font-black uppercase tracking-[0.14em] text-[#737373]">Revenue</div><div class="mt-3 text-4xl font-black text-[#111111]">@dashboard.RevenueSummary.ToString("N0")</div><p class="mt-2 text-sm text-[#66615a]">Current revenue summary.</p></div>
</section>

<section class="mt-6 grid gap-6 xl:grid-cols-[1fr_420px]">
    <div class="carrier-card overflow-hidden">
        <div class="flex items-center justify-between gap-4 border-b border-[#E7E5E0] p-5">
            <div><h3 class="text-xl font-black tracking-[-0.02em] text-[#111111]">Recent shipments</h3><p class="mt-1 text-sm text-[#66615a]">Latest assigned shipment activity.</p></div>
            <a asp-area="CarrierArea" asp-controller="Shipments" asp-action="Index" class="carrier-button-secondary">View all</a>
        </div>
        <div class="overflow-x-auto">
            <table class="carrier-table">
                <thead><tr><th>Tracking</th><th>Route</th><th>Status</th><th class="text-right">Action</th></tr></thead>
                <tbody>
                @foreach (var item in recentShipments.Select((value, index) => new { value, index }))
                {
                    <tr style="--row-index:@item.index">
                        <td><span class="font-mono text-xs font-black text-[#111111]">@item.value.TrackingNumber</span></td>
                        <td>@Display(item.value.PickupAddress.ToString(), "Pickup") -> @Display(item.value.DeliveryAddress.ToString(), "Delivery")</td>
                        <td><span class="carrier-badge @BadgeClass(item.value.CurrentStatus.ToString())">@item.value.CurrentStatus</span></td>
                        <td class="text-right"><a asp-area="CarrierArea" asp-controller="Shipments" asp-action="Details" asp-route-shipmentId="@item.value.Id" class="carrier-button-secondary !min-h-[34px] !px-3 !py-2">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="carrier-card p-5">
        <div class="flex items-center justify-between gap-3"><h3 class="text-xl font-black tracking-[-0.02em] text-[#111111]">Active trips</h3><a asp-area="CarrierArea" asp-controller="Trips" asp-action="Index" class="carrier-button-secondary !min-h-[34px] !px-3 !py-2">Trips</a></div>
        <div class="mt-5 space-y-3">
            @foreach (var trip in activeTrips.Take(5))
            {
                <a asp-area="CarrierArea" asp-controller="Trips" asp-action="Details" asp-route-tripId="@trip.Id" class="carrier-panel block p-4 transition hover:bg-white">
                    <div class="flex items-center justify-between gap-3"><span class="font-black text-[#111111]">@trip.TripType trip</span><span class="carrier-badge @BadgeClass(trip.Status.ToString())">@trip.Status</span></div>
                    <p class="mt-2 text-sm text-[#66615a]">@trip.WarehouseName - @trip.ShipmentCount shipments</p>
                </a>
            }
            @if (!activeTrips.Any())
            {
                <div class="carrier-panel p-5 text-sm font-bold text-[#66615a]">No active trips right now.</div>
            }
        </div>
    </div>
</section>

@functions {
    private static string Display(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value;
    private static string BadgeClass(string value)
    {
        var text = value.ToLowerInvariant();
        if (text.Contains("complete") || text.Contains("deliver") || text.Contains("warehouse") || text.Contains("active")) return "carrier-badge-success";
        if (text.Contains("pickup") || text.Contains("transit") || text.Contains("assigned")) return "carrier-badge-info";
        if (text.Contains("pending") || text.Contains("planned")) return "carrier-badge-warning";
        if (text.Contains("cancel") || text.Contains("reject") || text.Contains("fail")) return "carrier-badge-danger";
        return "carrier-badge-neutral";
    }
}