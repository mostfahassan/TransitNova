@model UiCarrierVehicleDto?
@{
    ViewData["Title"] = "Carrier Vehicle";
    var vehicle = Model;
}

<section class="carrier-fade-up">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div><div class="carrier-badge carrier-badge-info">Vehicle</div><h2 class="mt-4 text-3xl font-black tracking-[-0.03em] text-[#111111]">Assigned vehicle</h2><p class="mt-2 text-sm text-[#66615a]">Capacity and readiness information returned from the backend.</p></div>
        <a asp-area="CarrierArea" asp-controller="Profile" asp-action="Index" class="carrier-button-secondary">Profile</a>
    </div>

    @if (vehicle is null)
    {
        <div class="carrier-card mt-6 p-12 text-center"><h3 class="text-xl font-black text-[#111111]">No vehicle returned</h3><p class="mt-2 text-sm text-[#66615a]">Once a vehicle is linked to your profile, its details will appear here.</p></div>
    }
    else
    {
        <div class="carrier-card mt-6 overflow-hidden">
            <div class="grid gap-0 lg:grid-cols-[1fr_360px]">
                <div class="p-6 md:p-8">
                    <div class="carrier-badge @(vehicle.IsActive ? "carrier-badge-success" : "carrier-badge-neutral")">@(vehicle.IsActive ? "Active" : "Inactive")</div>
                    <h2 class="mt-5 text-4xl font-black tracking-[-0.04em] text-[#111111]">@vehicle.PlateNumber</h2>
                    <p class="mt-3 text-sm text-[#66615a]">@vehicle.VehicleType vehicle assigned for shipment movement.</p>
                </div>
                <aside class="border-t border-[#E7E5E0] bg-[#FBFBFA] p-6 lg:border-l lg:border-t-0">
                    <dl class="space-y-3 text-sm">
                        <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Weight capacity</dt><dd class="font-black text-[#111111]">@vehicle.CapacityWeight.ToString("N2") kg</dd></div>
                        <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Volume capacity</dt><dd class="font-black text-[#111111]">@vehicle.CapacityVolume.ToString("N2")</dd></div>
                        <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Refrigerated</dt><dd class="font-black text-[#111111]">@(vehicle.IsRefrigerated ? "Yes" : "No")</dd></div>
                    </dl>
                </aside>
            </div>
        </div>
    }
</section>