@model UiCarrierProfileDto?
@{
    ViewData["Title"] = "Carrier Profile";
    var profile = Model ?? new UiCarrierProfileDto();
    var vehicle = profile.Vehicle;
}

<section class="carrier-fade-up">
    <div class="carrier-card overflow-hidden">
        <div class="grid gap-0 lg:grid-cols-[360px_1fr]">
            <aside class="border-b border-[#E7E5E0] bg-[#FBFBFA] p-6 lg:border-b-0 lg:border-r">
                <div class="grid h-20 w-20 place-items-center rounded-[14px] bg-[#111111] text-xl font-black text-white">CR</div>
                <h2 class="mt-6 text-3xl font-black tracking-[-0.03em] text-[#111111]">@Display(profile.FullName, "Carrier")</h2>
                <p class="mt-2 text-sm font-semibold text-[#66615a]">@Display(profile.Email, "No email")</p>
                <div class="mt-5 carrier-badge @BadgeClass(profile.Status.ToString())">@profile.Status</div>
                <div class="mt-6 flex gap-3"><a asp-action="Edit" class="carrier-button">Edit profile</a><a asp-action="AdditionalInfo" class="carrier-button-secondary">Additional info</a></div>
            </aside>
            <div class="p-6 md:p-8">
                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                    @Info("Phone", profile.PhoneNumber)
                    @Info("Address", profile.Address.ToString())
                    @Info("City", profile.CityName)
                    @Info("Government", profile.GovernmentName)
                    @Info("Country", profile.CountryName)
                    @Info("License", profile.LicenseNumber)
                    @Info("Rating", profile.Rating.ToString("N1"))
                    @Info("Experience", $"{profile.Experience} years")
                    @Info("Cost per kg", profile.DefaultCostPerKg.ToString("N2"))
                </div>
            </div>
        </div>
    </div>

    <section class="carrier-card mt-6 p-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div><h3 class="text-xl font-black text-[#111111]">Vehicle snapshot</h3><p class="mt-1 text-sm text-[#66615a]">Main vehicle currently linked to this carrier profile.</p></div>
            <a asp-area="CarrierArea" asp-controller="Vehicles" asp-action="Index" class="carrier-button-secondary">Open vehicle</a>
        </div>
        @if (vehicle is null)
        {
            <div class="carrier-panel mt-5 p-5 text-sm font-bold text-[#66615a]">No vehicle returned from the backend yet.</div>
        }
        else
        {
            <div class="mt-5 grid gap-4 md:grid-cols-4">
                @Info("Plate", vehicle.PlateNumber)
                @Info("Type", vehicle.VehicleType.ToString())
                @Info("Weight", $"{vehicle.CapacityWeight:N2} kg")
                @Info("Active", vehicle.IsActive ? "Yes" : "No")
            </div>
        }
    </section>
</section>

@functions {
    private static string Display(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value;
    private IHtmlContent Info(string label, string? value) => new HtmlString($"<div class=\"carrier-panel p-4\"><div class=\"text-[10px] font-black uppercase tracking-[0.16em] text-[#737373]\">{label}</div><div class=\"mt-2 text-sm font-black text-[#111111]\">{Display(value, "-")}</div></div>");
    private static string BadgeClass(string value) => value.ToLowerInvariant().Contains("active") || value.ToLowerInvariant().Contains("available") ? "carrier-badge-success" : "carrier-badge-neutral";
}