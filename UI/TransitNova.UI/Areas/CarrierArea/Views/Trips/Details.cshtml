@model UiCarrierTripDto?
@{
    ViewData["Title"] = "Trip Details";
    var trip = Model ?? new UiCarrierTripDto();
    var shipments = trip.Shipments?.ToList() ?? [];
    var canComplete = IsTripCompletable(trip);
}

<section class="carrier-fade-up">
    <div class="carrier-card overflow-hidden">
        <div class="grid gap-0 lg:grid-cols-[1fr_360px]">
            <div class="p-6 md:p-8">
                <div class="carrier-badge @BadgeClass(trip.Status.ToString())">@trip.Status</div>
                <h2 class="mt-5 text-4xl font-black tracking-[-0.04em] text-[#111111]">@trip.TripType trip</h2>
                <p class="mt-3 text-sm leading-6 text-[#66615a]">@trip.WarehouseName - @trip.WarehouseAddress</p>
                <div class="mt-6 flex flex-wrap gap-3">
                    <a asp-action="Index" class="carrier-button-secondary">Back to trips</a>
                    @if (canComplete)
                    {
                        <form asp-action="Complete" asp-route-tripId="@trip.Id" method="post" data-loading-form data-loading-text="Completing...">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="carrier-button"><span class="carrier-spinner hidden" data-button-spinner></span><span data-button-text>Complete Trip</span></button>
                        </form>
                    }
                    else if (trip.Status == TripStatus.Completed)
                    {
                        <span class="carrier-button-disabled">Trip Done</span>
                    }
                </div>
            </div>
            <aside class="border-t border-[#E7E5E0] bg-[#FBFBFA] p-6 lg:border-l lg:border-t-0">
                <dl class="space-y-3 text-sm">
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Shipments</dt><dd class="font-black text-[#111111]">@shipments.Count</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Completed</dt><dd class="font-black text-[#111111]">@CompletedCount(trip)</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Started</dt><dd class="font-black text-[#111111]">@(trip.StartTime?.ToString("MMM dd, HH:mm") ?? "-")</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Ended</dt><dd class="font-black text-[#111111]">@(trip.EndTime?.ToString("MMM dd, HH:mm") ?? "-")</dd></div>
                </dl>
            </aside>
        </div>
    </div>

    <section class="carrier-card mt-6 overflow-hidden">
        <div class="border-b border-[#E7E5E0] p-5"><h3 class="text-xl font-black text-[#111111]">Trip shipments</h3><p class="mt-1 text-sm text-[#66615a]">Actions are available only when the shipment status allows them.</p></div>
        <div class="overflow-x-auto">
            <table class="carrier-table">
                <thead><tr><th>Tracking</th><th>Receiver</th><th>Route</th><th>Status</th><th class="text-right">Action</th></tr></thead>
                <tbody>
                @foreach (var item in shipments.Select((value, index) => new { value, index }))
                {
                    <tr style="--row-index:@item.index">
                        <td><span class="font-mono text-xs font-black text-[#111111]">@item.value.TrackingNumber</span></td>
                        <td>@item.value.Receiver.FullName<br /><span class="text-xs text-[#737373]">@item.value.Receiver.PhoneNumber</span></td>
                        <td>@item.value.PickupAddress -> @item.value.DeliveryAddress</td>
                        <td><span class="carrier-badge @BadgeClass(item.value.CurrentStatus.ToString())">@item.value.CurrentStatus</span></td>
                        <td class="text-right">
                            @if (trip.TripType == TripType.Pickup && item.value.CurrentStatus == ShipmentStatuses.OutForPickup)
                            {
                                <form asp-area="CarrierArea" asp-controller="Shipments" asp-action="PickedUp" asp-route-shipmentId="@item.value.Id" method="post" data-loading-form data-loading-text="Confirming...">@Html.AntiForgeryToken()<button class="carrier-button !min-h-[34px] !px-3 !py-2" type="submit"><span class="carrier-spinner hidden" data-button-spinner></span><span data-button-text>Pick Up</span></button></form>
                            }
                            else if (trip.TripType == TripType.Pickup && item.value.CurrentStatus == ShipmentStatuses.PickedUp)
                            {
                                <form asp-area="CarrierArea" asp-controller="Shipments" asp-action="CompletePickup" asp-route-shipmentId="@item.value.Id" method="post" data-loading-form data-loading-text="Completing...">@Html.AntiForgeryToken()<button class="carrier-button !min-h-[34px] !px-3 !py-2" type="submit"><span class="carrier-spinner hidden" data-button-spinner></span><span data-button-text>Complete Pickup</span></button></form>
                            }
                            else if (trip.TripType == TripType.Delivery && item.value.CurrentStatus == ShipmentStatuses.OutForDelivery)
                            {
                                <form asp-area="CarrierArea" asp-controller="Shipments" asp-action="CompleteDelivery" asp-route-shipmentId="@item.value.Id" method="post" data-loading-form data-loading-text="Completing...">@Html.AntiForgeryToken()<button class="carrier-button !min-h-[34px] !px-3 !py-2" type="submit"><span class="carrier-spinner hidden" data-button-spinner></span><span data-button-text>Delivered</span></button></form>
                            }
                            else if (IsShipmentDone(trip.TripType, item.value.CurrentStatus))
                            {
                                <span class="carrier-button-disabled !min-h-[34px] !px-3 !py-2">Done</span>
                            }
                            else
                            {
                                <span class="carrier-button-disabled !min-h-[34px] !px-3 !py-2">Waiting</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>

@functions {
    private static bool IsTripCompletable(UiCarrierTripDto trip) => trip.Status == TripStatus.Active && trip.Shipments.Any() && trip.TripType switch
    {
        TripType.Pickup => trip.Shipments.All(shipment => shipment.CurrentStatus == ShipmentStatuses.InWarehouse),
        TripType.Delivery => trip.Shipments.All(shipment => shipment.CurrentStatus == ShipmentStatuses.Delivered),
        _ => trip.Shipments.All(shipment => shipment.CurrentStatus is ShipmentStatuses.InWarehouse or ShipmentStatuses.Delivered)
    };
    private static int CompletedCount(UiCarrierTripDto trip) => trip.TripType switch
    {
        TripType.Pickup => trip.Shipments.Count(shipment => shipment.CurrentStatus == ShipmentStatuses.InWarehouse),
        TripType.Delivery => trip.Shipments.Count(shipment => shipment.CurrentStatus == ShipmentStatuses.Delivered),
        _ => trip.Shipments.Count(shipment => shipment.CurrentStatus is ShipmentStatuses.InWarehouse or ShipmentStatuses.Delivered)
    };
    private static bool IsShipmentDone(TripType tripType, ShipmentStatuses status) => tripType switch
    {
        TripType.Pickup => status == ShipmentStatuses.InWarehouse,
        TripType.Delivery => status == ShipmentStatuses.Delivered,
        _ => status is ShipmentStatuses.InWarehouse or ShipmentStatuses.Delivered
    };
    private static string BadgeClass(string value) { var text = value.ToLowerInvariant(); if (text.Contains("complete") || text.Contains("deliver") || text.Contains("warehouse") || text.Contains("active")) return "carrier-badge-success"; if (text.Contains("pickup") || text.Contains("assigned") || text.Contains("transit")) return "carrier-badge-info"; if (text.Contains("planned") || text.Contains("pending")) return "carrier-badge-warning"; if (text.Contains("cancel") || text.Contains("reject") || text.Contains("fail")) return "carrier-badge-danger"; return "carrier-badge-neutral"; }
}