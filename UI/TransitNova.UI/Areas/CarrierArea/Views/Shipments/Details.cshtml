@model UiRetrieveShipmentDto?
@{
    ViewData["Title"] = "Shipment Details";
    var shipment = Model ?? new UiRetrieveShipmentDto();
    var actions = ShipmentAction(shipment.CurrentStatus, shipment.Id);
}

<section class="carrier-fade-up">
    <div class="carrier-card overflow-hidden">
        <div class="grid gap-0 lg:grid-cols-[1fr_360px]">
            <div class="p-6 md:p-8">
                <div class="carrier-badge @BadgeClass(shipment.CurrentStatus.ToString())">@shipment.CurrentStatus</div>
                <h2 class="mt-5 font-mono text-3xl font-black tracking-[-0.02em] text-[#111111]">@(string.IsNullOrWhiteSpace(shipment.TrackingNumber) ? "Shipment" : shipment.TrackingNumber)</h2>
                <p class="mt-3 text-sm leading-6 text-[#66615a]">@shipment.PickupAddress -> @shipment.DeliveryAddress</p>
                <div class="mt-6 flex flex-wrap gap-3">@actions</div>
            </div>
            <aside class="border-t border-[#E7E5E0] bg-[#FBFBFA] p-6 lg:border-l lg:border-t-0">
                <div class="text-xs font-black uppercase tracking-[0.14em] text-[#737373]">Shipment metadata</div>
                <dl class="mt-4 space-y-3 text-sm">
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Shipment ID</dt><dd class="break-all text-right font-black text-[#111111]">@shipment.Id</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Receiver ID</dt><dd class="break-all text-right font-black text-[#111111]">@shipment.ReceiverId</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Sender ID</dt><dd class="break-all text-right font-black text-[#111111]">@shipment.SenderId</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Type</dt><dd class="font-black text-[#111111]">@shipment.ShipmentType</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Mode</dt><dd class="font-black text-[#111111]">@shipment.TransportationMode</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Created</dt><dd class="font-black text-[#111111]">@shipment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">ETA</dt><dd class="font-black text-[#111111]">@(shipment.EstimatedDeliveryDate?.ToString("MMM dd, yyyy HH:mm") ?? "Pending")</dd></div>
                    <div class="flex justify-between"><dt class="font-bold text-[#66615a]">Rejection</dt><dd class="font-black text-[#111111]">@(string.IsNullOrWhiteSpace(shipment.RejectionReason) ? "-" : shipment.RejectionReason)</dd></div>
                </dl>
            </aside>
        </div>
    </div>

    <section class="mt-6 grid gap-6 lg:grid-cols-[1fr_420px]">
        <div class="space-y-6">
            <div class="carrier-card p-6">
                <h3 class="text-xl font-black text-[#111111]">Package specification</h3>
                <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
                    <div class="carrier-panel p-4"><div class="carrier-label">Weight</div><div class="mt-2 font-black text-[#111111]">@shipment.PackageSpecification.Weight.ToString("N2") kg</div></div>
                    <div class="carrier-panel p-4"><div class="carrier-label">Width</div><div class="mt-2 font-black text-[#111111]">@shipment.PackageSpecification.Width.ToString("N2")</div></div>
                    <div class="carrier-panel p-4"><div class="carrier-label">Height</div><div class="mt-2 font-black text-[#111111]">@shipment.PackageSpecification.Height.ToString("N2")</div></div>
                    <div class="carrier-panel p-4"><div class="carrier-label">Length</div><div class="mt-2 font-black text-[#111111]">@shipment.PackageSpecification.Length.ToString("N2")</div></div>
                    <div class="carrier-panel p-4"><div class="carrier-label">Cost</div><div class="mt-2 font-black text-[#111111]">@shipment.ShippingCost.ToString("N2") @shipment.Currency</div></div>
                </div>
            </div>

            <div class="carrier-card p-6">
                <h3 class="text-xl font-black text-[#111111]">Receiver and sender</h3>
                <div class="mt-5 grid gap-4 md:grid-cols-2">
                    <div class="carrier-panel p-4">
                        <div class="carrier-label">Receiver</div>
                        <div class="font-black text-[#111111]">@(string.IsNullOrWhiteSpace(shipment.Receiver.FullName) ? "Receiver" : shipment.Receiver.FullName)</div>
                        <p class="mt-1 text-sm text-[#66615a]">@(string.IsNullOrWhiteSpace(shipment.Receiver.Email) ? "-" : shipment.Receiver.Email)<br />@(string.IsNullOrWhiteSpace(shipment.Receiver.PhoneNumber) ? "-" : shipment.Receiver.PhoneNumber)</p>
                        <p class="mt-3 text-sm text-[#66615a]">@shipment.Receiver.CityName<br />@shipment.Receiver.Address</p>
                    </div>
                    <div class="carrier-panel p-4">
                        <div class="carrier-label">Sender</div>
                        <div class="font-black text-[#111111]">@(string.IsNullOrWhiteSpace(shipment.Sender?.FullName) ? "Sender" : shipment.Sender.FullName)</div>
                        <p class="mt-1 text-sm text-[#66615a]">@(string.IsNullOrWhiteSpace(shipment.Sender?.Email) ? "-" : shipment.Sender.Email)<br />@(string.IsNullOrWhiteSpace(shipment.Sender?.PhoneNumber) ? "-" : shipment.Sender.PhoneNumber)</p>
                        <p class="mt-3 text-sm text-[#66615a]">@(string.IsNullOrWhiteSpace(shipment.Sender?.CityName) ? "-" : shipment.Sender.CityName)<br />@(shipment.Sender?.Address?.ToString() ?? "-")</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="carrier-card p-6">
            <h3 class="text-xl font-black text-[#111111]">Status timeline</h3>
            <div class="mt-5 space-y-3">
                @foreach (var state in shipment.ShipmentStates.Select((value, index) => new { value, index }))
                {
                    <div class="carrier-panel p-4" style="--row-index:@state.index">
                        <div class="carrier-badge @BadgeClass(state.value.StatusType.ToString())">@state.value.StatusType</div>
                        <p class="mt-2 text-xs font-bold text-[#737373]">@state.value.ChangedAt.ToString("MMM dd, yyyy HH:mm")</p>
                        <p class="mt-3 text-sm text-[#66615a]">@(string.IsNullOrWhiteSpace(state.value.Carrier?.FullName) ? "No carrier recorded for this state." : $"Carrier: {state.value.Carrier.FullName}")</p>
                        @if (!string.IsNullOrWhiteSpace(state.value.Carrier?.Email) || !string.IsNullOrWhiteSpace(state.value.Carrier?.PhoneNumber))
                        {
                            <p class="mt-1 text-xs text-[#66615a]">@state.value.Carrier?.Email @(string.IsNullOrWhiteSpace(state.value.Carrier?.PhoneNumber) ? string.Empty : $"• {state.value.Carrier?.PhoneNumber}")</p>
                        }
                    </div>
                }
                @if (!shipment.ShipmentStates.Any())
                {
                    <div class="carrier-panel p-4 text-sm font-bold text-[#66615a]">No status history returned.</div>
                }
            </div>
        </div>
    </section>
</section>

@functions {
    private IHtmlContent ShipmentAction(ShipmentStatuses status, Guid shipmentId)
    {
        if (status == ShipmentStatuses.OutForPickup) return Form("PickedUp", shipmentId, "Pick Up", "Confirming...");
        if (status == ShipmentStatuses.PickedUp) return Form("CompletePickup", shipmentId, "Complete Pickup", "Completing...");
        if (status == ShipmentStatuses.OutForDelivery) return Form("CompleteDelivery", shipmentId, "Delivered", "Completing...");
        if (status is ShipmentStatuses.InWarehouse or ShipmentStatuses.Delivered) return new HtmlString("<span class=\"carrier-button-disabled\">Done</span>");
        return new HtmlString("<span class=\"carrier-button-disabled\">No action</span>");
    }
    private IHtmlContent Form(string action, Guid shipmentId, string label, string loading) => new HtmlString($"<form method=\"post\" action=\"/CarrierArea/Shipments/{action}/{shipmentId}\" data-loading-form data-loading-text=\"{loading}\"><input name=\"__RequestVerificationToken\" type=\"hidden\" value=\"{Antiforgery()}\" /><button class=\"carrier-button\" type=\"submit\"><span class=\"carrier-spinner hidden\" data-button-spinner></span><span data-button-text>{label}</span></button></form>");
    private string Antiforgery() => Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>().GetAndStoreTokens(Context).RequestToken ?? string.Empty;
    private static string BadgeClass(string value) { var text = value.ToLowerInvariant(); if (text.Contains("deliver") || text.Contains("warehouse")) return "carrier-badge-success"; if (text.Contains("pickup") || text.Contains("transit") || text.Contains("assigned")) return "carrier-badge-info"; if (text.Contains("pending") || text.Contains("planned")) return "carrier-badge-warning"; if (text.Contains("cancel") || text.Contains("reject") || text.Contains("fail")) return "carrier-badge-danger"; return "carrier-badge-neutral"; }
}
